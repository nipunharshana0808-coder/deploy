// @ts-nocheck
import React, { useState, useEffect } from "react";import {  FileText,  Plus,  Trash2,  ShieldCheck,  Sparkles,  UploadCloud,  CheckCircle,  HelpCircle,  Eye,  AlertTriangle,  FlaskConical,  Image,  Activity,  ShieldAlert,  X,  Dna,  Users,  Award,  TrendingUp,} from "lucide-react";import {  Patient,  ONCOLOGY_TYPES,  Allergies,  SocialHistory,  Investigations,} from "../new-patient-types";import { STAGING_OPTIONS, HISTOLOGICAL_GRADING_OPTIONS } from "../data/staging";import { COUNTRY_CODES } from "../data";interface PatientFormProps {  existingPatientId?: string;  initialData?: any;  onClearInitialData?: () => void;  onSaveSuccess: () => void;  onCancel: () => void;}const emptyAllergies: Allergies = {  foods: [],  drugs: [],  plasters: [],  others: [],};const emptySocial: SocialHistory = {  smoking: { status: "Non consumer", amounts: "" },  alcohol: { status: "Non consumer", amounts: "" },};const emptyInvestigations: Investigations = {  imaging: [],  biopsies: [],  endoscopy: [],  ihc: [],  genetic: [],  tumour_markers: [],  others: [],};const calculateStays = (surg: any) => {  if (!surg) return surg;  const sIcuIn = surg.icu_entry_date    ? new Date(surg.icu_entry_date).getTime()    : NaN;  const sIcuOut = surg.icu_exit_date    ? new Date(surg.icu_exit_date).getTime()    : NaN;  let localIcuStay = 0;  if (    surg.icu_entered === "Yes" &&    !isNaN(sIcuIn) &&    !isNaN(sIcuOut) &&    sIcuOut >= sIcuIn  ) {    localIcuStay = Math.ceil((sIcuOut - sIcuIn) / 86400000);  }  const sWardIn = surg.after_surgery_ward_entry_date    ? new Date(surg.after_surgery_ward_entry_date).getTime()    : NaN;  const sWardOut = surg.after_surgery_discharged_date    ? new Date(surg.after_surgery_discharged_date).getTime()    : NaN;  let localWardStay = 0;  if (!isNaN(sWardIn) && !isNaN(sWardOut) && sWardOut >= sWardIn) {    localWardStay = Math.ceil((sWardOut - sWardIn) / 86400000);  }  return {    ...surg,    icu_stay_days: localIcuStay,    hospital_stay_days: localIcuStay + localWardStay,  };};const initialFormState: Omit<  Patient,  "patient_id" | "created_at" | "updated_at"> = {  consent_taken: false,  consent_date: "",  initials: "",  last_name: "",  nic: "",  bht_no: "",  clinic_no: "",  record_id: "",  tp: "",  tp_countryCode: "+94",  title: "",  oncology_type: [],  other_oncology_type: "",  dob: "",  age_display: "",  gender: "",  living_area: "",  hospital_location: "",  hospital_type: "",  hospital_name: "",  marital_status: "",  occupation: "",  presenting_complaints: [],  comorbidities: [],  hospital_admissions: [],  past_surgeries: [],  drug_history: [],  family_history: [],  risk_factors: [],  examination_findings: [],  problems: [],  usual_prescriptions: [],  allergies: emptyAllergies,  social_history: emptySocial,  provisional_diagnosis: "",  final_diagnosis: "",  other_notes: "",  investigations: emptyInvestigations,  neo_adjuvant_chemotherapy: {    status: "Not done",    date: "",    drug_name: "",    dose: "",    frequency: "",    route: "",    duration: "",    adverse_effects: "",    notes: "",  },  neo_adjuvant_radiotherapy: {    status: "Not done",    sessions: [],    type_name: "",    date: "",    site: "",    dose: "",    frequency: "",    approach: "",    cycles: "",    adverse_effects: "",    notes: "",  },  adjuvant_chemotherapy: {    status: "Not done",    date: "",    drug_name: "",    dose: "",    frequency: "",    route: "",    duration: "",    adverse_effects: "",    notes: "",  },  adjuvant_radiotherapy: {    status: "Not done",    sessions: [],    type_name: "",    date: "",    site: "",    dose: "",    frequency: "",    approach: "",    cycles: "",    adverse_effects: "",    notes: "",  },  surgeries: [    {      procedure_name: "",      surgery_site: "",      done_date: "",      approach: "",      icu_entered: "No",      icu_entry_date: "",      icu_exit_date: "",      icu_management_notes: "",      icu_stay_days: 0,      after_surgery_ward_entry_date: "",      after_surgery_discharged_date: "",      ward_management_notes: "",      hospital_stay_days: 0,      margin_status: "",      complications: [],      monitoring: [],      other_surgical_notes: "",    },  ],  staging_details: [    { staging_system_name: "TNM", overall_stage: "", staging_notes: "" },  ],  histological_staging_details: [    {      staging_system_name: "Broders (WHO General Grading)",      overall_stage: "",      staging_notes: "",    },  ],  preop_assessment: {    date: "",    asa_physical_status: "",    clerked_by: "",    anesthesia_plan: "",    risk_assessment_scores: "",    special_investigations: "",    preop_orders: "",    fitness_status: "",    met_score: "",    notes: "",  },  mdt_discussion: {    discussed: "Pending",    mdt_date: "",    mdt_panel_members: "",    recommendations: "",    molecular_tumor_board: false,    mdt_treatment_alignment: "Not Evaluated",    mdt_deviation_reason: "",  },  genomic_biomarkers: {    her2_status: "Not Tested",    er_status: "Not Tested",    pr_status: "Not Tested",    msi_status: "Not Tested",    brca_status: "Not Tested",    kras_nras_pik3ca: "",    egfr_alk_ros1: "",    pd_l1_cps_tps: "",  },  onco_surgical_audit: {    resection_margin_r0_r1_r2: "Rx",    total_lymph_nodes_harvested: 0,    positive_lymph_nodes: 0,    lymph_node_ratio: 0,    lymphovascular_invasion: "Equivocal",    perineural_invasion: "Equivocal",    biobanking_sample_stored: "No",    biobank_id: "",    clavien_dindo_grade: "",    closest_crm_mm: undefined,    tumor_regression_grade: "Not Applicable (No Neoadjuvant Tx)",    synoptic_pathology_reporting: "N/A",    biobank_tissue_type: "FFPE Block",  },  clinical_research_trial: {    trial_enrolled: "No",    trial_name_code: "",    study_type: "",    disease_free_survival_months: 0,    overall_survival_months: 0,    recurrence_detected: "No",    recurrence_date: "",    recurrence_site: "",    last_followup_status: "Alive and disease-free",    treatment_response_recist: "Not Evaluated",    treatment_toxicity_ctcae: "None",    qol_score_percentage: undefined,    unplanned_30day_readmission: "No",    unplanned_return_to_theatre: "No",  },  follow_up_notes: [],};export default function PatientForm({  existingPatientId,  initialData,  onClearInitialData,  onSaveSuccess,  onCancel,}: PatientFormProps): React.ReactElement {  const [formData, setFormData] =    useState<Omit<Patient, "patient_id" | "created_at" | "updated_at">>(      initialFormState,    );  const [loading, setLoading] = useState(false);  const [error, setError] = useState("");  /* Tabbed investigations selection */ const [activeInvTab, setActiveInvTab] =    useState<      | "imaging"      | "biopsies"      | "endoscopy"      | "ihc"      | "genetic"      | "tumour_markers"      | "others"    >("imaging");  /* AI extraction visual state indicators (for highlighting form fields) */ const [aiFilledFields, setAiFilledFields] = useState<Set<string>>(new Set()); const [aiExtracting, setAiExtracting] = useState(false); const [aiSuccessMessage, setAiSuccessMessage] = useState("");/* Media attachment files upload list state */ const [attachments, setAttachments] = useState<any[]>([]); const [uploadingAttachment, setUploadingAttachment] = useState(false);/* Load existing patient details if in edit mode */ useEffect(() => { if (existingPatientId) { setLoading(true); fetch(`/api/patients/${existingPatientId}`) .then((res) => { if (!res.ok) throw new Error("Failed to load patient record."); return res.json(); }) .then((data) => { setFormData({ ...initialFormState, ...data, mdt_discussion: { ...initialFormState.mdt_discussion, ...(data.mdt_discussion || {}), }, genomic_biomarkers: { ...initialFormState.genomic_biomarkers, ...(data.genomic_biomarkers || {}), }, onco_surgical_audit: { ...initialFormState.onco_surgical_audit, ...(data.onco_surgical_audit || {}), }, clinical_research_trial: { ...initialFormState.clinical_research_trial, ...(data.clinical_research_trial || {}), }, surgeries: (data.surgeries || []).map((s: any) => calculateStays(s)), investigations: { ...emptyInvestigations, ...(data.investigations || {}), others: data.investigations?.others || data.investigations?.other || [], }, staging_details: data.staging_details || initialFormState.staging_details, histological_staging_details: data.histological_staging_details || initialFormState.histological_staging_details, }); setLoading(false); }) .catch((err) => { setError(err.message); setLoading(false); });/* Load associated media records */ fetch(`/api/files?patientId=${encodeURIComponent(existingPatientId)}`) .then((res) => res.json()) .then((mediaItems) => setAttachments(mediaItems.map((item: any) => ({ ...item, public_id: item.id, original_filename: item.name, secure_url: item.webViewLink || item.webContentLink || "", created_at: item.uploadDate, bytes: item.size, upload_type: item.extracted ? "ai_extracted" : "manual", })))) .catch((err) => console.error("Failed to load media attachments", err)); } }, [existingPatientId]);/* Load initial extracted data from global state if present */ useEffect(() => { if (initialData && !existingPatientId) { setFormData((prev) => { const merged = { ...initialFormState, ...initialData, };/* Ensure lists/structures are present and merged */ merged.surgeries = (initialData.surgeries || initialFormState.surgeries || []).map((s: any) => calculateStays(s)); merged.presenting_complaints = initialData.presenting_complaints || initialFormState.presenting_complaints || []; merged.comorbidities = initialData.comorbidities || initialFormState.comorbidities || []; merged.family_history = initialData.family_history || initialFormState.family_history || []; merged.risk_factors = initialData.risk_factors || initialFormState.risk_factors || []; merged.usual_prescriptions = initialData.usual_prescriptions || initialFormState.usual_prescriptions || []; if (initialData.imaging || initialData.biopsies) { merged.investigations = { ...emptyInvestigations, imaging: initialData.imaging || [], biopsies: initialData.biopsies || [], endoscopy: initialData.endoscopy || [], ihc: initialData.ihc || [], genetic: initialData.genetic || [], tumour_markers: initialData.tumour_markers || [], others: initialData.others || [], }; } merged.consent_taken = true; merged.consent_date = new Date().toISOString().split("T")[0]; return merged; });/* Highlight the fields that were parsed */ const filledSet = new Set<string>(); Object.keys(initialData).forEach((k) => { if (initialData[k] !== undefined && initialData[k] !== null) { filledSet.add(k); } }); filledSet.add("consent_taken"); setAiFilledFields(filledSet); setAiSuccessMessage("Successfully imported clinical oncology indicators extracted by Gemini AI!"); if (onClearInitialData) { onClearInitialData(); } } }, [initialData, existingPatientId, onClearInitialData]); useEffect(() => { if (!formData.record_id && (formData.nic || formData.bht_no)) { const date = new Date().toISOString().split('T')[0].replace(/-/g, "");/* YYYYMMDD */ const time = new Date().toTimeString().split(' ')[0].replace(/:/g, "");/* HHMMSS */ const recordNum = formData.nic || formData.bht_no || "000"; const id = `${date}${time}-${recordNum}`; setFormData(prev => ({ ...prev, record_id: id })); } }, [formData.nic, formData.bht_no]); useEffect(() => { if (formData.dob) { const today = new Date(); const birthDate = new Date(formData.dob); let years = today.getFullYear() - birthDate.getFullYear(); let months = today.getMonth() - birthDate.getMonth(); let days = today.getDate() - birthDate.getDate(); if (days < 0) { months--; const previousMonth = new Date(today.getFullYear(), today.getMonth(), 0); days += previousMonth.getDate(); } if (months < 0) { years--; months += 12; } const age_display = `${years} years, ${months} months, ${days} days`; setFormData((prev) => ({ ...prev, age_display })); } }, [formData.dob]);/* AI Extraction Drag and Drop */ const handleAiExtractUpload = async ( e: React.ChangeEvent<HTMLInputElement>, ) => { const file = e.target.files?.[0]; if (!file) return; setAiExtracting(true); setError(""); setAiSuccessMessage(""); const reader = new FileReader(); reader.readAsDataURL(file); reader.onload = async () => { try { const base64String = reader.result as string;/* 1. Submit to Gemini AI extraction API */ const extractRes = await fetch("/api/extract", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ fileContent: base64String, mimeType: file.type, fileName: file.name, patientId: existingPatientId || undefined, }), }); const extractData = await extractRes.json(); if (!extractRes.ok) throw new Error( extractData.error || "Gemini document extraction failed.", ); const { driveFile: _driveFile, ...aiResult } = extractData;/* 2. Map AI extracted parameters back to the patient form state */ setFormData((prev) => { const filled = new Set<string>(); const updated = { ...prev }; Object.keys(aiResult).forEach((key) => { if (aiResult[key] !== undefined && aiResult[key] !== null) { if (Array.isArray(aiResult[key])) { if (aiResult[key].length > 0) { (updated as any)[key] = aiResult[key]; filled.add(key); } } else if (typeof aiResult[key] === "object") { (updated as any)[key] = { ...(updated as any)[key], ...aiResult[key], }; filled.add(key); } else { (updated as any)[key] = aiResult[key]; filled.add(key); } } });/* Always ensure consent stays toggled appropriately but keep consent flow if user wants */ setAiFilledFields(filled); return updated; });/* 3. Keep a manual attachment mapping */ setAiSuccessMessage( `Gemini AI successfully parsed '${file.name}'. Requisite values imported for clinician review.`, ); if (extractData.driveFile && existingPatientId) { setAttachments((prev) => [...prev, { public_id: extractData.driveFile.id, original_filename: file.name, secure_url: extractData.driveFile.webViewLink || "", created_at: new Date().toISOString(), bytes: Number(extractData.driveFile.size || file.size), upload_type: "ai_extracted", }]); } } catch (err: any) { setError(`AI Parsing Failed: ${err.message}`); } finally { setAiExtracting(false); } }; };   Regular Attachment Upload const handleManualAttachmentUpload = async ( e: React.ChangeEvent<HTMLInputElement>, ) => { const file = e.target.files?.[0]; if (!file) return; setUploadingAttachment(true); const reader = new FileReader(); reader.readAsDataURL(file); reader.onload = async () => { try { if (!existingPatientId) { throw new Error("Save the patient record before uploading attachments."); } const res = await fetch("/api/files", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ patientId: existingPatientId, name: file.name, mimeType: file.type, size: file.size, contentBase64: reader.result as string, extracted: false, }), }); const data = await res.json(); if (!res.ok) throw new Error(data.error || "Failed to attach file."); setAttachments((prev) => [...prev, { ...data, public_id: data.id, original_filename: data.name, secure_url: data.webViewLink || data.webContentLink || "", created_at: data.uploadDate, bytes: data.size, upload_type: "manual", }]); } catch (err: any) { setError(`Upload Failed: ${err.message}`); } finally { setUploadingAttachment(false); } }; };/* Delete an attachment */ const handleDeleteAttachment = async (publicId: string) => { try { const res = await fetch(`/api/files/${publicId}`, { method: "DELETE", }); const data = await res.json(); if (!res.ok) throw new Error(data.error || "Failed to delete attachment."); setAttachments((prev) => prev.filter((a) => a.public_id !== publicId)); } catch (err: any) { setError(err.message); } };/* Form saving logic */ const handleSave = async (e: React.FormEvent) => { e.preventDefault(); if (!formData.consent_taken) { setError( "You must confirm informed patient consent prior to saving clinical records!", ); return; } setLoading(true); setError(""); try { const endpoint = existingPatientId ? `/api/patients/${existingPatientId}` : "/api/patients"; const method = existingPatientId ? "PUT" : "POST";/* Assemble full patient body (preserving unique patient ID generated on backend if new) */ const finalPatientBody = { ...formData, patient_id: existingPatientId || undefined, id: existingPatientId || undefined, record_id: formData.record_id || `${new Date().toISOString().split('T')[0].replace(/-/g, "")}${new Date().toTimeString().split(' ')[0].replace(/:/g, "")}-${formData.nic || formData.bht_no || "000"}` }; const res = await fetch(endpoint, { method, headers: { "Content-Type": "application/json" }, body: JSON.stringify(finalPatientBody), }); const data = await res.json(); if (!res.ok) throw new Error(data.error || "Failed to commit patient file.");/* If we uploaded media under temporary patient, update their ID inside media db! */ if (!existingPatientId) {/* Simple client trigger } onSaveSuccess(); } */ catch (err: any) { setError(err.message); } finally { setLoading(false); } };   Helper arrays manipulators const addArrayRow = ( field: keyof Omit<Patient, "patient_id" | "created_at" | "updated_at">, defaultTemplate: any, ) => { setFormData((prev) => ({ ...prev, [field]: [...((prev[field] as any[]) || []), defaultTemplate], })); }; const removeArrayRow = ( field: keyof Omit<Patient, "patient_id" | "created_at" | "updated_at">, index: number, ) => { setFormData((prev) => { const list = [...(prev[field] as any[])]; list.splice(index, 1); return { ...prev, [field]: list }; }); }; const updateArrayField = ( field: keyof Omit<Patient, "patient_id" | "created_at" | "updated_at">, index: number, subKey: string, val: any, ) => { setFormData((prev) => { const list = ((prev[field] || []) as any[]).map((item, id) => { if (id === index) { return { ...item, [subKey]: val }; } return item; }); return { ...prev, [field]: list }; }); }; const calculateBMI = (heightCm: string, weightKg: string) => { const h = parseFloat(heightCm); const w = parseFloat(weightKg); if (h > 0 && w > 0) { const hMeter = h / 100; return (w / (hMeter * hMeter)).toFixed(2); } return ""; }; const calculateBSA = (heightCm: string, weightKg: string) => { const h = parseFloat(heightCm); const w = parseFloat(weightKg); if (h > 0 && w > 0) { return Math.sqrt((h * w) / 3600).toFixed(2); } return ""; }; const updateAnthroValues = (date: string, type: "Height" | "Weight", value: string) => { setFormData((prev) => { const otherFindings = (prev.examination_findings || []).filter( (f) => f.date !== date || f.examination_type === "Organ System", ); const dateFindings = (prev.examination_findings || []).filter( (f) => f.date === date && f.examination_type !== "Organ System", ); let hVal = dateFindings.find((f) => f.examination_type === "Height")?.findings || ""; let wVal = dateFindings.find((f) => f.examination_type === "Weight")?.findings || ""; if (type === "Height") hVal = value; if (type === "Weight") wVal = value; const bmi = calculateBMI(hVal, wVal); const bsa = calculateBSA(hVal, wVal); const updatedDateSet: any[] = []; if (hVal !== "" || type === "Height") updatedDateSet.push({ examination_type: "Height", date, findings: hVal }); if (wVal !== "" || type === "Weight") updatedDateSet.push({ examination_type: "Weight", date, findings: wVal }); if (bmi) updatedDateSet.push({ examination_type: "BMI", date, findings: bmi }); if (bsa) updatedDateSet.push({ examination_type: "BSA", date, findings: bsa }); return { ...prev, examination_findings: [...otherFindings, ...updatedDateSet] }; }); }; const removeAnthroSet = (date: string) => { setFormData((prev) => ({ ...prev, examination_findings: (prev.examination_findings || []).filter( (f) => f.date !== date || f.examination_type === "Organ System", ), })); };   Surgery complications list helpers const addSurgComplicationRow = (surgIdx: number) => { setFormData((prev) => { const newSurgeries = [...(prev.surgeries || [])]; if (!newSurgeries[surgIdx]) return prev; newSurgeries[surgIdx] = { ...newSurgeries[surgIdx], complications: [ ...(newSurgeries[surgIdx].complications || []), { complication_name: "", significant_amount: "", duration: "", notes: "" }, ], }; return { ...prev, surgeries: newSurgeries }; }); }; const removeSurgComplicationRow = (surgIdx: number, compIdx: number) => { setFormData((prev) => { const newSurgeries = [...(prev.surgeries || [])]; if (!newSurgeries[surgIdx]) return prev; const list = [...(newSurgeries[surgIdx].complications || [])]; list.splice(compIdx, 1); newSurgeries[surgIdx] = { ...newSurgeries[surgIdx], complications: list }; return { ...prev, surgeries: newSurgeries }; }); }; const updateSurgComplicationField = ( surgIdx: number, compIdx: number, subKey: string, val: any, ) => { setFormData((prev) => { const newSurgeries = [...(prev.surgeries || [])]; if (!newSurgeries[surgIdx]) return prev; const list = (newSurgeries[surgIdx].complications || []).map((item, id) => { if (id === compIdx) { return { ...item, [subKey]: val }; } return item; }); newSurgeries[surgIdx] = { ...newSurgeries[surgIdx], complications: list }; return { ...prev, surgeries: newSurgeries }; }); };   Surgery monitoring list helpers const addSurgMonitoringRow = (surgIdx: number) => { setFormData((prev) => { const newSurgeries = [...(prev.surgeries || [])]; if (!newSurgeries[surgIdx]) return prev; newSurgeries[surgIdx] = { ...newSurgeries[surgIdx], monitoring: [ ...(newSurgeries[surgIdx].monitoring || []), { post_op_day_no: "", parameter: "", findings: "" }, ], }; return { ...prev, surgeries: newSurgeries }; }); }; const addParameterForDay = (surgIdx: number, dayVal: string) => { setFormData((prev) => { const newSurgeries = [...(prev.surgeries || [])]; if (!newSurgeries[surgIdx]) return prev; newSurgeries[surgIdx] = { ...newSurgeries[surgIdx], monitoring: [ ...(newSurgeries[surgIdx].monitoring || []), { post_op_day_no: dayVal, parameter: "", findings: "" }, ], }; return { ...prev, surgeries: newSurgeries }; }); }; const addNewDaySection = (surgIdx: number) => { setFormData((prev) => { const newSurgeries = [...(prev.surgeries || [])]; if (!newSurgeries[surgIdx]) return prev; const monitoringItems = newSurgeries[surgIdx].monitoring || []; const days = monitoringItems.map(m => parseInt(m.post_op_day_no)).filter(n => !isNaN(n)); const nextDay = days.length > 0 ? Math.max(...days) + 1 : 1; newSurgeries[surgIdx] = { ...newSurgeries[surgIdx], monitoring: [ ...monitoringItems, { post_op_day_no: String(nextDay), parameter: "", findings: "" }, ], }; return { ...prev, surgeries: newSurgeries }; }); }; const removeSurgMonitoringRow = (surgIdx: number, monIdx: number) => { setFormData((prev) => { const newSurgeries = [...(prev.surgeries || [])]; if (!newSurgeries[surgIdx]) return prev; const list = [...(newSurgeries[surgIdx].monitoring || [])]; list.splice(monIdx, 1); newSurgeries[surgIdx] = { ...newSurgeries[surgIdx], monitoring: list }; return { ...prev, surgeries: newSurgeries }; }); }; const updateSurgMonitoringField = ( surgIdx: number, monIdx: number, subKey: string, val: any, ) => { setFormData((prev) => { const newSurgeries = [...(prev.surgeries || [])]; if (!newSurgeries[surgIdx]) return prev; const list = (newSurgeries[surgIdx].monitoring || []).map((item, id) => { if (id === monIdx) { return { ...item, [subKey]: val }; } return item; }); newSurgeries[surgIdx] = { ...newSurgeries[surgIdx], monitoring: list }; return { ...prev, surgeries: newSurgeries }; }); };/* Oncology type selection handler */ const handleOncologySelect = (type: string) => { setFormData((prev) => { const current = [...prev.oncology_type]; const index = current.indexOf(type); if (index === -1) { current.push(type); } else { current.splice(index, 1); } return { ...prev, oncology_type: current }; }); };/* Rendering fields helper classes */ const getFieldClass = (key: string) => { const base = "w-full bg-slate-50 dark:bg-slate-900 border text-slate-800 dark:text-slate-100 rounded-lg px-3 py-1.5 focus:outline-none focus:ring-1 text-sm "; if (aiFilledFields.has(key)) { return ( base + "border-blue-500 ring-1 ring-blue-500/50 bg-blue-50 dark:bg-blue-950/25" ); } return ( base + "border-neutral-300 dark:border-slate-700/80 focus:ring-blue-500/50 focus:border-blue-600" ); };   Surgical duration / stay calculator variables const icuEntry = formData.surgery?.icu_entry_date; const icuExit = formData.surgery?.icu_exit_date; const icuStayDays = (() => { if (formData.surgery?.icu_entered !== "Yes" || !icuEntry || !icuExit) return 0; const d1 = new Date(icuEntry); const d2 = new Date(icuExit); if (isNaN(d1.getTime()) || isNaN(d2.getTime())) return 0; const diff = Math.ceil( (d2.getTime() - d1.getTime()) / (1000 * 60 * 60 * 24), ); return diff >= 0 ? diff : 0; })(); const wardEntry = formData.surgery?.after_surgery_ward_entry_date; const wardExit = formData.surgery?.after_surgery_discharged_date; const wardStayDays = (() => { if (!wardEntry || !wardExit) return 0; const d1 = new Date(wardEntry); const d2 = new Date(wardExit); if (isNaN(d1.getTime()) || isNaN(d2.getTime())) return 0; const diff = Math.ceil( (d2.getTime() - d1.getTime()) / (1000 * 60 * 60 * 24), ); return diff >= 0 ? diff : 0; })(); const surgDate = formData.surgery?.done_date; const hospitalStayDays = (() => { if (!surgDate || !wardExit) return 0; const d1 = new Date(surgDate); const d2 = new Date(wardExit); if (isNaN(d1.getTime()) || isNaN(d2.getTime())) return 0; const diff = Math.ceil( (d2.getTime() - d1.getTime()) / (1000 * 60 * 60 * 24), ); return diff >= 0 ? diff : 0; })(); const complicationsCount = (formData.surgery?.complications || []).length; return ( <div id="patient-form-view" className="space-y-8 animate-fade-in text-neutral-800 dark:text-neutral-100 pb-16" > {/* View Header */} <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pb-6"> <div> <h1 className="text-3xl font-bold flex items-center gap-2"> <FileText className="w-8 h-8 text-blue-600 dark:text-blue-500" /> {existingPatientId ? "Revise Patient Document" : "Provisional Oncology Admission Form"} </h1> <p className="text-sm text-neutral-500 mt-1"> Populate, review, and persist clinical data conforming to standards. </p> </div> <div className="flex gap-3"> <button id="back_btn" type="button" onClick={onCancel} className="px-4 py-2 text-slate-700 dark:text-slate-300 rounded-lg text-sm bg-white dark:bg-slate-800 hover:bg-neutral-50 dark:hover:bg-slate-700 transition" > Cancel and Discard </button> </div> </div> {/* ERROR MSG CONTAINER */} {error && ( <div className="p-4 rounded-xl bg-rose-500/10 border border-rose-500/30 text-rose-600 dark:text-rose-400 text-sm flex gap-2 items-center"> <ShieldAlert className="w-5 h-5 flex-shrink-0" /> <span>{error}</span> </div> )} <form onSubmit={handleSave} className="space-y-8"> {/* SECTION 1: CONSENT GATEWAY CHECKBOX */} <div className="bg-blue-500/5 dark:bg-blue-500/5 rounded-2xl p-6 space-y-4"> <div className="flex items-start gap-4"> <div className="p-3 bg-blue-500/10 text-blue-600 dark:text-blue-400 rounded-xl mt-0.5"> <ShieldCheck className="w-6 h-6" /> </div> <div className="space-y-1"> <h3 className="text-base font-bold text-slate-800 dark:text-white"> Informed Patient Clinical Consent Declarations </h3> <p className="text-xs text-neutral-500 leading-relaxed"> As required by international laws, the practitioner must obtain full informed verbal and written medical consent from the patient prior to database storage. </p> </div> </div> <div className="pt-4 border-t border-blue-500/10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4"> <label className="flex items-center gap-3 cursor-pointer select-none"> <input id="consent_checkbox" type="checkbox" checked={formData.consent_taken} onChange={(e) => { setFormData((prev) => ({ ...prev, consent_taken: e.target.checked, consent_date: e.target.checked ? new Date().toISOString().split("T")[0] : "", })); }} className="accent-blue-650 w-5 h-5 rounded" /> <span className="text-xs font-semibold text-slate-700 dark:text-slate-300"> Informed consent has been taken and documented from input patient </span> </label> {formData.consent_taken && ( <div className="flex items-center gap-2"> <span className="text-xs text-neutral-500"> Date of Declaration: </span> <input id="consent_date_input" type="date" value={formData.consent_date || ""} onChange={(e) => setFormData((prev) => ({ ...prev, consent_date: e.target.value, })) } className="bg-white dark:bg-slate-900 border dark:border-slate-800 text-xs px-2.5 py-1 rounded" /> </div> )} </div> </div> {/* LOCK COVER SCREEN GUARD */} {!formData.consent_taken && ( <div className="bg-slate-500/5 border text-center border-dashed rounded-2xl p-8 flex flex-col items-center justify-center gap-2"> <AlertTriangle className="w-8 h-8 text-amber-500" /> <p className="text-sm font-semibold text-neutral-500"> All Admissions form inputs are locked until you acknowledge the "Informed Patient Clinical Consent Declarations" check above. </p> </div> )} {/* CORE FORM FIELDS (FROZEN UNLESS CONSENT=TRUE) */} <div className={`space-y-8 transition-opacity duration-300 ${formData.consent_taken ? "opacity-100" : "opacity-30 pointer-events-none"}`} > {/* INTAKE HUB: AI AUTO-EXTRACTION & MANUAL UPLOAD DIRECT PORTALS */} <div className="bg-gradient-to-br from-indigo-50/45 to-blue-50/20 dark:from-indigo-950/20 dark:to-slate-900 p-6 rounded-2xl shadow-sm space-y-6"> <div className="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b dark:border-slate-800 pb-4"> <div className="space-y-1"> <h2 className="text-lg font-bold flex items-center gap-2 text-indigo-900 dark:text-indigo-400"> <Sparkles className="w-5 h-5 text-indigo-600 dark:text-indigo-400" /> Clinical Document Smart Hub </h2> </div> {aiFilledFields.size > 0 && ( <div className="flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/30 text-emerald-600 dark:text-emerald-400 px-3 py-1.5 rounded-lg text-xs font-semibold"> <CheckCircle className="w-4 h-4" /> <span>AI Extracted {aiFilledFields.size} fields!</span> <button type="button" onClick={() => setAiFilledFields(new Set())} className="underline text-[10px] hover:text-emerald-700 ml-1.5" > Dismiss Highlights </button> </div> )} </div> <div className="grid grid-cols-1 md:grid-cols-2 gap-6"> {/* PORTAL A: AI INTELLIGENT CLINICAL EXTRACTION */} <div className="bg-white dark:bg-slate-800/80 p-5 rounded-xl shadow-sm flex flex-col justify-between space-y-4"> <div className="space-y-1.5"> <span className="text-[10px] bg-indigo-100 dark:bg-indigo-950/60 text-indigo-700 dark:text-indigo-300 px-2 py-0.5 rounded font-bold uppercase tracking-wider font-mono"> Option A: Gemini Auto-Parse </span> <h3 className="text-sm font-bold text-slate-800 dark:text-slate-100">AI Clinical Auto-Extractor</h3> </div> <div> <label className="relative flex flex-col items-center justify-center border border-dashed border-indigo-500/40 hover:border-indigo-500 hover:bg-indigo-50/10 dark:hover:bg-indigo-950/10 transition rounded-xl p-6 cursor-pointer text-center group min-h-[140px]"> {aiExtracting ? ( <div className="space-y-3 py-2"> <div className="w-6 h-6 rounded-full border-3 border-indigo-600 border-t-transparent animate-spin mx-auto"></div> <span className="text-[11px] font-semibold text-indigo-600 dark:text-indigo-400 block animate-pulse"> Analyzing clinical syntax... </span> </div> ) : ( <div className="space-y-2"> <Sparkles className="w-8 h-8 text-indigo-500 group-hover:scale-110 duration-200 mx-auto" /> <div> <span className="text-xs font-semibold text-slate-700 dark:text-slate-200 block border-0 cursor-pointer"> Upload Clinical File to Auto-Fill Form </span> <span className="text-[10px] text-neutral-400 block mt-0.5"> PDF, Scans, Images, Reports (max 10MB) </span> </div> </div> )} <input id="ai_extractor_form_input" type="file" accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.txt" onChange={handleAiExtractUpload} disabled={aiExtracting} className="hidden" /> </label> </div> {aiSuccessMessage && ( <div className="text-[11px] bg-slate-50 dark:bg-slate-900 border dark:border-slate-800 p-2 rounded text-emerald-600 dark:text-emerald-400 leading-snug"> {aiSuccessMessage} </div> )} </div> {/* PORTAL B: DIRECT FILE ATTACHMENT VAULT */} <div className="bg-white dark:bg-slate-800/80 p-5 rounded-xl shadow-sm flex flex-col justify-between space-y-4"> <div className="space-y-1.5"> <span className="text-[10px] bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300 px-2 py-0.5 rounded font-bold uppercase tracking-wider font-mono"> Option B: Simple Direct Upload </span> <h3 className="text-sm font-bold text-slate-800 dark:text-slate-100">Attach Scans / Reports to Vault</h3> </div> <div> <label className="relative flex flex-col items-center justify-center border border-dashed border-slate-300 dark:border-slate-600 hover:border-slate-400 hover:bg-slate-50/50 dark:hover:bg-slate-700/20 transition rounded-xl p-6 cursor-pointer text-center group min-h-[140px]"> {uploadingAttachment ? ( <div className="space-y-3 py-2"> <div className="w-6 h-6 rounded-full border-3 border-emerald-600 border-t-transparent animate-spin mx-auto"></div> <span className="text-[11px] font-semibold text-emerald-600 dark:text-emerald-400 block animate-pulse"> Uploading to clinical vault... </span> </div> ) : ( <div className="space-y-2"> <UploadCloud className="w-8 h-8 text-neutral-400 group-hover:scale-110 duration-200 mx-auto" /> <div> <span className="text-xs font-semibold text-slate-700 dark:text-slate-200 block border-0 cursor-pointer"> Directly Attach Document to File Vault </span> <span className="text-[10px] text-neutral-400 block mt-0.5"> Any diagnostic file, image, or clinical record </span> </div> </div> )} <input id="manual_attacher_direct" type="file" disabled={uploadingAttachment} onChange={handleManualAttachmentUpload} className="hidden" /> </label> </div> {attachments.length > 0 && ( <div className="text-[11px] bg-slate-50 dark:bg-slate-900 border dark:border-slate-800 p-2 rounded text-slate-600 dark:text-slate-400 leading-snug"> <span className="font-semibold block text-slate-700 dark:text-slate-300 mb-1"> Vault Contents ({attachments.length}): </span> <ul className="list-disc pl-4 space-y-0.5 max-h-16 overflow-y-auto"> {attachments.slice(0, 3).map((a, i) => ( <li key={i} className="truncate">{a.original_filename}</li> ))} {attachments.length > 3 && <li>and {attachments.length - 3} more files</li>} </ul> </div> )} </div> </div> </div> {/* SECTION A: KEY IDENTIFIERS */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <h2 className="text-lg font-bold pb-3"> Section A: Core Identifiers & Contact </h2> <div className="grid grid-cols-1 md:grid-cols-3 gap-6"> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Title </label> <select id="patient_title" value={formData.title || ""} onChange={(e: any) => setFormData((prev) => ({ ...prev, title: e.target.value })) } className={getFieldClass("title")} > <option value="">Select Title</option> <option value="Mr.">Mr.</option> <option value="Mrs.">Mrs.</option> <option value="Miss">Miss</option> <option value="Dr">Dr</option> <option value="Prof">Prof</option> <option value="Rev">Rev</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Unique Record ID (Auto-Generated) </label> <input type="text" readOnly value={formData.record_id || ""} className={`${getFieldClass("record_id")} bg-slate-100 cursor-not-allowed`} placeholder="Will generate automatically..." /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Initials * </label> <input id="patient_initials" type="text" placeholder="e.g. A.B.C." value={formData.initials || ""} onChange={(e) => setFormData((prev) => ({ ...prev, initials: e.target.value, })) } className={getFieldClass("initials")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Last Name * </label> <input id="patient_lastname" type="text" placeholder="e.g. Perera" value={formData.last_name || ""} onChange={(e) => setFormData((prev) => ({ ...prev, last_name: e.target.value, })) } className={getFieldClass("last_name")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> NIC No (National ID) * </label> <input id="patient_nic" type="text" placeholder="e.g. 199015904838" value={formData.nic || ""} onChange={(e) => setFormData((prev) => ({ ...prev, nic: e.target.value })) } className={getFieldClass("nic")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Clinic Admission No </label> <input id="patient_clinic_no" type="text" placeholder="e.g. ONCO-2026-928" value={formData.clinic_no || ""} onChange={(e) => setFormData((prev) => ({ ...prev, clinic_no: e.target.value, })) } className={getFieldClass("clinic_no")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> BHT Registration No (Bed Head Ticket) </label> <input id="patient_bht_no" type="text" placeholder="e.g. BHT-4938" value={formData.bht_no || ""} onChange={(e) => setFormData((prev) => ({ ...prev, bht_no: e.target.value })) } className={getFieldClass("bht_no")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Telephone Contact * </label> <div className="flex gap-2"> <select className={`${getFieldClass("tp_countryCode")} w-32`} value={formData.tp_countryCode || "+94"} onChange={(e) => setFormData((prev) => ({ ...prev, tp_countryCode: e.target.value }))} > {COUNTRY_CODES.map((c) => ( <option key={`${c.name}-${c.code}`} value={c.code}> {c.name} ({c.code}) </option> ))} </select> <input id="patient_tp" type="text" placeholder="e.g. 77 123 4567" value={formData.tp || ""} onChange={(e) => setFormData((prev) => ({ ...prev, tp: e.target.value })) } className={`${getFieldClass("tp")} flex-grow`} /> </div> </div> </div> </div> {/* SECTION B: BIOMETRICS & BASIC DETAILS */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <h2 className="text-lg font-bold pb-3"> Section B: Demographics & Biometrics </h2> <div className="grid grid-cols-1 md:grid-cols-4 gap-6"> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Gender * </label> <select id="patient_gender" value={formData.gender || ""} onChange={(e: any) => setFormData((prev) => ({ ...prev, gender: e.target.value })) } className={getFieldClass("gender")} > <option value="">Select Gender</option> <option value="Male">Male</option> <option value="Female">Female</option> <option value="non-binary">non-binary</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Date of Birth * </label> <input id="patient_dob" type="date" value={formData.dob || ""} onChange={(e) => setFormData((prev) => ({ ...prev, dob: e.target.value })) } className={getFieldClass("dob")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Age </label> <input type="text" readOnly value={formData.age_display || ""} className={`${getFieldClass("age_display")} bg-slate-100 cursor-not-allowed`} placeholder="Calculated..." /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Marital Status </label> <select id="patient_marital" value={formData.marital_status || ""} onChange={(e: any) => setFormData((prev) => ({ ...prev, marital_status: e.target.value, })) } className={getFieldClass("marital_status")} > <option value="">Select Marriage</option> <option value="Single">Single</option> <option value="Married">Married</option> <option value="Separated">Separated</option> <option value="Divorced">Divorced</option> <option value="Widowed">Widowed</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Occupation </label> <input id="patient_occupation" type="text" placeholder="e.g. Teacher" value={formData.occupation || ""} onChange={(e) => setFormData((prev) => ({ ...prev, occupation: e.target.value, })) } className={getFieldClass("occupation")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Living Area (City / County) </label> <input id="patient_living" type="text" placeholder="e.g. Colombo" value={formData.living_area || ""} onChange={(e) => setFormData((prev) => ({ ...prev, living_area: e.target.value, })) } className={getFieldClass("living_area")} /> </div> </div> </div> {/* SECTION C: HOSPITAL INFORMATION */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <h2 className="text-lg font-bold pb-3"> Section C: Hospital Information </h2> <div className="grid grid-cols-1 md:grid-cols-3 gap-6"> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Hospital Location </label> <input id="patient_hosp_loc" type="text" placeholder="e.g. Kandy National Hospital" value={formData.hospital_location || ""} onChange={(e) => setFormData((prev) => ({ ...prev, hospital_location: e.target.value, })) } className={getFieldClass("hospital_location")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Hospital Name </label> <input id="patient_hosp_name" type="text" placeholder="e.g. NCI Maharagama" value={formData.hospital_name || ""} onChange={(e) => setFormData((prev) => ({ ...prev, hospital_name: e.target.value, })) } className={getFieldClass("hospital_name")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Hospital Type </label> <select id="patient_hosp_type" value={formData.hospital_type || ""} onChange={(e: any) => setFormData((prev) => ({ ...prev, hospital_type: e.target.value, })) } className={getFieldClass("hospital_type")} > <option value="">Select Hospital Type</option> <option value="Government">Government</option> <option value="Private">Private</option> <option value="Teaching">Teaching</option> <option value="National">National</option> <option value="Tertiary Base">Tertiary Base</option> <option value="District Hospital">District Hospital</option> <option value="Base Hospital">Base Hospital</option> <option value="General Hospital">General Hospital</option> <option value="Other">Other</option> </select> </div> </div> </div> {/* SECTION D: ONCOLOGICAL CLASSIFICATIONS */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <h2 className="text-lg font-bold pb-3"> Section D: Oncological Classifications </h2> {/* MULTI_SELECT CANCER TAXONOMY TYPES */} <div className="space-y-3"> <label className="block text-xs font-bold text-neutral-500 dark:text-neutral-400 uppercase tracking-wide"> Primary Oncology Classifications (Multi-Select Group) * </label> <div className="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-3.5 max-h-[180px] overflow-y-auto p-4 bg-slate-50 dark:bg-slate-900 border dark:border-slate-800 rounded-xl"> {ONCOLOGY_TYPES.map((type, idx) => { const isSelected = formData.oncology_type.includes(type); return ( <button key={idx} id={`oncology_type_${idx}`} type="button" onClick={() => handleOncologySelect(type)} className={`px-3 py-2 text-left rounded-lg text-xs font-semibold border transition-all ${ isSelected ? "bg-blue-600 text-white border-blue-600 shadow-sm" : "bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-300 border-neutral-200 dark:border-slate-700 hover:border-neutral-300" }`} > {type} </button> ); })} </div> <p className="text-[10px] text-slate-400"> Selected: {formData.oncology_type.join(", ") || "None Selected"} </p> {formData.oncology_type.includes("Other") && ( <div className="pt-2"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Please specify other oncology type </label> <input type="text" value={formData.other_oncology_type || ""} onChange={(e) => setFormData({ ...formData, other_oncology_type: e.target.value })} className="w-full bg-white dark:bg-slate-900 border-neutral-200 dark:border-slate-700 border text-slate-800 dark:text-slate-100 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Type other oncology classification..." /> </div> )} </div> </div> {/* SECTION E: DYNAMIC STRUCTURAL ARRAYS */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-8"> <h2 className="text-lg font-bold pb-3"> Section E: Medical & Surgical History </h2> {/* 1. PRESENTING COMPLAINTS */} <div className="space-y-4"> <div className="flex justify-between items-center text-sm"> <span className="font-bold text-slate-700 dark:text-slate-300"> 1. Presenting Complaints </span> <button id="add_complaint_row" type="button" onClick={() => addArrayRow("presenting_complaints", { complaint_name: "", duration: "", notes: "", }) } className="px-2.5 py-1 text-xs font-semibold rounded bg-emerald-500/10 text-emerald-500 hover:bg-emerald-500/20 flex items-center gap-1 border border-emerald-500/20" > <Plus className="w-3.5 h-3.5" /> Row </button> </div> <div className="overflow-x-auto"> <table className="w-full text-xs text-left"> <thead> <tr className="bg-neutral-50 dark:bg-slate-900 border-b dark:border-slate-800 text-neutral-500 font-bold uppercase tracking-wide"> <th className="p-2">Complaint Name</th> <th className="p-2">Duration</th> <th className="p-2">Additional Notes</th> <th className="p-2 w-12 text-center">Action</th> </tr> </thead> <tbody> {formData.presenting_complaints.map((item, idx) => ( <tr key={idx} className="border-b dark:border-slate-800"> <td className="p-1"> <input id={`complaint_name_${idx}`} type="text" placeholder="e.g. Cough" value={item.complaint_name || ""} onChange={(e) => updateArrayField( "presenting_complaints", idx, "complaint_name", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-emerald-500 border-none" /> </td> <td className="p-1"> <input id={`complaint_dur_${idx}`} type="text" placeholder="e.g. 2 months" value={item.duration} onChange={(e) => updateArrayField( "presenting_complaints", idx, "duration", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-emerald-500 border-none" /> </td> <td className="p-1"> <input id={`complaint_notes_${idx}`} type="text" value={item.notes || ""} onChange={(e) => updateArrayField( "presenting_complaints", idx, "notes", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-emerald-500 border-none" /> </td> <td className="p-1 text-center"> <button id={`del_complaint_${idx}`} type="button" onClick={() => removeArrayRow("presenting_complaints", idx) } className="p-1 text-rose-500 hover:text-rose-600 transition" > <Trash2 className="w-4 h-4" /> </button> </td> </tr> ))} {formData.presenting_complaints.length === 0 && ( <tr> <td colSpan={4} className="p-4 text-center text-neutral-400 font-mono" > No complaint records appended. </td> </tr> )} </tbody> </table> </div> </div> {/* 2. COMORBIDITIES */} <div className="space-y-4"> <div className="flex justify-between items-center text-sm"> <span className="font-bold text-slate-700 dark:text-slate-300"> 2. Pre-existing Comorbidities </span> <button id="add_comorbidity_row" type="button" onClick={() => addArrayRow("comorbidities", { comorbidity_name: "", duration: "", notes: "", }) } className="px-2.5 py-1 text-xs font-semibold rounded bg-emerald-500/10 text-emerald-500 hover:bg-emerald-500/20 flex items-center gap-1 border border-emerald-500/20" > <Plus className="w-3.5 h-3.5" /> Row </button> </div> <div className="overflow-x-auto"> <table className="w-full text-xs text-left"> <thead> <tr className="bg-neutral-50 dark:bg-slate-900 border-b dark:border-slate-800 text-neutral-500 font-bold uppercase tracking-wide"> <th className="p-2">Comorbidity Name</th> <th className="p-2">Duration</th> <th className="p-2">Additional Notes</th> <th className="p-2 w-12 text-center">Action</th> </tr> </thead> <tbody> {formData.comorbidities.map((item, idx) => ( <tr key={idx} className="border-b dark:border-slate-800"> <td className="p-1"> <input id={`comorb_name_${idx}`} type="text" placeholder="e.g. Hypertension" value={item.comorbidity_name || ""} onChange={(e) => updateArrayField( "comorbidities", idx, "comorbidity_name", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-emerald-500 border-none" /> </td> <td className="p-1"> <input id={`comorb_dur_${idx}`} type="text" placeholder="e.g. 5 Years" value={item.duration || ""} onChange={(e) => updateArrayField( "comorbidities", idx, "duration", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-emerald-500 border-none" /> </td> <td className="p-1"> <input id={`comorb_notes_${idx}`} type="text" value={item.notes || ""} onChange={(e) => updateArrayField( "comorbidities", idx, "notes", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-emerald-500 border-none" /> </td> <td className="p-1 text-center"> <button id={`del_comorb_${idx}`} type="button" onClick={() => removeArrayRow("comorbidities", idx)} className="p-1 text-rose-500 hover:text-rose-600 transition" > <Trash2 className="w-4 h-4" /> </button> </td> </tr> ))} {formData.comorbidities.length === 0 && ( <tr> <td colSpan={4} className="p-4 text-center text-neutral-400 font-mono" > No medical comorbidities specified. </td> </tr> )} </tbody> </table> </div> </div> {/* 3. HOSPITAL ADMISSIONS */} <div className="space-y-4"> <div className="flex justify-between items-center text-sm"> <span className="font-bold text-slate-700 dark:text-slate-300"> 3. Historical Hospital Admissions </span> <button id="add_admission_row" type="button" onClick={() => addArrayRow("hospital_admissions", { admission_no: "", reason: "", date: "", notes: "", }) } className="px-2.5 py-1 text-xs font-semibold rounded bg-emerald-500/10 text-emerald-500 hover:bg-emerald-500/20 flex items-center gap-1 border border-emerald-500/20" > <Plus className="w-3.5 h-3.5" /> Row </button> </div> <div className="overflow-x-auto"> <table className="w-full text-xs text-left"> <thead> <tr className="bg-neutral-50 dark:bg-slate-900 border-b dark:border-slate-800 text-neutral-500 font-bold uppercase tracking-wide"> <th className="p-2">Admission No</th> <th className="p-2">Reason</th> <th className="p-2">Date</th> <th className="p-2">Additional Notes</th> <th className="p-2 w-12 text-center">Action</th> </tr> </thead> <tbody> {formData.hospital_admissions.map((item, idx) => ( <tr key={idx} className="border-b dark:border-slate-800"> <td className="p-1"> <input id={`admission_no_${idx}`} type="text" placeholder="e.g. ADM28" value={item.admission_no || ""} onChange={(e) => updateArrayField( "hospital_admissions", idx, "admission_no", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none" /> </td> <td className="p-1"> <input id={`admission_reason_${idx}`} type="text" placeholder="e.g. Fever" value={item.reason || ""} onChange={(e) => updateArrayField( "hospital_admissions", idx, "reason", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none" /> </td> <td className="p-1"> <input id={`admission_date_${idx}`} type="date" value={item.date || ""} onChange={(e) => updateArrayField( "hospital_admissions", idx, "date", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none" /> </td> <td className="p-1"> <input id={`admission_notes_${idx}`} type="text" value={item.notes || ""} onChange={(e) => updateArrayField( "hospital_admissions", idx, "notes", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none" /> </td> <td className="p-1 text-center"> <button id={`del_admission_${idx}`} type="button" onClick={() => removeArrayRow("hospital_admissions", idx) } className="p-1 text-rose-500 hover:text-rose-600 transition" > <Trash2 className="w-4 h-4" /> </button> </td> </tr> ))} {formData.hospital_admissions.length === 0 && ( <tr> <td colSpan={5} className="p-4 text-center text-neutral-400 font-mono" > No admissions registered. </td> </tr> )} </tbody> </table> </div> </div> {/* 4. SURGICAL HISTORY */} <div className="space-y-4"> <div className="flex justify-between items-center text-sm"> <span className="font-bold text-slate-700 dark:text-slate-300"> 4. Surgeries & Critical Procedures </span> <button id="add_surgery_row" type="button" onClick={() => addArrayRow("past_surgeries", { procedure_name: "", complications: "", notes: "", }) } className="px-2.5 py-1 text-xs font-semibold rounded bg-emerald-500/10 text-emerald-500 hover:bg-emerald-500/20 flex items-center gap-1 border border-emerald-500/20" > <Plus className="w-3.5 h-3.5" /> Row </button> </div> <div className="overflow-x-auto"> <table className="w-full text-xs text-left"> <thead> <tr className="bg-neutral-50 dark:bg-slate-900 border-b dark:border-slate-800 text-neutral-500 font-bold uppercase tracking-wide"> <th className="p-2">Procedure / Surgery Name</th> <th className="p-2">Complications</th> <th className="p-2">Additional Notes</th> <th className="p-2 w-12 text-center">Action</th> </tr> </thead> <tbody> {formData.past_surgeries.map((item, idx) => ( <tr key={idx} className="border-b dark:border-slate-800"> <td className="p-1"> <input id={`procedure_name_${idx}`} type="text" placeholder="e.g. Appendectomy" value={item.procedure_name || ""} onChange={(e) => updateArrayField( "past_surgeries", idx, "procedure_name", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none" /> </td> <td className="p-1"> <input id={`procedure_compl_${idx}`} type="text" value={item.complications || ""} onChange={(e) => updateArrayField( "past_surgeries", idx, "complications", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none" /> </td> <td className="p-1"> <input id={`procedure_notes_${idx}`} type="text" value={item.notes} onChange={(e) => updateArrayField( "past_surgeries", idx, "notes", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none" /> </td> <td className="p-1 text-center"> <button id={`del_procedure_${idx}`} type="button" onClick={() => removeArrayRow("past_surgeries", idx) } className="p-1 text-rose-500 hover:text-rose-600 transition" > <Trash2 className="w-4 h-4" /> </button> </td> </tr> ))} {formData.past_surgeries.length === 0 && ( <tr> <td colSpan={4} className="p-4 text-center text-neutral-400 font-mono" > No previous surgical history inputted. </td> </tr> )} </tbody> </table> </div> </div> {/* 5. CURRENT MEDICATION RECORDS OR PRESCRIBED DRUGS */} <div className="space-y-4"> <div className="flex justify-between items-center text-sm"> <span className="font-bold text-slate-700 dark:text-slate-300"> 5. Pharmacological Dosing (Drug History) </span> <button id="add_drug_row" type="button" onClick={() => addArrayRow("drug_history", { drug_name: "", dose: "", frequency: "", route: "", duration: "", notes: "", }) } className="px-2.5 py-1 text-xs font-semibold rounded bg-emerald-500/10 text-emerald-500 hover:bg-emerald-500/20 flex items-center gap-1 border border-emerald-500/20" > <Plus className="w-3.5 h-3.5" /> Row </button> </div> <div className="overflow-x-auto"> <table className="w-full text-xs text-left"> <thead> <tr className="bg-neutral-50 dark:bg-slate-900 border-b dark:border-slate-800 text-neutral-500 font-bold uppercase tracking-wide"> <th className="p-2">Drug Name</th> <th className="p-2">Dose</th> <th className="p-2">Frequency</th> <th className="p-2">Route</th> <th className="p-2">Duration</th> <th className="p-2">Notes</th> <th className="p-2 w-12 text-center">Action</th> </tr> </thead> <tbody> {formData.drug_history.map((item, idx) => ( <tr key={idx} className="border-b dark:border-slate-800"> <td className="p-1"> <input id={`drug_name_${idx}`} type="text" placeholder="e.g. Metformin" value={item.drug_name || ""} onChange={(e) => updateArrayField( "drug_history", idx, "drug_name", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none" /> </td> <td className="p-1"> <input id={`drug_dose_${idx}`} type="text" placeholder="e.g. 500mg" value={item.dose || ""} onChange={(e) => updateArrayField( "drug_history", idx, "dose", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none" /> </td> <td className="p-1"> <input id={`drug_freq_${idx}`} type="text" placeholder="e.g. BD" value={item.frequency || ""} onChange={(e) => updateArrayField( "drug_history", idx, "frequency", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none" /> </td> <td className="p-1 max-w-[100px]"> <select id={`drug_route_${idx}`} value={item.route || ""} onChange={(e) => updateArrayField( "drug_history", idx, "route", e.target.value, ) } className="w-full bg-transparent py-1 border-none px-1" > <option value="Oral">Oral</option> <option value="IV">IV</option> <option value="SC">SC</option> <option value="IM">IM</option> <option value="Inhalation">Inhalation</option> </select> </td> <td className="p-1"> <input id={`drug_dur_${idx}`} type="text" placeholder="e.g. Ongoing" value={item.duration || ""} onChange={(e) => updateArrayField( "drug_history", idx, "duration", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none" /> </td> <td className="p-1"> <input id={`drug_notes_${idx}`} type="text" value={item.notes || ""} onChange={(e) => updateArrayField( "drug_history", idx, "notes", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none" /> </td> <td className="p-1 text-center"> <button id={`del_drug_${idx}`} type="button" onClick={() => removeArrayRow("drug_history", idx)} className="p-1 text-rose-500 hover:text-rose-600 transition" > <Trash2 className="w-4 h-4" /> </button> </td> </tr> ))} {formData.drug_history.length === 0 && ( <tr> <td colSpan={7} className="p-4 text-center text-neutral-400 font-mono" > No prescribed pharmacological elements specified. </td> </tr> )} </tbody> </table> </div> </div> {/* 6. FAMILY CLINICAL HISTORY */} <div className="space-y-4 pt-4 pt-4"> <div className="flex justify-between items-center text-sm"> <span className="font-bold text-slate-700 dark:text-slate-300"> 6. Family Clinical History </span> <button id="add_family_hist_row" type="button" onClick={() => addArrayRow("family_history", { morbidity_name: "", relationship: "", notes: "", }) } className="px-2.5 py-1 text-xs font-semibold rounded bg-blue-500/10 text-blue-600 dark:text-blue-400 hover:bg-blue-500/20 flex items-center gap-1 border border-blue-500/20" > <Plus className="w-3.5 h-3.5" /> Row </button> </div> <div className="overflow-x-auto"> <table className="w-full text-xs text-left"> <thead> <tr className="bg-neutral-50 dark:bg-slate-900 border-b dark:border-slate-800 text-neutral-500 font-bold uppercase tracking-wide"> <th className="p-2">Morbidity Name</th> <th className="p-2">Relationship</th> <th className="p-2">Additional Notes</th> <th className="p-2 w-12 text-center">Action</th> </tr> </thead> <tbody> {formData.family_history && formData.family_history.map((item, idx) => ( <tr key={idx} className="border-b dark:border-slate-800" > <td className="p-1"> <input id={`family_morbidity_${idx}`} type="text" placeholder="e.g. Breast Cancer" value={item.morbidity_name || ""} onChange={(e) => updateArrayField( "family_history", idx, "morbidity_name", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none text-xs" /> </td> <td className="p-1"> <input id={`family_relation_${idx}`} type="text" placeholder="e.g. Mother" value={item.relationship || ""} onChange={(e) => updateArrayField( "family_history", idx, "relationship", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none text-xs" /> </td> <td className="p-1"> <input id={`family_notes_${idx}`} type="text" value={item.notes || ""} onChange={(e) => updateArrayField( "family_history", idx, "notes", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none text-xs" /> </td> <td className="p-1 text-center"> <button id={`del_family_hist_${idx}`} type="button" onClick={() => removeArrayRow("family_history", idx) } className="p-1 text-rose-500 hover:text-rose-600 transition" > <Trash2 className="w-4 h-4" /> </button> </td> </tr> ))} {(!formData.family_history || formData.family_history.length === 0) && ( <tr> <td colSpan={4} className="p-4 text-center text-neutral-400 font-mono" > No hereditary or family clinical history recorded. </td> </tr> )} </tbody> </table> </div> </div> {/* 7. ONCOLOGY RISK FACTORS */} <div className="space-y-4 pt-4 pt-4"> <div className="flex justify-between items-center text-sm"> <span className="font-bold text-slate-700 dark:text-slate-300"> 7. Oncology Risk Factors </span> <button id="add_risk_factor_row" type="button" onClick={() => addArrayRow("risk_factors", { risk_factor_name: "", notes: "", }) } className="px-2.5 py-1 text-xs font-semibold rounded bg-blue-500/10 text-blue-600 dark:text-blue-400 hover:bg-blue-500/20 flex items-center gap-1 border border-blue-500/20" > <Plus className="w-3.5 h-3.5" /> Row </button> </div> <div className="overflow-x-auto"> <table className="w-full text-xs text-left"> <thead> <tr className="bg-neutral-50 dark:bg-slate-900 border-b dark:border-slate-800 text-neutral-500 font-bold uppercase tracking-wide"> <th className="p-2">Risk Factor</th> <th className="p-2"> Additional Notes / Exposure details </th> <th className="p-2 w-12 text-center">Action</th> </tr> </thead> <tbody> {formData.risk_factors && formData.risk_factors.map((item, idx) => ( <tr key={idx} className="border-b dark:border-slate-800" > <td className="p-1"> <input id={`risk_factor_name_${idx}`} type="text" placeholder="e.g. Asbestos Exposure" value={item.risk_factor_name || ""} onChange={(e) => updateArrayField( "risk_factors", idx, "risk_factor_name", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none text-xs" /> </td> <td className="p-1"> <input id={`risk_factor_notes_${idx}`} type="text" placeholder="e.g. Worked in construction for 15 years" value={item.notes || ""} onChange={(e) => updateArrayField( "risk_factors", idx, "notes", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none text-xs" /> </td> <td className="p-1 text-center"> <button id={`del_risk_factor_${idx}`} type="button" onClick={() => removeArrayRow("risk_factors", idx) } className="p-1 text-rose-500 hover:text-rose-600 transition" > <Trash2 className="w-4 h-4" /> </button> </td> </tr> ))} {(!formData.risk_factors || formData.risk_factors.length === 0) && ( <tr> <td colSpan={3} className="p-4 text-center text-neutral-400 font-mono" > No specific environmental or genetic risk factors added. </td> </tr> )} </tbody> </table> </div> </div> {/* 8. USUAL LONG-TERM PRESCRIPTIONS */} <div className="space-y-4 pt-4 pt-4"> <div className="flex justify-between items-center text-sm"> <span className="font-bold text-slate-700 dark:text-slate-300"> 8. Usual Long-term Prescriptions </span> <button id="add_usual_pres_row" type="button" onClick={() => addArrayRow("usual_prescriptions", { drug_name: "", dose: "", frequency: "", duration: "", notes: "", }) } className="px-2.5 py-1 text-xs font-semibold rounded bg-blue-500/10 text-blue-600 dark:text-blue-400 hover:bg-blue-500/20 flex items-center gap-1 border border-blue-500/20" > <Plus className="w-3.5 h-3.5" /> Row </button> </div> <div className="overflow-x-auto"> <table className="w-full text-xs text-left"> <thead> <tr className="bg-neutral-50 dark:bg-slate-900 border-b dark:border-slate-800 text-neutral-500 font-bold uppercase tracking-wide"> <th className="p-2">Drug Name</th> <th className="p-2">Dose</th> <th className="p-2">Frequency</th> <th className="p-2">Duration</th> <th className="p-2">Additional Notes</th> <th className="p-2 w-12 text-center">Action</th> </tr> </thead> <tbody> {formData.usual_prescriptions && formData.usual_prescriptions.map((item, idx) => ( <tr key={idx} className="border-b dark:border-slate-800" > <td className="p-1"> <input id={`pres_drug_name_${idx}`} type="text" placeholder="e.g. Metformin" value={item.drug_name} onChange={(e) => updateArrayField( "usual_prescriptions", idx, "drug_name", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none text-xs" /> </td> <td className="p-1"> <input id={`pres_drug_dose_${idx}`} type="text" placeholder="e.g. 500mg" value={item.dose} onChange={(e) => updateArrayField( "usual_prescriptions", idx, "dose", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none text-xs" /> </td> <td className="p-1"> <input id={`pres_drug_freq_${idx}`} type="text" placeholder="e.g. Daily" value={item.frequency} onChange={(e) => updateArrayField( "usual_prescriptions", idx, "frequency", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none text-xs" /> </td> <td className="p-1"> <input id={`pres_drug_dur_${idx}`} type="text" placeholder="e.g. Chronic" value={item.duration} onChange={(e) => updateArrayField( "usual_prescriptions", idx, "duration", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none text-xs" /> </td> <td className="p-1"> <input id={`pres_drug_notes_${idx}`} type="text" value={item.notes} onChange={(e) => updateArrayField( "usual_prescriptions", idx, "notes", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none text-xs" /> </td> <td className="p-1 text-center"> <button id={`del_usual_pres_${idx}`} type="button" onClick={() => removeArrayRow("usual_prescriptions", idx) } className="p-1 text-rose-500 hover:text-rose-600 transition" > <Trash2 className="w-4 h-4" /> </button> </td> </tr> ))} {(!formData.usual_prescriptions || formData.usual_prescriptions.length === 0) && ( <tr> <td colSpan={6} className="p-4 text-center text-neutral-400 font-mono" > No standard home medication prescriptions entered. </td> </tr> )} </tbody> </table> </div> </div> {/* 9. PERSONAL SOCIAL HISTORY & HABITS */} <div className="space-y-4 pt-4 pt-4"> <span className="text-sm font-semibold text-slate-700 dark:text-slate-300 block"> 9. Personal Social History & Habits </span> <div className="grid grid-cols-1 md:grid-cols-2 gap-6 bg-slate-50/50 dark:bg-slate-900/25 p-4 rounded-xl border dark:border-slate-800"> {/* Smoking Habits */} <div className="space-y-3"> <label className="text-xs font-bold text-slate-500 uppercase tracking-wider block"> Smoking Profile </label> <div className="grid grid-cols-1 sm:grid-cols-2 gap-4"> <div> <label className="block text-[10px] text-neutral-400 font-medium mb-1"> Status </label> <select id="smoking_status_sec_e" value={formData.social_history?.smoking?.status || "Non consumer"} onChange={(e) => { const statusVal = e.target.value as any; setFormData((prev) => ({ ...prev, social_history: { ...prev.social_history, smoking: { status: statusVal, amounts: prev.social_history?.smoking?.amounts || "", }, alcohol: prev.social_history?.alcohol || { status: "Non consumer", amounts: "" }, }, })); }} className="w-full bg-white dark:bg-slate-900 border dark:border-slate-700 rounded-lg px-3 py-1.5 focus:outline-none text-xs text-slate-700 dark:text-slate-200" > <option value="Non consumer">Non consumer</option> <option value="Ex">Ex-consumer</option> <option value="Current">Current consumer</option> </select> </div> <div> <label className="block text-[10px] text-neutral-400 font-medium mb-1"> Amounts / Frequency / Pack Years </label> <input id="smoking_amounts_sec_e" type="text" placeholder="e.g. 10 pack-years" value={formData.social_history?.smoking?.amounts || ""} onChange={(e) => { const val = e.target.value; setFormData((prev) => ({ ...prev, social_history: { ...prev.social_history, smoking: { status: prev.social_history?.smoking?.status || "Non consumer", amounts: val, }, alcohol: prev.social_history?.alcohol || { status: "Non consumer", amounts: "" }, }, })); }} className="w-full bg-white dark:bg-slate-900 border dark:border-slate-700 rounded-lg px-3 py-1.5 focus:outline-none text-xs" /> </div> </div> </div> {/* Alcohol Habits */} <div className="space-y-3"> <label className="text-xs font-bold text-slate-500 uppercase tracking-wider block"> Alcohol Profile </label> <div className="grid grid-cols-1 sm:grid-cols-2 gap-4"> <div> <label className="block text-[10px] text-neutral-400 font-medium mb-1"> Status </label> <select id="alcohol_status_sec_e" value={formData.social_history?.alcohol?.status || "Non consumer"} onChange={(e) => { const statusVal = e.target.value as any; setFormData((prev) => ({ ...prev, social_history: { ...prev.social_history, smoking: prev.social_history?.smoking || { status: "Non consumer", amounts: "" }, alcohol: { status: statusVal, amounts: prev.social_history?.alcohol?.amounts || "", }, }, })); }} className="w-full bg-white dark:bg-slate-900 border dark:border-slate-700 rounded-lg px-3 py-1.5 focus:outline-none text-xs text-slate-700 dark:text-slate-200" > <option value="Non consumer">Non consumer</option> <option value="Ex">Ex-consumer</option> <option value="Current">Current consumer</option> </select> </div> <div> <label className="block text-[10px] text-neutral-400 font-medium mb-1"> Amounts / Frequency / Weekly intake </label> <input id="alcohol_amounts_sec_e" type="text" placeholder="e.g. Occasional social" value={formData.social_history?.alcohol?.amounts || ""} onChange={(e) => { const val = e.target.value; setFormData((prev) => ({ ...prev, social_history: { ...prev.social_history, smoking: prev.social_history?.smoking || { status: "Non consumer", amounts: "" }, alcohol: { status: prev.social_history?.alcohol?.status || "Non consumer", amounts: val, }, }, })); }} className="w-full bg-white dark:bg-slate-900 border dark:border-slate-700 rounded-lg px-3 py-1.5 focus:outline-none text-xs" /> </div> </div> </div> </div> </div> {/* 10. CRITICAL ALLERGIES / ADVERSE RESPONSES */} <div className="space-y-4 pt-4 pt-4"> <span className="text-sm font-semibold text-slate-700 dark:text-slate-300 block"> 10. Critical Allergies / Adverse Responses </span> <div className="grid grid-cols-1 md:grid-cols-4 gap-4"> <div> <label className="block text-[10px] text-neutral-500 font-bold uppercase mb-1"> Drug Allergies </label> <input id="allergy_drugs_sec_e" type="text" placeholder="e.g. Penicillin, Sulfa" value={formData.allergies.drugs.join(", ")} onChange={(e) => { const list = e.target.value.split(",").map((s) => s.trim()).filter(Boolean); setFormData((prev) => ({ ...prev, allergies: { ...prev.allergies, drugs: list }, })); }} className="w-full bg-slate-50 dark:bg-slate-900 border dark:border-slate-700 rounded-lg px-3 py-1.5 focus:outline-none text-xs" /> </div> <div> <label className="block text-[10px] text-neutral-500 font-bold uppercase mb-1"> Food Allergies </label> <input id="allergy_foods_sec_e" type="text" placeholder="e.g. Shellfish, Nuts" value={formData.allergies.foods.join(", ")} onChange={(e) => { const list = e.target.value.split(",").map((s) => s.trim()).filter(Boolean); setFormData((prev) => ({ ...prev, allergies: { ...prev.allergies, foods: list }, })); }} className="w-full bg-slate-50 dark:bg-slate-900 border dark:border-slate-700 rounded-lg px-3 py-1.5 focus:outline-none text-xs" /> </div> <div> <label className="block text-[10px] text-neutral-500 font-bold uppercase mb-1"> Plaster / Latex Allergies </label> <input id="allergy_plasters_sec_e" type="text" placeholder="e.g. Latex tape" value={formData.allergies.plasters.join(", ")} onChange={(e) => { const list = e.target.value.split(",").map((s) => s.trim()).filter(Boolean); setFormData((prev) => ({ ...prev, allergies: { ...prev.allergies, plasters: list }, })); }} className="w-full bg-slate-50 dark:bg-slate-900 border dark:border-slate-700 rounded-lg px-3 py-1.5 focus:outline-none text-xs" /> </div> <div> <label className="block text-[10px] text-neutral-500 font-bold uppercase mb-1"> Others </label> <input id="allergy_other_sec_e" type="text" placeholder="e.g. Pollen" value={formData.allergies.others.join(", ")} onChange={(e) => { const list = e.target.value.split(",").map((s) => s.trim()).filter(Boolean); setFormData((prev) => ({ ...prev, allergies: { ...prev.allergies, others: list }, })); }} className="w-full bg-slate-50 dark:bg-slate-900 border dark:border-slate-700 rounded-lg px-3 py-1.5 focus:outline-none text-xs" /> </div> </div> </div> </div> {/* SECTION F: ANTHROPOMETRIC MEASUREMENTS */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <h2 className="text-lg font-bold pb-3"> Section F: Anthropometric Measurements </h2> <div className="space-y-4"> <div className="flex justify-between items-center text-sm"> <span className="font-bold text-slate-700 dark:text-slate-300"> Growth & Weight Tracking </span> <button id="add_anthropometric_row" type="button" onClick={() => { const today = new Date().toISOString().split("T")[0];   Check if already exists for today to avoid duplicates const exists = formData.examination_findings.some( (f) => f.date === today && f.examination_type !== "Organ System", ); if (!exists) { addArrayRow("examination_findings", { examination_type: "Height", date: today, findings: "", }); } }} className="px-2.5 py-1 text-xs font-semibold rounded bg-blue-500/10 text-blue-600 dark:text-blue-400 hover:bg-blue-500/20 flex items-center gap-1 border border-blue-500/20" > <Plus className="w-3.5 h-3.5" /> Date Set </button> </div> <div className="overflow-x-auto"> <table className="w-full text-xs text-left"> <thead> <tr className="bg-neutral-50 dark:bg-slate-900 border-b dark:border-slate-800 text-neutral-500 font-bold uppercase tracking-wide"> <th className="p-2">Date conducted</th> <th className="p-2">Height (cm)</th> <th className="p-2">Weight (kg)</th> <th className="p-2">BMI (kg/m²)</th> <th className="p-2">BSA (m²)</th> <th className="p-2 w-12 text-center">Action</th> </tr> </thead> <tbody> {(() => { const groups: Record< string, { height: string; weight: string; bmi: string; bsa: string } > = {}; formData.examination_findings.forEach((f) => { if (f.examination_type === "Organ System") return; if (!groups[f.date]) { groups[f.date] = { height: "", weight: "", bmi: "", bsa: "" }; } if (f.examination_type === "Height") groups[f.date].height = f.findings; if (f.examination_type === "Weight") groups[f.date].weight = f.findings; if (f.examination_type === "BMI") groups[f.date].bmi = f.findings; if (f.examination_type === "BSA") groups[f.date].bsa = f.findings; }); const sortedDates = Object.keys(groups).sort((a, b) => b.localeCompare(a)); if (sortedDates.length === 0) { return ( <tr> <td colSpan={6} className="p-4 text-center text-neutral-400 font-mono italic" > No anthropometric tracks found. Add a date set above. </td> </tr> ); } return sortedDates.map((date) => ( <tr key={date} className="border-b dark:border-slate-800"> <td className="p-1"> <input type="date" value={date} onChange={(e) => { const newDate = e.target.value; if (!newDate) return; setFormData((prev) => { const newList = prev.examination_findings.map((f) => { if (f.date === date && f.examination_type !== "Organ System") { return { ...f, date: newDate }; } return f; }); return { ...prev, examination_findings: newList }; }); }} className="bg-transparent px-1 py-1 focus:outline-none w-full font-semibold" /> </td> <td className="p-1"> <input type="text" placeholder="..." value={groups[date].height} onChange={(e) => updateAnthroValues(date, "Height", e.target.value)} className="bg-transparent px-1 py-1 focus:outline-none w-full" /> </td> <td className="p-1"> <input type="text" placeholder="..." value={groups[date].weight} onChange={(e) => updateAnthroValues(date, "Weight", e.target.value)} className="bg-transparent px-1 py-1 focus:outline-none w-full" /> </td> <td className="p-1"> <input type="text" readOnly value={groups[date].bmi} className="bg-transparent px-1 py-1 focus:outline-none w-full text-slate-500 font-mono" /> </td> <td className="p-1"> <input type="text" readOnly value={groups[date].bsa} className="bg-transparent px-1 py-1 focus:outline-none w-full text-slate-500 font-mono" /> </td> <td className="p-1 text-center"> <button type="button" onClick={() => removeAnthroSet(date)} className="p-1 text-rose-500 hover:bg-rose-500/10 rounded transition" > <Trash2 className="w-4 h-4" /> </button> </td> </tr> )); })()} </tbody> </table> </div> </div> </div> {/* SECTION G: PHYSICAL EXAMINATIONS */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <h2 className="text-lg font-bold pb-3"> Section G: Physical Examinations </h2> <div className="space-y-4"> <div className="flex justify-between items-center text-sm"> <span className="font-bold text-slate-700 dark:text-slate-300"> Physical Examinations </span> <button id="add_physical_exam_row" type="button" onClick={() => addArrayRow("examination_findings", { examination_type: "Organ System", date: new Date().toISOString().split("T")[0], findings: "", organ_system_name: "", }) } className="px-2.5 py-1 text-xs font-semibold rounded bg-blue-500/10 text-blue-600 dark:text-blue-400 hover:bg-blue-500/20 flex items-center gap-1 border border-blue-500/20" > <Plus className="w-3.5 h-3.5" /> Row </button> </div> <div className="overflow-x-auto"> <table className="w-full text-xs text-left"> <thead> <tr className="bg-neutral-50 dark:bg-slate-900 border-b dark:border-slate-800 text-neutral-500 font-bold uppercase tracking-wide"> <th className="p-2 w-1/3">Date Conducted</th> <th className="p-2 w-1/3">Organ System Name</th> <th className="p-2 w-1/3">Findings</th> <th className="p-2 w-12 text-center">Action</th> </tr> </thead> <tbody> {formData.examination_findings && formData.examination_findings.map((item, idx) => { if (item.examination_type !== "Organ System") return null; return ( <tr key={idx} className="border-b dark:border-slate-800"> <td className="p-1"> <input id={`phys_exam_date_${idx}`} type="date" value={item.date} onChange={(e) => updateArrayField( "examination_findings", idx, "date", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none text-xs" /> </td> <td className="p-1"> <input id={`phys_exam_system_${idx}`} type="text" placeholder="e.g. Cardiovascular" value={item.organ_system_name || ""} onChange={(e) => updateArrayField( "examination_findings", idx, "organ_system_name", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none text-xs" /> </td> <td className="p-1"> <input id={`phys_exam_findings_${idx}`} type="text" placeholder="Clinical findings..." value={item.findings} onChange={(e) => updateArrayField( "examination_findings", idx, "findings", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none text-xs" /> </td> <td className="p-1 text-center"> <button id={`del_phys_exam_${idx}`} type="button" onClick={() => removeArrayRow("examination_findings", idx) } className="p-1 text-rose-500 hover:text-rose-600 transition" > <Trash2 className="w-4 h-4" /> </button> </td> </tr> ); })} {(!formData.examination_findings || formData.examination_findings.filter(f => f.examination_type === "Organ System").length === 0) && ( <tr> <td colSpan={4} className="p-4 text-center text-neutral-400 font-mono" > No physical examination records updated. </td> </tr> )} </tbody> </table> </div> </div> </div> {/* SECTION H: CLINICAL ONCOLOGY DIAGNOSIS & CLINICAL PROBLEM LIST */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <h2 className="text-lg font-bold pb-3"> Section H: Diagnosis Summary & Clinical Problem List </h2> <div className="grid grid-cols-1 md:grid-cols-2 gap-6"> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Provisional Diagnosis </label> <textarea id="provisional_diag" rows={4} value={formData.provisional_diagnosis || ""} onChange={(e) => setFormData((prev) => ({ ...prev, provisional_diagnosis: e.target.value, })) } className={getFieldClass("provisional_diagnosis")} placeholder="Insert provisional diagnostic remarks..." ></textarea> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Final Concluding Diagnosis </label> <textarea id="final_diag" rows={4} value={formData.final_diagnosis || ""} onChange={(e) => setFormData((prev) => ({ ...prev, final_diagnosis: e.target.value, })) } className={getFieldClass("final_diagnosis")} placeholder="Insert final cellular/pathological diagnosis conclusions..." ></textarea> </div> </div> <div className="space-y-4 pt-4 pt-4"> <div className="flex justify-between items-center text-sm"> <span className="font-semibold text-slate-700 dark:text-slate-300"> Active Problems & Treatment Plan: </span> <button id="add_problem_row" type="button" onClick={() => addArrayRow("problems", { problem_name: "", management_plan: "", }) } className="px-2 py-0.5 text-xs bg-emerald-500/10 hover:bg-emerald-500/20 border border-emerald-500/20 rounded flex items-center text-emerald-500" > <Plus className="w-3.5 h-3.5" /> Problem </button> </div> <table className="w-full text-xs text-left"> <tbody> {formData.problems.map((prob, id) => ( <tr key={id} className="border-b dark:border-slate-800"> <td className="p-1 w-1/3"> <input id={`problem_name_${id}`} type="text" placeholder="e.g. Bone Metastasis pain" value={prob.problem_name} onChange={(e) => updateArrayField( "problems", id, "problem_name", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none" /> </td> <td className="p-1"> <input id={`problem_plan_${id}`} type="text" placeholder="e.g. Local radiotherapy + analgesics" value={prob.management_plan} onChange={(e) => updateArrayField( "problems", id, "management_plan", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none" /> </td> <td className="p-1 w-12 text-center"> <button id={`del_problem_${id}`} type="button" onClick={() => removeArrayRow("problems", id)} className="p-1 text-rose-500" > <Trash2 className="w-4 h-4" /> </button> </td> </tr> ))} {formData.problems.length === 0 && ( <tr> <td colSpan={3} className="p-4 text-center text-neutral-400 font-mono" > No active problems set. </td> </tr> )} </tbody> </table> </div> </div> <div className="py-2"></div> {/* SECTION I: TABBED CLINICAL INVESTIGATIONS */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <h2 className="text-lg font-bold pb-3"> Section I: Lab / Pathology Investigations </h2> {/* TAB SELECTORS */} <div className="flex border-b border-neutral-200 dark:border-slate-700 overflow-x-auto gap-2 text-xs"> {( [ "imaging", "biopsies", "endoscopy", "ihc", "genetic", "tumour_markers", "others", ] as const ).map((tab) => ( <button key={tab} id={`tab_trigger_${tab}`} type="button" onClick={() => setActiveInvTab(tab)} className={`px-4 py-2.5 font-bold border-b-2 capitalize transition-all whitespace-nowrap ${ activeInvTab === tab ? "border-emerald-500 text-emerald-600 dark:text-emerald-400" : "border-transparent text-neutral-400 hover:text-slate-600" }`} > {tab === "ihc" ? "immunohistochemistry (IHC)" : tab === "tumour_markers" ? "tumour markers" : tab === "biopsies" ? "biopsy" : tab} </button> ))} </div> {/* TAB CONTENT IMAGING */} {activeInvTab === "imaging" && ( <div className="space-y-4"> <div className="flex justify-between items-center"> <span className="text-xs font-semibold text-neutral-400 font-mono"> Radiological, Ultrasound, or Scans reports: </span> <button id="add_imaging_row" type="button" onClick={() => { const updatedImaging = [ ...formData.investigations.imaging, { modality: "CT", date: "", mass_present: "No", mass_size: "", findings: "", reporting_system_status: "", }, ]; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, imaging: updatedImaging, }, })); }} className="px-2.5 py-1 text-xs bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-500 border border-emerald-500/20 rounded flex items-center gap-1" > <Plus className="w-3.5 h-3.5" /> Row </button> </div> <div className="space-y-6"> {formData.investigations.imaging.map((item, id) => ( <div key={id} className="p-4 bg-slate-50 dark:bg-slate-900 border dark:border-slate-800 rounded-xl space-y-4 relative" > <button id={`del_imaging_${id}`} type="button" onClick={() => { const list = formData.investigations.imaging.filter( (_, i) => i !== id, ); setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, imaging: list, }, })); }} className="absolute top-4 right-4 p-1.5 rounded-lg bg-rose-500/10 text-rose-500 hover:bg-rose-500/20 transition" > <Trash2 className="w-4 h-4" /> </button> <div className="grid grid-cols-1 md:grid-cols-5 gap-4"> <div> <label className="block text-[10px] font-bold text-neutral-500 uppercase"> Investigation Purpose </label> <select id={`imaging_purpose_${id}`} value={item.purpose || ""} onChange={(e) => { const list = [...formData.investigations.imaging]; list[id].purpose = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, imaging: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2 py-1 text-xs text-sm mt-1" > <option value="">-- Choose Purpose --</option> <option value="Diagnosis">Diagnosis</option> <option value="Confirmation">Confirmation</option> <option value="Pre-operative Fitness Assessment">Pre-operative Fitness Assessment</option> <option value="Complications Assessment">Complications Assessment</option> <option value="Assessment of Malignant Potential">Assessment of Malignant Potential</option> <option value="Prognosis Assessment">Prognosis Assessment</option> <option value="Follow-up">Follow-up</option> </select> </div> <div> <label className="block text-[10px] font-bold text-neutral-500 uppercase"> Imaging Modality * </label> <select id={`imaging_modality_${id}`} value={item.modality || ""} onChange={(e) => { const list = [...formData.investigations.imaging]; list[id].modality = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, imaging: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2 py-1 test-xs text-sm mt-1" > <option value="CT">CT Scan</option> <option value="MRI">MRI Scan</option> <option value="PET">PET-CT Scan</option> <option value="Ultrasound">Ultrasound</option> <option value="X-Ray">X-Ray</option> </select> </div> <div> <label className="block text-[10px] font-bold text-neutral-500 uppercase"> Scan Dating </label> <input id={`imaging_date_${id}`} type="date" value={item.date || ""} onChange={(e) => { const list = [...formData.investigations.imaging]; list[id].date = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, imaging: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2 py-1 text-xs text-sm mt-1" /> </div> <div> <label className="block text-[10px] font-bold text-neutral-500 uppercase"> Mass lesion Present? </label> <select id={`imaging_mass_${id}`} value={item.mass_present || "No"} onChange={(e: any) => { const list = [...formData.investigations.imaging]; list[id].mass_present = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, imaging: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2 py-1 text-xs text-sm mt-1" > <option value="No">No Mass Identified</option> <option value="Yes">Yes, Lesion Present</option> </select> </div> {item.mass_present === "Yes" && ( <div> <label className="block text-[10px] font-bold text-neutral-500 uppercase"> Lesion dimensions/size </label> <input id={`imaging_size_${id}`} type="text" placeholder="e.g. 4.5 cm" value={item.mass_size || ""} onChange={(e) => { const list = [ ...formData.investigations.imaging, ]; list[id].mass_size = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, imaging: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2 py-1 text-xs text-sm mt-1" /> </div> )} </div> <div> <label className="block text-[10px] font-bold text-neutral-500 uppercase"> Detailed imaging findings </label> <textarea id={`imaging_findings_${id}`} rows={2} value={item.findings || ""} onChange={(e) => { const list = [...formData.investigations.imaging]; list[id].findings = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, imaging: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2 py-1 mt-1 text-xs text-sm" ></textarea> </div> </div> ))} {formData.investigations.imaging.length === 0 && ( <div className="p-8 text-center text-neutral-400 font-mono border border-dashed rounded-xl"> No imaging report scans specified. </div> )} </div> </div> )} {/* TAB CONTENT BIOPSIES */} {activeInvTab === "biopsies" && ( <div className="space-y-4"> <div className="flex justify-between items-center"> <span className="text-xs font-semibold text-neutral-400"> Histopathology Biopsy findings: </span> <button id="add_biopsy_row" type="button" onClick={() => { const updatedBiopsies = [ ...formData.investigations.biopsies, { biopsy_type: "", date: "", pathology_status: "", findings: "", }, ]; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, biopsies: updatedBiopsies, }, })); }} className="px-2.5 py-1 text-xs bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-500 border border-emerald-500/20 rounded flex items-center gap-1" > <Plus className="w-3.5 h-3.5" /> Row </button> </div> <div className="space-y-4"> {formData.investigations.biopsies.map((item, id) => ( <div key={id} className="p-4 bg-slate-50 dark:bg-slate-900 border dark:border-slate-800 rounded-xl relative space-y-4" > <button id={`del_biopsy_${id}`} type="button" onClick={() => { const list = formData.investigations.biopsies.filter( (_, i) => i !== id, ); setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, biopsies: list, }, })); }} className="absolute top-4 right-4 p-1 hover:text-rose-600 text-rose-500" > <Trash2 className="w-4 h-4" /> </button> <div className="grid grid-cols-1 md:grid-cols-4 gap-4"> <div> <label className="block text-[10px] font-bold text-neutral-500"> Investigation Purpose </label> <select id={`biopsy_purpose_${id}`} value={item.purpose || ""} onChange={(e) => { const list = [...formData.investigations.biopsies]; list[id].purpose = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, biopsies: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2.5 py-1 text-xs mt-1" > <option value="">-- Choose Purpose --</option> <option value="Diagnosis">Diagnosis</option> <option value="Confirmation">Confirmation</option> <option value="Pre-operative Fitness Assessment">Pre-operative Fitness Assessment</option> <option value="Complications Assessment">Complications Assessment</option> <option value="Assessment of Malignant Potential">Assessment of Malignant Potential</option> <option value="Prognosis Assessment">Prognosis Assessment</option> <option value="Follow-up">Follow-up</option> </select> </div> <div> <label className="block text-[10px] font-bold text-neutral-500"> Biopsy procedure type </label> <input id={`biopsy_type_${id}`} type="text" placeholder="e.g. Core Needle Biopsy" value={item.biopsy_type || ""} onChange={(e) => { const list = [ ...formData.investigations.biopsies, ]; list[id].biopsy_type = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, biopsies: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2.5 py-1 text-xs mt-1" /> </div> <div> <label className="block text-[10px] font-bold text-neutral-500"> Conduct Date </label> <input id={`biopsy_date_${id}`} type="date" value={item.date || ""} onChange={(e) => { const list = [ ...formData.investigations.biopsies, ]; list[id].date = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, biopsies: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2.5 py-1 text-xs mt-1" /> </div> <div> <label className="block text-[10px] font-bold text-neutral-500"> Pathology status </label> <input id={`biopsy_status_${id}`} type="text" placeholder="e.g. Invasive Duct Carcinoma" value={item.pathology_status || ""} onChange={(e) => { const list = [ ...formData.investigations.biopsies, ]; list[id].pathology_status = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, biopsies: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2.5 py-1 text-xs mt-1" /> </div> </div> <div> <label className="block text-[10px] font-bold text-neutral-500"> Histology findings & staging </label> <textarea id={`biopsy_findings_${id}`} rows={2} value={item.findings || ""} onChange={(e) => { const list = [...formData.investigations.biopsies]; list[id].findings = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, biopsies: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2.5 py-1 mt-1 text-xs" ></textarea> </div> </div> ))} {formData.investigations.biopsies.length === 0 && ( <div className="p-8 text-center text-neutral-400 font-mono border border-dashed rounded-xl"> No biopsies registered. </div> )} </div> </div> )} {/* TAB CONTENT ENDOSCOPY */} {activeInvTab === "endoscopy" && ( <div className="space-y-4"> <div className="flex justify-between items-center"> <span className="text-xs font-semibold text-neutral-400 font-mono"> Endoscopic Procedures (Gastroscopy, Colonoscopy, etc.): </span> <button id="add_endoscopy_row" type="button" onClick={() => { const updatedEndo = [ ...formData.investigations.endoscopy, { procedure_type: "", date: "", findings: "", biopsy_taken: "No", }, ]; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, endoscopy: updatedEndo, }, })); }} className="px-2.5 py-1 text-xs bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-500 border border-emerald-500/20 rounded flex items-center gap-1" > <Plus className="w-3.5 h-3.5" /> Row </button> </div> <div className="space-y-4"> {formData.investigations.endoscopy.map((item, id) => ( <div key={id} className="p-4 bg-slate-50 dark:bg-slate-900 border dark:border-slate-800 rounded-xl relative space-y-4" > <button id={`del_endoscopy_${id}`} type="button" onClick={() => { const list = formData.investigations.endoscopy.filter( (_, i) => i !== id, ); setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, endoscopy: list, }, })); }} className="absolute top-4 right-4 p-1.5 rounded-lg bg-rose-500/10 text-rose-500 hover:bg-rose-500/20 transition" > <Trash2 className="w-4 h-4" /> </button> <div className="grid grid-cols-1 md:grid-cols-4 gap-4"> <div> <label className="block text-[10px] font-bold text-neutral-500 uppercase"> Investigation Purpose </label> <select id={`endoscopy_purpose_${id}`} value={item.purpose || ""} onChange={(e) => { const list = [...formData.investigations.endoscopy]; list[id].purpose = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, endoscopy: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2 py-1 text-xs mt-1" > <option value="">-- Choose Purpose --</option> <option value="Diagnosis">Diagnosis</option> <option value="Confirmation">Confirmation</option> <option value="Pre-operative Fitness Assessment">Pre-operative Fitness Assessment</option> <option value="Complications Assessment">Complications Assessment</option> <option value="Assessment of Malignant Potential">Assessment of Malignant Potential</option> <option value="Prognosis Assessment">Prognosis Assessment</option> <option value="Follow-up">Follow-up</option> </select> </div> <div> <label className="block text-[10px] font-bold text-neutral-500 uppercase"> Procedure Type * </label> <input type="text" placeholder="e.g. OGD / Colonoscopy" value={item.procedure_type || ""} onChange={(e) => { const list = [...formData.investigations.endoscopy]; list[id].procedure_type = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, endoscopy: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2 py-1 text-xs mt-1" /> </div> <div> <label className="block text-[10px] font-bold text-neutral-500 uppercase"> Date </label> <input type="date" value={item.date} onChange={(e) => { const list = [...formData.investigations.endoscopy]; list[id].date = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, endoscopy: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2 py-1 text-xs mt-1" /> </div> <div> <label className="block text-[10px] font-bold text-neutral-500 uppercase"> Biopsy Taken? </label> <select value={item.biopsy_taken || "No"} onChange={(e: any) => { const list = [...formData.investigations.endoscopy]; list[id].biopsy_taken = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, endoscopy: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2 py-1 text-xs mt-1" > <option value="No">No</option> <option value="Yes">Yes</option> </select> </div> </div> <div> <label className="block text-[10px] font-bold text-neutral-500 uppercase"> Endoscopic Findings </label> <textarea rows={2} value={item.findings || ""} onChange={(e) => { const list = [...formData.investigations.endoscopy]; list[id].findings = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, endoscopy: list, }, })); }} className="w-full bg-white dark:bg-slate-800 border dark:border-slate-700/60 rounded px-2 py-1 mt-1 text-xs" ></textarea> </div> </div> ))} {formData.investigations.endoscopy.length === 0 && ( <div className="p-8 text-center text-neutral-400 font-mono border border-dashed rounded-xl"> No endoscopic reports registered. </div> )} </div> </div> )} {/* TAB CONTENT IHC */} {activeInvTab === "ihc" && ( <div className="space-y-4"> <div className="flex justify-between items-center"> <span className="text-xs font-semibold text-neutral-400"> Immunohistochemistry Indicators (ER, PR, HER2, Ki-67): </span> <button id="add_ihc_row" type="button" onClick={() => { const updatedIhc = [ ...formData.investigations.ihc, { marker_name: "", status: "Negative", notes: "" }, ]; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, ihc: updatedIhc, }, })); }} className="px-2.5 py-1 text-xs bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-500 border border-emerald-500/20 rounded flex items-center gap-1" > <Plus className="w-3.5 h-3.5" /> Row </button> </div> <table className="w-full text-xs text-left"> <thead> <tr className="bg-slate-50 dark:bg-slate-900 border-b dark:border-slate-800 text-neutral-500 font-bold uppercase"> <th className="p-2">Marker name</th> <th className="p-2">expression Status</th> <th className="p-2">intensity</th> <th className="p-2">Purpose</th> <th className="p-2">clinical Notes</th> <th className="p-2 w-12 text-center">Action</th> </tr> </thead> <tbody> {formData.investigations.ihc.map((item, id) => ( <tr key={id} className="border-b dark:border-slate-800"> <td className="p-1"> <input id={`ihc_marker_${id}`} type="text" placeholder="e.g. HER2 / ER" value={item.marker_name || ""} onChange={(e) => { const list = [...formData.investigations.ihc]; list[id].marker_name = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, ihc: list, }, })); }} className="w-full bg-transparent px-2 py-1 border-none" /> </td> <td className="p-1"> <select id={`ihc_status_${id}`} value={item.status || "Negative"} onChange={(e) => { const list = [...formData.investigations.ihc]; list[id].status = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, ihc: list, }, })); }} className="w-full bg-transparent py-1 border-none" > <option value="Positive">Positive</option> <option value="Negative">Negative</option> <option value="Borderline">Borderline</option> </select> </td> <td className="p-1"> <input id={`ihc_intensity_${id}`} type="text" placeholder="e.g. 3+" value={item.intensity || ""} onChange={(e) => { const list = [...formData.investigations.ihc]; list[id].intensity = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, ihc: list, }, })); }} className="w-full bg-transparent px-2 py-1 border-none" /> </td> <td className="p-1"> <select id={`ihc_purpose_${id}`} value={item.purpose || ""} onChange={(e) => { const list = [...formData.investigations.ihc]; list[id].purpose = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, ihc: list, }, })); }} className="w-full bg-transparent py-1 border-none" > <option value="">-- Choose Purpose --</option> <option value="Diagnosis">Diagnosis</option> <option value="Confirmation">Confirmation</option> <option value="Pre-operative Fitness Assessment">Pre-operative Fitness Assessment</option> <option value="Complications Assessment">Complications Assessment</option> <option value="Assessment of Malignant Potential">Assessment of Malignant Potential</option> <option value="Prognosis Assessment">Prognosis Assessment</option> <option value="Follow-up">Follow-up</option> </select> </td> <td className="p-1"> <input id={`ihc_notes_${id}`} type="text" placeholder="e.g. High intensity" value={item.notes || ""} onChange={(e) => { const list = [...formData.investigations.ihc]; list[id].notes = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, ihc: list, }, })); }} className="w-full bg-transparent px-2 py-1 border-none" /> </td> <td className="p-1 text-center"> <button id={`del_ihc_${id}`} type="button" onClick={() => { const list = formData.investigations.ihc.filter( (_, i) => i !== id, ); setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, ihc: list, }, })); }} className="p-1 text-rose-500 hover:text-rose-600" > <Trash2 className="w-4 h-4" /> </button> </td> </tr> ))} {formData.investigations.ihc.length === 0 && ( <tr id="no_ihc_markers"> <td colSpan={6} className="p-4 text-center text-neutral-400 font-mono" > No IHC immunomarkers logged. </td> </tr> )} </tbody> </table> </div> )} {/* TAB CONTENT GENETIC */} {activeInvTab === "genetic" && ( <div className="space-y-4"> <div className="flex justify-between items-center"> <span className="text-xs font-semibold text-neutral-400 font-mono"> Genetic sequencing (BRCA1/2, EGFR, KRAS, ALK): </span> <button id="add_genetic_row" type="button" onClick={() => { const updatedGen = [ ...formData.investigations.genetic, { mutation_tested: "", status: "Not detected", notes: "", }, ]; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, genetic: updatedGen, }, })); }} className="px-2.5 py-1 text-xs bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-500 border border-emerald-500/20 rounded flex items-center gap-1" > <Plus className="w-3.5 h-3.5" /> Row </button> </div> <table className="w-full text-xs text-left"> <thead> <tr className="bg-slate-50 dark:bg-slate-900 border-b dark:border-s