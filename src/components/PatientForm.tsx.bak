HO CNS Tumor Grade (Brain / Gliomas) </option> <option value="FNCLCC Sarcoma Grade"> FNCLCC Sarcoma Grade (Soft Tissue Sarcomas) </option> <option value="Edmondson-Steiner Grade"> Edmondson-Steiner Grade (Hepatocellular Carcinoma) </option> <option value="GOG Endometrial Grade"> GOG Endometrial Grade (Gynecological / Endometrial) </option> <option value="Lauren Classification"> Lauren Classification (Gastric Adenocarcinoma) </option> <option value="WHO Neuroendocrine Tumor (NET) Group"> WHO Neuroendocrine Tumor (NET) Group </option> <option value="Other">Other (Specify in notes)</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 mb-1"> Overall Histological Grade / Classification </label> <div className="relative"> <input list={`hist_stage_options_${index}`} type="text" placeholder={ HISTOLOGICAL_GRADING_OPTIONS[staging.staging_system_name] ? "Select or type histological grade" : "e.g. Grade II, G3, Diffuse Type" } value={staging.overall_stage} onChange={(e) => setFormData((prev) => { const newStaging = [ ...prev.histological_staging_details, ]; newStaging[index] = { ...newStaging[index], overall_stage: e.target.value, }; return { ...prev, histological_staging_details: newStaging, }; }) } className="w-full bg-slate-50 dark:bg-slate-900 border dark:border-slate-700 rounded px-3 py-1.5 focus:outline-none text-xs text-sm" /> <datalist id={`hist_stage_options_${index}`}> {HISTOLOGICAL_GRADING_OPTIONS[staging.staging_system_name]?.map( (opt) => ( <option key={opt.stage} value={opt.stage}> {opt.description} </option> ), )} </datalist> </div> </div> <div> <label className="block text-xs font-semibold text-neutral-500 mb-1"> Grading notes / criteria observations </label> <input type="text" placeholder="Histological grading observations" value={staging.staging_notes} onChange={(e) => setFormData((prev) => { const newStaging = [ ...prev.histological_staging_details, ]; newStaging[index] = { ...newStaging[index], staging_notes: e.targ