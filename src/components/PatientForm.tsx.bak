ions Assessment</option> <option value="Assessment of Malignant Potential">Assessment of Malignant Potential</option> <option value="Prognosis Assessment">Prognosis Assessment</option> <option value="Follow-up">Follow-up</option> </select> </td> <td className="p-1"> <input id={`genetic_notes_${id}`} type="text" placeholder="e.g. Cleared pathologically" value={item.notes || ""} onChange={(e) => { const list = [...formData.investigations.genetic]; list[id].notes = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, genetic: list, }, })); }} className="w-full bg-transparent px-2 py-1 border-none" /> </td> <td className="p-1 text-center"> <button id={`del_genetic_${id}`} type="button" onClick={() => { const list = formData.investigations.genetic.filter( (_, i) => i !== id, ); setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, genetic: list, }, })); }} className="p-1 text-rose-500 hover:text-rose-600" > <Trash2 className="w-4 h-4" /> </button> </td> </tr> ))} {formData.investigations.genetic.length === 0 && ( <tr id="no_genetic_profiles"> <td colSpan={5} className="p-4 text-center text-neutral-400 font-mono" > No genetic profiles recorded. </td> </tr> )} </tbody> </table> </div> )} {/* TAB CONTENT TUMOUR MARKERS */} {activeInvTab === "tumour_markers" && ( <div className="space-y-4"> <div className="flex justify-between items-center"> <span className="text-xs font-semibold text-neutral-400 font-mono"> Tumour marker assessments (PSA, CA-125, CEA, AFP, etc.): </span> <button id="add_tumour_marker_row" type="button" onClick={() => { const updatedMarkers = [ ...formData.investigations.tumour_markers, { marker_name: "", value: "", unit: "", date: "" }, ]; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, tumour_markers: updatedMarkers, }, })); }} className="px-2.5 py-1 text-xs bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-500 border border-emerald-500/20 rounded flex items-cente