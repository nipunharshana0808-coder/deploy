v) => ({ ...prev, investigations: { ...prev.investigations, others: updatedOthers, }, })); }} className="px-2.5 py-1 text-xs bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-500 border border-emerald-500/20 rounded flex items-center gap-1" > <Plus className="w-3.5 h-3.5" /> Row </button> </div> <table className="w-full text-xs text-left"> <thead> <tr className="bg-slate-50 dark:bg-slate-900 border-b dark:border-slate-800 text-neutral-500 font-bold uppercase"> <th className="p-2">Investigation Procedure</th> <th className="p-2">Date conducted</th> <th className="p-2">clinical findings</th> <th className="p-2">Purpose</th> <th className="p-2 w-12 text-center">Action</th> </tr> </thead> <tbody> {formData.investigations.others.map((item, id) => ( <tr key={id} className="border-b dark:border-slate-800"> <td className="p-1"> <input id={`others_type_${id}`} type="text" placeholder="e.g. Bone scan" value={item.investigation_type || ""} onChange={(e) => { const list = [...formData.investigations.others]; list[id].investigation_type = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, others: list, }, })); }} className="w-full bg-transparent px-2 py-1 border-none" /> </td> <td className="p-1"> <input id={`others_date_${id}`} type="date" value={item.date || ""} onChange={(e) => { const list = [...formData.investigations.others]; list[id].date = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, others: list, }, })); }} className="w-full bg-transparent px-2 py-1 border-none" /> </td> <td className="p-1"> <input id={`others_findings_${id}`} type="text" placeholder="findings notes" value={item.findings || ""} onChange={(e) => { const list = [...formData.investigations.others]; list[id].findings = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, others: list, }, })); }} className="w-full bg-transparent px-2 py-1 border-none" /> </td> <td className="p-1"> <select id={`others_purpose_${id}`} value={item.purpose || ""} onChange={(e) => { const list = [...formData.investigations.others]; list[id].purpose = e.target.value; setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, others: list, }, })); }} className="w-full bg-transparent py-1 border-none px-1" > <option value="">-- Choose Purpose --</option> <option value="Diagnosis">Diagnosis</option> <option value="Confirmation">Confirmation</option> <option value="Pre-operative Fitness Assessment">Pre-operative Fitness Assessment</option> <option value="Complications Assessment">Complications Assessment</option> <option value="Assessment of Malignant Potential">Assessment of Malignant Potential</option> <option value="Prognosis Assessment">Prognosis Assessment</option> <option value="Follow-up">Follow-up</option> </select> </td> <td className="p-1 text-center"> <button id={`del_others_${id}`} type="button" onClick={() => { const list = formData.investigations.others.filter( (_, i) => i !== id, ); setFormData((prev) => ({ ...prev, investigations: { ...prev.investigations, others: list, }, })); }} className="p-1 text-rose-500 hover:text-rose-600" > <Trash2 className="w-4 h-4" /> </button> </td> </tr> ))} {formData.investigations.others.length === 0 && ( <tr id="no_others_tests"> <td colSpan={5} className="p-4 text-center text-neutral-400 font-mono" > No supplementary findings specified. </td> </tr> )} </tbody> </table> </div> )} </div> {/* SECTION J & K: CLINICAL & HISTOLOGICAL STAGING */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <h2 className="text-lg font-bold pb-3"> Section J: Clinical Staging </h2> <div className="space-y-4"> {formData.staging_details.map((staging, index) => ( <div key={index} className="grid grid-cols-1 md:grid-cols-3 gap-6 relative border dark:border-slate-700/60 p-4 rounded-xl" > {formData.staging_details.length > 1 && ( <button type="button" onClick={() => setFormData((prev) => ({ ...prev, staging_details: prev.staging_details.filter( (_, i) => i !== index, ), })) } className="absolute -top-3 -right-3 bg-red-100 text-red-600 dark:bg-red-900/30 dark:text-red-400 w-6 h-6 rounded-full flex items-center justify-center hover:bg-red-200 dark:hover:bg-red-900/50" > <X className="w-3 h-3" /> </button> )} <div> <label className="block text-xs font-semibold text-neutral-500 mb-1"> Staging System {index + 1} </label> <select value={staging.staging_system_name} onChange={(e) => setFormData((prev) => { const newStaging = [...prev.staging_details]; newStaging[index] = { ...newStaging[index], staging_system_name: e.target.value, }; return { ...prev, staging_details: newStaging }; }) } className="w-full bg-slate-50 dark:bg-slate-900 border dark:border-slate-700 rounded px-3 py-1.5 focus:outline-none text-xs text-sm" > <option value="TNM">TNM (Most Solid Tumors)</option> <option value="FIGO">FIGO (Gynecological Cancers)</option> <option value="Duke">Duke (Colorectal Cancer)</option> <option value="Ann Arbor">Ann Arbor (Lymphomas)</option> <option value="Binet / Rai"> Binet / Rai (Chronic Lymphocytic Leukemia) </option> <option value="ISS / R-ISS"> ISS / R-ISS (Multiple Myeloma) </option> <option value="Gleason"> Gleason Score / Grade Groups (Prostate Cancer) </option> <option value="Breslow / Clark"> Breslow Depth & Clark Level (Melanoma) </option> <option value="Masaoka-Koga"> Masaoka-Koga (Thymoma) </option> <option value="Enneking"> Enneking System (Bone & Soft Tissue Sarcomas) </option> <option value="BCLC"> BCLC (Hepatocellular Carcinoma) </option> <option value="Lugano"> Lugano Classification (Lymphomas) </option> <option value="PRETEXT"> PRETEXT / POSTTEXT (Pediatric Hepatoblastoma) </option> <option value="INSS"> INSS (Pediatric Neuroblastoma) </option> <option value="Murphy"> Murphy Staging (Pediatric Burkitt Lymphoma) </option> <option value="FAB / WHO"> FAB / WHO (Leukemias & Myelodysplastic Syndromes) </option> <option value="Other">Other (Specify in notes)</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 mb-1"> Overall Diagnosis Stage Grouping </label> <div className="relative"> <input list={`stage_options_${index}`} type="text" placeholder={ STAGING_OPTIONS[staging.staging_system_name] ? "Select or type stage" : "e.g. Stage IIIa (T3 N1 M0)" } value={staging.overall_stage} onChange={(e) => setFormData((prev) => { const newStaging = [...prev.staging_details]; newStaging[index] = { ...newStaging[index], overall_stage: e.target.value, }; return { ...prev, staging_details: newStaging }; }) } className={getFieldClass("staging_details")} /> <datalist id={`stage_options_${index}`}> {STAGING_OPTIONS[staging.staging_system_name]?.map( (opt) => ( <option key={opt.stage} value={opt.stage}> {opt.description} </option> ), )} </datalist> {STAGING_OPTIONS[staging.staging_system_name]?.find( (o) => o.stage === staging.overall_stage, ) && ( <p className="mt-1.5 text-[10px] text-neutral-500 bg-neutral-50 dark:bg-slate-900 px-2 py-1 rounded inline-block"> <span className="font-semibold">Meaning:</span>{" "} { STAGING_OPTIONS[staging.staging_system_name]?.find( (o) => o.stage === staging.overall_stage, )?.description } </p> )} </div> </div> <div> <label className="block text-xs font-semibold text-neutral-500 mb-1"> Staging notes </label> <input type="text" placeholder="Clinical Staging observations" value={staging.staging_notes} onChange={(e) => setFormData((prev) => { const newStaging = [...prev.staging_details]; newStaging[index] = { ...newStaging[index], staging_notes: e.target.value, }; return { ...prev, staging_details: newStaging }; }) } className="w-full bg-slate-50 dark:bg-slate-900 border dark:border-slate-700 rounded px-3 py-1.5 focus:outline-none text-xs text-sm" /> </div> </div> ))} {formData.staging_details.length < 4 && ( <button type="button" onClick={() => setFormData((prev) => ({ ...prev, staging_details: [ ...prev.staging_details, { staging_system_name: "TNM", overall_