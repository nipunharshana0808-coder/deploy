xt-neutral-300 mb-4 uppercase tracking-wide"> Adjuvant Radiotherapy - Details </h3> <div className="grid grid-cols-1 md:grid-cols-3 gap-4"> <div className="space-y-1"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400"> Type Name </label> <input type="text" placeholder="e.g. EBRT / Brachytherapy" value={formData.adjuvant_radiotherapy.type_name || ""} onChange={(e) => setFormData((p) => ({ ...p, adjuvant_radiotherapy: { ...p.adjuvant_radiotherapy, type_name: e.target.value, }, })) } className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" /> </div> <div className="space-y-1"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400"> Date </label> <input type="date" value={formData.adjuvant_radiotherapy.date || ""} onChange={(e) => setFormData((p) => ({ ...p, adjuvant_radiotherapy: { ...p.adjuvant_radiotherapy, date: e.target.value, }, })) } className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" /> </div> <div className="space-y-1"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400"> Site </label> <input type="text" placeholder="e.g. Breast bed / Pelvis" value={formData.adjuvant_radiotherapy.site || ""} onChange={(e) => setFormData((p) => ({ ...p, adjuvant_radiotherapy: { ...p.adjuvant_radiotherapy, site: e.target.value, }, })) } className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" /> </div> <div className="space-y-1"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400"> Dose </label> <input type="text" placeholder="e.g. 50 Gy in 25 fractions" value={formData.adjuvant_radiotherapy.dose || ""} onChange={(e) => setFormData((p) => ({ ...p, adjuvant_radiotherapy: { ...p.adjuvant_radiotherapy, dose: e.target.value, }, })) } className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" /> </div> <div className="space-y-1"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400"> Frequency </label> <input type="text" placeholder="e.g. Daily, 5 days a week" value={formData.adjuvant_radiotherapy.frequency || ""} onChange={(e) => setFormData((p) => ({ ...p, adjuvant_radiotherapy: { ...p.adjuvant_radiotherapy, frequency: e.target.value, }, })) } className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" /> </div> <div className="space-y-1"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400"> Approach </label> <input type="text" placeholder="e.g. 3D-CRT / IMRT / VMAT" value={formData.adjuvant_radiotherapy.approach || ""} onChange={(e) => setFormData((p) => ({ ...p, adjuvant_radiotherapy: { ...p.adjuvant_radiotherapy, approach: e.target.value, }, })) } className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" /> </div> <div className="space-y-1"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400"> Cycles </label> <input type="text" placeholder="e.g. 25 fractions" value={formData.adjuvant_radiotherapy.cycles || ""} onChange={(e) => setFormData((p) => ({ ...p, adjuvant_radiotherapy: { ...p.adjuvant_radiotherapy, cycles: e.target.value, }, })) } className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" /> </div> <div className="space-y-1 md:col-span-2"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400"> Adverse effects </label> <input type="text" placeholder="e.g. Radiation dermatitis, fatigue" value={ formData.adjuvant_radiotherapy.adverse_effects || "" } onChange={(e) => setFormData((p) => ({ ...p, adjuvant_radiotherapy: { ...p.adjuvant_radiotherapy, adverse_effects: e.target.value, }, })) } className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" /> </div> <div className="space-y-1 md:col-span-3"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400"> Notes </label> <textarea placeholder="Insert customized treatment setup details or specialist radiotherapy observations..." value={formData.adjuvant_radiotherapy.notes || ""} onChange={(e) => setFormData((p) => ({ ...p, adjuvant_radiotherapy: { ...p.adjuvant_radiotherapy, notes: e.target.value, }, })) } className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm min-h-[80px]" /> </div> </div> </div> )} </div> </div> {/* SECTION O: PRE-OP ASSESSMENT */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <div className="flex justify-between items-center pb-3"> <h2 className="text-lg font-bold">Section O: Pre-op Assessment</h2> </div> <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Assessment Date </label> <input type="date" value={formData.preop_assessment?.date || ""} onChange={(e) => setFormData(p => ({ ...p, preop_assessment: { ...p.preop_assessment!, date: e.target.value } }))} className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> ASA Physical Status </label> <select value={formData.preop_assessment?.asa_physical_status || ""} onChange={(e) => setFormData(p => ({ ...p, preop_assessment: { ...p.preop_assessment!, asa_physical_status: e.target.value } }))} className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" > <option value="">Select ASA Status</option> <option value="ASA I">ASA I - Normal healthy patient</option> <option value="ASA II">ASA II - Mild systemic disease</option> <option value="ASA III">ASA III - Severe systemic disease</option> <option value="ASA IV">ASA IV - Severe systemic disease that is a constant threat to life</option> <option value="ASA V">ASA V - Moribund patient not expected to survive without operation</option> <option value="ASA VI">ASA VI - Declared brain-dead patient for organ harvest</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Clerked By </label> <input type="text" placeholder="Doctor name / designation" value={formData.preop_assessment?.clerked_by || ""} onChange={(e) => setFormData(p => ({ ...p, preop_assessment: { ...p.preop_assessment!, clerked_by: e.target.value } }))} className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" /> </div> <div className="md:col-span-2"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Anesthesia Plan </label> <input type="text" placeholder="e.g. GA + Epidural / Spinal" value={formData.preop_assessment?.anesthesia_plan || ""} onChange={(e) => setFormData(p => ({ ...p, preop_assessment: { ...p.preop_assessment!, anesthesia_plan: e.target.value } }))} className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Functional Capacity (MET Score) </label> <select value={formData.preop_assessment?.met_score || ""} onChange={(e) => { const val = e.target.value; setFormData(p => { let fitnessStatus = p.preop_assessment?.fitness_status || ""; if (val === "< 4 METs (Poor Functional Capacity)") { fitnessStatus = "High Risk"; } else if (val === "> 10 METs (Excellent Functional Capacity)") { fitnessStatus = "Fit"; } else if (val === "4 - 10 METs (Moderate Functional Capacity)") { if (fitnessStatus !== "High Risk" && fitnessStatus !== "Unfit") { fitnessStatus = "Fit"; } } return { ...p, preop_assessment: { ...p.preop_assessment!, met_score: val, fitness_status: fitnessStatus } }; }); }} className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm text-slate-800 dark:text-slate-105" > <option value="">Select MET Score / Capacity</option> <option value="< 4 METs (Poor Functional Capacity)">&lt; 4 METs (Poor Functional Capacity)</option> <option value="4 - 10 METs (Moderate Functional Capacity)">4 - 10 METs (Moderate Functional Capacity)</option> <option value="> 10 METs (Excellent Functional Capacity)">&gt; 10 METs (Excellent Functional Capacity)</option> </select> <p className="text-[10px] text-neutral-400 mt-1 leading-snug"> Guidelines: &lt;4 METs (cannot climb 2 flights of stairs), 4-10 METs (climb stairs, carries groceries), &gt;10 (jog, heavy physical work). </p> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Fitness Status </label> <select value={formData.preop_assessment?.fitness_status || ""} onChange={(e) => setFormData(p => ({ ...p, preop_assessment: { ...p.preop_assessment!, fitness_status: e.target.value } }))} className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm text-slate-800 dark:text-slate-105" > <option value="">Select Status</option> <option value="Fit">Fit for Surgery</option> <option value="Optimizable">Optimizable</option> <option value="High Risk">High Risk</option> <option value="Unfit">Unfit</option> </select> {formData.preop_assessment?.met_score && ( <p className="text-[10px] text-indigo-505 dark:text-indigo-400 font-medium mt-1"> {formData.preop_assessment.met_score.startsWith("< 4") ? "⚠️ MET < 4 recommends High Risk status." : "👍 METs support clinical fitness."} </p> )} </div> <div className="md:col-span-3"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Risk Assessment Scores (NSQIP, RCRI, etc.) </label> <input type="text" placeholder="e.g. RCRI Score 2, 6% risk of MACE" value={formData.preop_assessment?.risk_assessment_scores || ""} onChange={(e) => setFormData(p => ({ ...p, preop_assessment: { ...p.preop_assessment!, risk_assessment_scores: e.target.value } }))} className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" /> </div> <div className="md:col-span-3"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Special Investigations for Surgery (Stress Echo, PFT, etc.) </label> <textarea rows={2} value={formData.preop_assessment?.special_investigations || ""} onChange={(e) => setFormData(p => ({ ...p, preop_assessment: { ...p.preop_assessment!, special_investigations: e.target.value } }))} className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" /> </div> <div className="md:col-span-3"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Pre-op Orders / Preparation </label> <textarea rows={2} value={formData.preop_assessment?.preop_orders || ""} onChange={(e) => setFormData(p => ({ ...p, preop_assessment: { ...p.preop_assessment!, preop_orders: e.target.value } }))} className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" /> </div> <div className="md:col-span-3"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> General Pre-op Notes </label> <textarea rows={2} value={formData.preop_assessment?.notes || ""} onChange={(e) => setFormData(p => ({ ...p, preop_assessment: { ...p.preop_assessment!, notes: e.target.value } }))} className="w-full bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-md px-3 py-2 text-sm" /> </div> </div> </div> {/* SECTION P: SURGICAL DETAILS */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <div className="flex justify-between items-center pb-3"> <h2 className="text-lg font-bold">Section P: Surgical Details</h2> </div> <div className="space-y-8"> {(formData.surgeries || []).map((surgery, surgIdx) => { const sIcuIn = new Date(surgery.icu_entry_date || "").getTime(); const sIcuOut = new Date(surgery.icu_exit_date || "").getTime(); let localIcuStay = surgery.icu_stay_days ?? 0; if (surgery.icu_stay_days === undefined && !isNaN(sIcuIn) && !isNaN(sIcuOut) && sIcuOut >= sIcuIn) { localIcuStay = Math.ceil((sIcuOut - sIcuIn) / 86400000); } const sWardIn = new Date(surgery.after_surgery_ward_entry_date || "").getTime(); const sWardOut = new Date(surgery.after_surgery_discharged_date || "").getTime(); let localWardStay = 0; if (!isNaN(sWardIn) && !isNaN(sWardOut) && sWardOut >= sWardIn) { localWardStay = Math.ceil((sWardOut - sWardIn) / 86400000); } const localHospStay = surgery.hospital_stay_days ?? (localIcuStay + localWardStay); const complCount = (surgery.complications || []).length; return ( <div key={`surg_${surgIdx}`} className="bg-slate-50/50 dark:bg-slate-900/40 p-4 sm:p-6 rounded-xl space-y-6 relative"> {formData.surgeries.length > 1 && ( <button type="button" onClick={() => setFormData(p => ({ ...p, surgeries: p.surgeries.filter((_, i) => i !== surgIdx) }))} className="absolute -top-3 -right-3 bg-red-100 text-red-600 dark:bg-red-900/30 w-7 h-7 rounded-full flex items-center justify-center hover:bg-red-200 dark:hover:bg-red-900/50" > <X className="w-4 h-4" /> </button> )} <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6"> <div className="lg:col-span-1"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Procedure Name: </label> <input type="text" placeholder="e.g. Lumpectomy / Right Hemicolectomy" value={surgery.procedure_name || ""} onChange={(e) => setFormData(p => { const ns = [...p.surgeries]; ns[surgIdx] = { ...ns[surgIdx], procedure_name: e.target.value }; return { ...p, surgeries: ns }; })} className="w-full bg-yellow-50/50 dark:bg-yellow-900/10 border-yellow-200 dark:border-yellow-900/50 border text-slate-800 dark:text-slate-100 rounded-lg px-3 py-1.5 focus:outline-none focus:ring-1 focus:ring-yellow-400 text-sm" /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Site of Surgery: </label> <input type="text" placeholder="e.g. Left Breast / Distal Colon" value={surgery.surgery_site || ""} onChange={(e) => setFormData(p => { const ns = [...p.surgeries]; ns[surgIdx] = { ...ns[surgIdx], surgery_site: e.target.value }; return { ...p, surgeries: ns }; })} className={getFieldClass(`surg_site_${surgIdx}`)} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Done Date </label> <input type="date" value={surgery.done_date || ""} onChange={(e) => setFormData(p => { const ns = [...p.surgeries]; ns[surgIdx] = { ...ns[surgIdx], done_date: e.target.value }; return { ...p, surgeries: ns }; })} className={getFieldClass(`surg_done_${surgIdx}`)} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Approach </label> <select value={surgery.approach || ""} onChange={(e) => setFormData(p => { const ns = [...p.surgeries]; ns[surgIdx] = { ...ns[surgIdx], approach: e.target.value }; return { ...p, surgeries: ns }; })} className={getFieldClass(`surg_app_${surgIdx}`)} > <option value="">Select Approach</option> <option value="Open">Open</option> <option value="Laparoscopic">Laparoscopic</option> <option value="Robotic">Robotic</option> <option value="Endoscopic">Endoscopic</option> <option value="Other">Other</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Margin Status (Resection Type) </label> <select value={surgery.margin_status || ""} onChange={(e) => setFormData(p => { const ns = [...p.surgeries]; ns[surgIdx] = { ...ns[surgIdx], margin_status: e.target.value }; return { ...p, surgeries: ns }; })} className={getFieldClass(`surg_margin_${surgIdx}`)} > <option value="">Select Resection Status / Margin</option> <option value="R0 (Complete resection - negative margins)">R0: Complete Resection (Microscopically Clear Margins)</option> <option value="R1 (Incomplete resection - microscopically positive)">R1: Microscopically Incomplete Resection (Microscopically Positive Margins)</option> <option value="R2 (Incomplete resection - macroscopically positive / gross residual)">R2: Macroscopically Incomplete Resection (Macroscopic Residual Tumor)</option> <option value="Rx (Resection margin cannot be assessed)">Rx: Margin Cannot Be Assessed</option> <option value="Not Applicable">Not Applicable</option> </select> </div> <div className="lg:col-span-3 md:col-span-2 col-span-1"> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Other Surgical Notes: </label> <textarea rows={1} placeholder="e.g. Unusual anatomy, intra operative blood loss, or additional details" value={surgery.other_surgical_notes || ""} onChange={(e) => setFormData(p => { const ns = [...p.surgeries]; ns[surgIdx] = { ...ns[surgIdx], other_surgical_notes: e.target.value }; return { ...p, surgeries: ns }; })} className={getFieldClass(`surg_other_notes_${surgIdx}`)} /> </div> </div> <div className="grid grid-cols-1 lg:grid-cols-2 gap-6"> {/* ICU SECTION */} <div className="p-4 rounded-xl border dark:border-slate-700/65 bg-white dark:bg-slate-800 space-y-4"> <div className="flex justify-between items-center"> <span className="text-xs font-bold text-slate-700 dark:text-slate-300 uppercase block"> ICU Details </span> <span className="text-[11px] bg-red-100 dark:bg-red-900/40 text-red-600 dark:text-red-400 px-2 py-0.5 rounded font-mono font-bold"> ICU Stay: {localIcuStay} Days </span> </div> <div className="grid grid-cols-1 sm:grid-cols-3 gap-4"> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1">ICU Entered</label> <select value={surgery.icu_entered || "No"} onChange={(e) => setFormData(p => { const ns = [...p.surgeries]; ns[surgIdx] = calculateStays({ ...ns[surgIdx], icu_entered: e.target.value as 'Yes' | 'No' }); return { ...p, surgeries: ns }; })} className={getFieldClass(`surg_icu_ent_${surgIdx}`)} > <option value="No">No</option> <option value="Yes">Yes</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1">ICU Entry Date</label> <input type="date" disabled={surgery.icu_entered !== "Yes"} value={surgery.icu_entry_date || ""} onChange={(e) => setFormData(p => { const ns = [...p.surgeries]; ns[surgIdx] = calculateStays({ ...ns[surgIdx], icu_entry_date: e.target.value }); return { ...p, surgeries: ns }; })} className={`${getFieldClass(`icu_in_${surgIdx}`)} disabled:opacity-50`} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1">ICU Exit Date</label> <input type="date" disabled={surgery.icu_entered !== "Yes"} value={surgery.icu_exit_date || ""} onChange={(e) => setFormData(p => { const ns = [...p.surgeries]; ns[surgIdx] = calculateStays({ ...ns[surgIdx], icu_exit_date: e.target.value }); return { ...p, surgeries: ns }; })} className={`${getFieldClass(`icu_out_${surgIdx}`)} disabled:opacity-50`} /> </div> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1">ICU Management Notes</label> <textarea rows={2} disabled={surgery.icu_entered !== "Yes"} value={surgery.icu_management_notes || ""} onChange={(e) => setFormData(p => { const ns = [...p.surgeries]; ns[surgIdx] = { ...ns[surgIdx], icu_management_notes: e.target.value }; return { ...p, surgeries: ns }; })} className={`${getFieldClass(`icu_notes_${surgIdx}`)} disabled:opacity-50`} ></textarea> </div> </div> {/* WARD SECTION */} <div className="p-4 rounded-xl border dark:border-slate-700/65 bg-white dark:bg-slate-800 space-y-4"> <div className="flex justify-between items-center"> <span className="text-xs font-bold text-slate-700 dark:text-slate-300 uppercase block"> Ward Stay Details </span> <div className="flex gap-2"> <span className="text-[11px] bg-red-100 dark:bg-red-900/40 text-red-600 dark:text-red-400 px-2 py-0.5 rounded font-mono font-bold"> Ward Stay: {localWardStay} Days </span> </div> </div> <div className="grid grid-cols-1 sm:grid-cols-2 gap-4"> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1">Ward Entry Date</label> <input type="date" value={surgery.after_surgery_ward_entry_date || ""} onChange={(e) => setFormData(p => { const ns = [...p.surgeries]; ns[surgIdx] = calculateStays({ ...ns[surgIdx], after_surgery_ward_entry_date: e.target.value }); return { ...p, surgeries: ns }; })} className={getFieldClass(`ward_in_${surgIdx}`)} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1">Discharged Date</label> <input type="date" value={surgery.after_surgery_discharged_date || ""} onChange={(e) => setFormData(p => { const ns = [...p.surgeries]; ns[surgIdx] = calculateStays({ ...ns[surgIdx], after_surgery_discharged_date: e.target.value }); return { ...p, surgeries: ns }; })} className={getFieldClass(`ward_out_${surgIdx}`)} /> </div> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1">Ward Management Notes</label> <textarea rows={2} value={surgery.ward_management_notes || ""} onChange={(e) => setFormData(p => { const ns = [...p.surgeries]; ns[surgIdx] = { ...ns[surgIdx], ward_management_notes: e.target.value }; return { ...p, surgeries: ns }; })} className={getFieldClass(`ward_notes_${surgIdx}`)} ></textarea> </div> </div> </div> <div className="flex justify-end pr-2"> <span className="text-xs bg-red-100 dark:bg-red-900/40 text-red-600 dark:text-red-400 px-3 py-1 rounded font-mono font-bold"> Hospital Stay Day Count: {localHospStay} Days </span> </div> {/* COMPLICATIONS */} <div className="space-y-4 pt-4 pt-4"> <div className="flex justify-between items-center"> <span className="text-sm font-bold text-slate-700 dark:text-slate-300 block"> Post op complications </span> <span className="text-[10px] text-neutral-400 uppercase font-mono font-medium block"> Count: {complCount} </span> </div> <div className="bg-white dark:bg-slate-900/30 rounded-xl overflow-hidden border dark:border-slate-700/60"> <div className="grid grid-cols-12 gap-4 p-3 bg-slate-100/50 dark:bg-slate-800/50 border-b dark:border-slate-700/60 text-[10px] font-bold text-slate-500 uppercase"> <div className="col-span-3">Complication Name</div> <div className="col-span-3">Sig. Amount</div> <div className="col-span-2">Post Op Dur</div> <div className="col-span-3">Notes</div> <div className="col-span-1 text-center">Act</div> </div> <div className="p-2 space-y-2"> {(surgery.complications || []).map((comp, compIdx) => ( <div key={compIdx} className="grid grid-cols-12 gap-4 items-center"> <div className="col-span-3"> <input type="text" placeholder="e.g. SSI, DVT..." value={comp.complication_name || ""} onChange={(e) => updateSurgComplicationField(surgIdx, compIdx, "complication_name", e.target.value)} className="w-full bg-yellow-50/50 dark:bg-yellow-900/10 border-yellow-200 dark:border-yellow-900/50 border text-slate-800 dark:text-slate-100 rounded px-2 py-1.5 focus:outline-none focus:ring-1 focus:ring-yellow-400 text-xs" /> </div> <div className="col-span-3"> <input type="text" placeholder="Amount / Severity" value={comp.significant_amount || ""} onChange={(e) => updateSurgComplicationField(surgIdx, compIdx, "significant_amount", e.target.value)} className="w-full bg-slate-50 dark:bg-slate-900 border border-neutral-200 dark:border-slate-800 text-slate-800 dark:text-slate-100 rounded px-2 py-1.5 focus:outline-none text-xs" /> </div> <div className="col-span-2"> <input type="text" placeholder="Dur" value={comp.duration || ""} onChange={(e) => updateSurgComplicationField(surgIdx, compIdx, "duration", e.target.value)} className="w-full bg-slate-50 dark:bg-slate-900 border text-slate-800 dark:text-slate-100 rounded px-2 py-1.5 focus:outline-none text-xs" /> </div> <div className="col-span-3"> <input type="text" placeholder="Notes" value={comp.notes || ""} onChange={(e) => updateSurgComplicationField(surgIdx, compIdx, "notes", e.target.value)} className="w-full bg-slate-50 dark:bg-slate-900 border text-slate-800 dark:text-slate-100 rounded px-2 py-1.5 focus:outline-none text-xs" /> </div> <div className="col-span-1 flex justify-center"> <button type="button" onClick={() => removeSurgComplicationRow(surgIdx, compIdx)} className="p-1.5 text-neutral-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded" > <Trash2 className="w-3.5 h-3.5" /> </button> </div> </div> ))} {(!surgery.complications || surgery.complications.length === 0) && ( <div className="text-center py-4 text-xs text-neutral-400"> No complications recorded. </div> )} </div> </div> <button type="button" onClick={() => addSurgComplicationRow(surgIdx)} className="px-2.5 py-1 text-xs font-semibold rounded bg-rose-500/10 text-rose-600 dark:text-rose-400 hover:bg-rose-500/20 flex items-center gap-1 border border-rose-500/20" > <Plus className="w-3.5 h-3.5" /> Add Complication </button> </div> {/* MONITORING */} {(() => { const monitoring = surgery.monitoring || []; const groupedDays: { day: string; items: { index: number; parameter: string; findings: string }[] }[] = []; const dayMap: { [key: string]: number } = {}; monitoring.forEach((mon, idx) => { const d = mon.post_op_day_no || ""; if (dayMap[d] === undefined) { dayMap[d] = groupedDays.length; groupedDays.push({ day: d, items: [{ index: idx, parameter: mon.parameter, findings: mon.findings }] }); } else { groupedDays[dayMap[d]].items.push({ index: idx, parameter: mon.parameter, findings: mon.findings }); } }); return ( <div className="space-y-4 pt-4 pt-4 animate-fade-in"> <span className="text-sm font-bold text-slate-700 dark:text-slate-300 block"> Post Op Monitoring (Grouped by Day) </span> <div className="space-y-4"> {groupedDays.map((group, groupIdx) => ( <div key={groupIdx} className="bg-slate-50/50 dark:bg-slate-900/40 rounded-xl p-4 border border-slate-200/60 dark:border-slate-850 space-y-4"> <div className="flex items-center justify-between gap-4 border-b dark:border-slate-800 pb-2.5"> <div className="flex items-center gap-2"> <span className="text-xs font-bold text-slate-500 uppercase tracking-wider">Post-Op Day:</span> <input type="text" placeholder="Day (e.g., 1)" value={group.day} onChange={(e) => { const newVal = e.target.value; setFormData((prev) => { const newSurgeries = [...(prev.surgeries || [])]; if (!newSurgeries[surgIdx]) return prev; const newMon = [...(newSurgeries[surgIdx].monitoring || [])]; group.items.forEach(it => { newMon[it.index] = { ...newMon[it.index], post_op_day_no: newVal }; }); newSurgeries[surgIdx] = { ...newSurgeries[surgIdx], monitoring: newMon }; return { ...prev, surgeries: newSurgeries }; }); }} className="w-20 bg-yellow-50/60 dark:bg-yellow-950/20 border-yellow-200 dark:border-yellow-900/60 border text-slate-800 dark:text-slate-100 rounded px-2.5 py-1 text-xs font-bold focus:outline-none focus:ring-1 focus:ring-yellow-400 text-center" /> </div> <button type="button" onClick={() => { setFormData((prev) => { const newSurgeries = [...(prev.surgeries || [])]; if (!newSurgeries[surgIdx]) return prev; const newMon = (newSurgeries[surgIdx].monitoring || []).filter((_, idx) => !group.items.some(it => it.index === idx) ); newSurgeries[surgIdx] = { ...newSurgeries[surgIdx], monitoring: newMon }; return { ...prev, surgeries: newSurgeries }; }); }} className="text-[10px] text-red-500 hover:text-red-600 font-bold uppercase tracking-wider flex items-center gap-1 bg-red-50 dark:bg-red-950/20 px-2 py-1 rounded border border-red-200/50 dark:border-red-900/30 transition shadow-sm" > <Trash2 className="w-3.5 h-3.5" /> Delete Day {group.day} </button> </div> <div className="space-y-3"> <div className="grid grid-cols-12 gap-4 text-[10px] font-bold text-slate-400 uppercase tracking-wider pl-1.5"> <div className="col-span-11 grid grid-cols-12 gap-4"> <div className="col-span-5">Parameter</div> <div className="col-span-7">Value / Findings</div> </div> <div className="col-span-1 text-center">Delete</div> </div> <div className="space-y-2.5"> {group.items.map((item, itemIdx) => ( <div key={item.index} className="grid grid-cols-12 gap-4 items-center"> <div className="col-span-11 grid grid-cols-12 gap-4"> <div className="col-span-5"> <input type="text" placeholder="e.g. Drain, CRP, Pulse" value={item.parameter || ""} onChange={(e) => updateSurgMonitoringField(surgIdx, item.index, "parameter", e.target.value)} className="w-full bg-white dark:bg-slate-900 border text-slate-850 dark:text-slate-105 rounded px-2.5 py-1.5 focus:outline-none focus:ring-1 focus:ring-indigo-400 text-xs" /> </div> <div className="col-span-7"> <input type="text" placeholder="e.g. 150ml, 12, 78bpm" value={item.findings || ""} onChange={(e) => updateSurgMonitoringField(surgIdx, item.index, "findings", e.target.value)} className="w-full bg-white dark:bg-slate-900 border text-slate-850 dark:text-slate-105 rounded px-2.5 py-1.5 focus:outline-none focus:ring-1 focus:ring-indigo-400 text-xs" /> </div> </div> <div className="col-span-1 flex justify-center"> <button type="button" onClick={() => removeSurgMonitoringRow(surgIdx, item.index)} className="p-1.5 text-neutral-400 hover:text-red-500 hover:bg-neutral-100 dark:hover:bg-slate-800 rounded transition" > <X className="w-3.5 h-3.5" /> </button> </div> </div> ))} </div> </div> <div className="pt-1 select-none"> <button type="button" onClick={() => addParameterForDay(surgIdx, group.day)} className="px-2.5 py-1 text-[10px] font-bold rounded bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 hover:bg-indigo-500/20 flex items-center gap-1 border border-indigo-500/25 uppercase tracking-wider transition" > <Plus className="w-3 h-3" /> Add Parameter under Day {group.day} </button> </div> </div> ))} {groupedDays.length === 0 && ( <div className="text-center py-6 text-xs text-neutral-400 bg-white dark:bg-slate-900/10 border border-dashed rounded-xl dark:border-slate-800"> No clinical post-op monitoring records added. </div> )} </div> <button type="button" onClick={() => addNewDaySection(surgIdx)} className="px-3 py-1.5 text-xs font-bold rounded bg-sky-500/10 text-sky-600 dark:text-sky-400 hover:bg-sky-500/20 flex items-center gap-1 border border-sky-500/20 uppercase tracking-wider transition" > <Plus className="w-3.5 h-3.5" /> Add New Post-Op Day Group </button> </div> ); })()} </div> ); })} <div className="pt-2"> <button type="button" onClick={() => setFormData(p => ({ ...p, surgeries: [ ...(p.surgeries || []), { procedure_name: "", surgery_site: "", done_date: "", approach: "", icu_entered: "No", icu_entry_date: "", icu_exit_date: "", icu_management_notes: "", icu_stay_days: 0, after_surgery_ward_entry_date: "", after_surgery_discharged_date: "", ward_management_notes: "", hospital_stay_days: 0, margin_status: "", complications: [], monitoring: [], other_surgical_notes: "", } ] }))} className="px-4 py-2 text-sm font-semibold rounded-lg bg-slate-900 text-white dark:bg-slate-100 dark:text-slate-900 hover:bg-slate-800 dark:hover:bg-slate-200 flex items-center gap-2" > <Plus className="w-4 h-4" /> Add Another Procedure </button> </div> </div> </div> {/* SECTION S: FOLLOW-UP NOTES */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <h2 className="text-lg font-bold pb-3 flex justify-between items-center"> <span>Section S: Follow Up Notes</span> <button id="add_follow_up_row" type="button" onClick={() => addArrayRow("follow_up_notes", { date: new Date().toISOString().split("T")[0], findings: [""], note: "", }) } className="px-2.5 py-1 text-xs font-semibold rounded bg-blue-500/10 text-blue-600 dark:text-blue-400 hover:bg-blue-500/20 flex items-center gap-1 border border-blue-500/20 animate-pulse" > <Plus className="w-3.5 h-3.5" /> Append Encounter </button> </h2> <div className="overflow-x-auto"> <table className="w-full text-xs text-left"> <thead> <tr className="bg-neutral-50 dark:bg-slate-900 border-b dark:border-slate-800 text-neutral-500 font-bold uppercase tracking-wide"> <th className="p-2 w-1/4">Encounter Date</th> <th className="p-2">Diary note / Findings</th> <th className="p-2 w-12 text-center">Action</th> </tr> </thead> <tbody> {formData.follow_up_notes && formData.follow_up_notes.map((item, idx) => ( <tr key={idx} className="border-b dark:border-slate-800" > <td className="p-1"> <input id={`follow_up_date_${idx}`} type="date" value={item.date || ""} onChange={(e) => updateArrayField( "follow_up_notes", idx, "date", e.target.value, ) } className="w-full bg-transparent px-2 py-1 focus:outline-none border-none text-xs text-slate-755 dark:text-slate-200" /> </td> <td className="p-1"> <textarea id={`follow_up_findings_${idx}`} rows={2} placeholder="Write historic followup report card..." value={ (item as any).note || (item.findings || []).join(", ") } onChange={(e) => { setFormData((prev) => { const list = [ ...(prev.follow_up_notes || []), ]; list[idx] = { ...list[idx], note: e.target.value, findings: [e.target.value], } as any; return { ...prev, follow_up_notes: list }; }); }} className="w-full bg-transparent px-2 py-1 focus:outline-none border-none text-xs resize-none text-slate-755 dark:text-slate-200" /> </td> <td className="p-1 text-center"> <button id={`del_follow_up_${idx}`} type="button" onClick={() => removeArrayRow("follow_up_notes", idx) } className="p-1 text-rose-500 hover:text-rose-600 transition" > <Trash2 className="w-4 h-4" /> </button> </td> </tr> ))} {(!formData.follow_up_notes || formData.follow_up_notes.length === 0) && ( <tr> <td colSpan={3} className="p-4 text-center text-neutral-400 font-mono" > No historical follow up notes logged. </td> </tr> )} </tbody> </table> </div> </div> {/* SECTION U: MULTIDISCIPLINARY TEAM (MDT) & GENOMIC BIOMARKERS */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <h2 className="text-lg font-bold pb-3 flex items-center gap-2"> <Users className="w-5 h-5 text-indigo-600 dark:text-indigo-400" /> Section U: Multidisciplinary Team (MDT) Board & Genomic Biomarkers </h2> <div className="grid grid-cols-1 md:grid-cols-3 gap-6"> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> MDT Status </label> <select id="mdt_discussed" value={formData.mdt_discussion?.discussed || "Pending"} onChange={(e) => setFormData((p) => ({ ...p, mdt_discussion: { ...p.mdt_discussion!, discussed: e.target.value as any, }, })) } className={getFieldClass("mdt_discussion.discussed")} > <option value="Pending">Pending Evaluation</option> <option value="Yes">Discussed in MDT</option> <option value="No">No MDT Discussion</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> MDT Date </label> <input id="mdt_date" type="date" value={formData.mdt_discussion?.mdt_date || ""} onChange={(e) => setFormData((p) => ({ ...p, mdt_discussion: { ...p.mdt_discussion!, mdt_date: e.target.value, }, })) } className={getFieldClass("mdt_discussion.mdt_date")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> MDT Panel Members & Specialities </label> <input id="mdt_members" type="text" placeholder="Dr. Silva (Oncology), Dr. Perera (Surgeon)" value={formData.mdt_discussion?.mdt_panel_members || ""} onChange={(e) => setFormData((p) => ({ ...p, mdt_discussion: { ...p.mdt_discussion!, mdt_panel_members: e.target.value, }, })) } className={getFieldClass("mdt_discussion.mdt_panel_members")} /> </div> <div className="md:col-span-3"> <div className="flex items-center gap-2 mb-2"> <input id="mol_tumor_board" type="checkbox" checked={formData.mdt_discussion?.molecular_tumor_board || false} onChange={(e) => setFormData((p) => ({ ...p, mdt_discussion: { ...p.mdt_discussion!, molecular_tumor_board: e.target.checked, }, })) } className="rounded text-indigo-600 focus:ring-indigo-500 h-4 w-4" /> <label htmlFor="mol_tumor_board" className="text-xs font-semibold text-neutral-600 dark:text-neutral-400 cursor-pointer"> Referred to Molecular Tumor Board (MTB) for Advanced Genomics </label> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> MDT / MTB Recommendations </label> <textarea id="mdt_recommendations" rows={2} placeholder="Insert customized treatment recommendations (e.g., Surgery followed by adjuvant platinum-containing chemo)..." value={formData.mdt_discussion?.recommendations || ""} onChange={(e) => setFormData((p) => ({ ...p, mdt_discussion: { ...p.mdt_discussion!, recommendations: e.target.value, }, })) } className={getFieldClass("mdt_discussion.recommendations")} /> </div> </div> <div className="md:col-span-3 grid grid-cols-1 md:grid-cols-2 gap-4 border-t border-slate-100 dark:border-slate-700/40 pt-4"> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> MDT Treatment Alignment (Quality Metric) </label> <select id="mdt_treatment_alignment" value={formData.mdt_discussion?.mdt_treatment_alignment || "Not Evaluated"} onChange={(e) => setFormData((p) => ({ ...p, mdt_discussion: { ...p.mdt_discussion!, mdt_treatment_alignment: e.target.value as any, }, })) } className={getFieldClass("mdt_discussion.mdt_treatment_alignment")} > <option value="Not Evaluated">Not Evaluated</option> <option value="Aligned">Aligned (Patient treated per MDT plan)</option> <option value="Partially Aligned">Partially Aligned (Adjusted Plan)</option> <option value="Not Aligned">Not Aligned (Complete Deviation)</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> MDT Plan Deviation Reason </label> <input id="mdt_deviation_reason" type="text" placeholder="e.g. Patient preference, systemic fitness drop, disease progression, toxicity" value={formData.mdt_discussion?.mdt_deviation_reason || ""} onChange={(e) => setFormData((p) => ({ ...p, mdt_discussion: { ...p.mdt_discussion!, mdt_deviation_reason: e.target.value, }, })) } disabled={formData.mdt_discussion?.mdt_treatment_alignment === "Aligned" || formData.mdt_discussion?.mdt_treatment_alignment === "Not Evaluated"} className={`${getFieldClass("mdt_discussion.mdt_deviation_reason")} disabled:opacity-50`} /> </div> </div> </div> <div className="border-t border-slate-200/50 dark:border-slate-700/50 pt-5 space-y-4"> <span className="text-xs font-bold text-slate-700 dark:text-slate-300 flex items-center gap-1.5 uppercase tracking-wider"> <Dna className="w-4 h-4 text-emerald-500" /> Genomic & Personalized Biomarker Profiles </span> <div className="grid grid-cols-1 md:grid-cols-5 gap-6"> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> HER2 Status </label> <select id="her2_status" value={formData.genomic_biomarkers?.her2_status || "Not Tested"} onChange={(e) => setFormData((p) => ({ ...p, genomic_biomarkers: { ...p.genomic_biomarkers!, her2_status: e.target.value as any, }, })) } className={getFieldClass("genomic_biomarkers.her2_status")} > <option value="Not Tested">Not Tested</option> <option value="Positive">Positive (+3 or FISH +)</option> <option value="Negative">Negative (0 or 1+)</option> <option value="Equivocal">Equivocal (2+)</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> ER Status </label> <select id="er_status" value={formData.genomic_biomarkers?.er_status || "Not Tested"} onChange={(e) => setFormData((p) => ({ ...p, genomic_biomarkers: { ...p.genomic_biomarkers!, er_status: e.target.value as any, }, })) } className={getFieldClass("genomic_biomarkers.er_status")} > <option value="Not Tested">Not Tested</option> <option value="Positive">Positive</option> <option value="Negative">Negative</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> PR Status </label> <select id="pr_status" value={formData.genomic_biomarkers?.pr_status || "Not Tested"} onChange={(e) => setFormData((p) => ({ ...p, genomic_biomarkers: { ...p.genomic_biomarkers!, pr_status: e.target.value as any, }, })) } className={getFieldClass("genomic_biomarkers.pr_status")} > <option value="Not Tested">Not Tested</option> <option value="Positive">Positive</option> <option value="Negative">Negative</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> MSI Status </label> <select id="msi_status" value={formData.genomic_biomarkers?.msi_status || "Not Tested"} onChange={(e) => setFormData((p) => ({ ...p, genomic_biomarkers: { ...p.genomic_biomarkers!, msi_status: e.target.value as any, }, })) } className={getFieldClass("genomic_biomarkers.msi_status")} > <option value="Not Tested">Not Tested</option> <option value="MSS">MSS (Stable / pMMR)</option> <option value="MSI-H">MSI-H (High / dMMR)</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> BRCA Status </label> <select id="brca_status" value={formData.genomic_biomarkers?.brca_status || "Not Tested"} onChange={(e) => setFormData((p) => ({ ...p, genomic_biomarkers: { ...p.genomic_biomarkers!, brca_status: e.target.value as any, }, })) } className={getFieldClass("genomic_biomarkers.brca_status")} > <option value="Not Tested">Not Tested</option> <option value="Mutated">Mutated Germline/Somatic</option> <option value="Wild-Type">Wild-Type</option> </select> </div> </div> <div className="grid grid-cols-1 md:grid-cols-3 gap-6 pt-2"> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> KRAS / NRAS / PIK3CA Profiling </label> <input id="kras_nras" type="text" placeholder="e.g. KRAS G12D mutation detected" value={formData.genomic_biomarkers?.kras_nras_pik3ca || ""} onChange={(e) => setFormData((p) => ({ ...p, genomic_biomarkers: { ...p.genomic_biomarkers!, kras_nras_pik3ca: e.target.value, }, })) } className={getFieldClass("genomic_biomarkers.kras_nras_pik3ca")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> EGFR / ALK / ROS1 Status </label> <input id="egfr_alk" type="text" placeholder="e.g. EGFR Exon 19 deletion" value={formData.genomic_biomarkers?.egfr_alk_ros1 || ""} onChange={(e) => setFormData((p) => ({ ...p, genomic_biomarkers: { ...p.genomic_biomarkers!, egfr_alk_ros1: e.target.value, }, })) } className={getFieldClass("genomic_biomarkers.egfr_alk_ros1")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> PD-L1 Expression (CPS / TPS) </label> <input id="pd_l1" type="text" placeholder="e.g. TPS = 45%, CPS = 12" value={formData.genomic_biomarkers?.pd_l1_cps_tps || ""} onChange={(e) => setFormData((p) => ({ ...p, genomic_biomarkers: { ...p.genomic_biomarkers!, pd_l1_cps_tps: e.target.value, }, })) } className={getFieldClass("genomic_biomarkers.pd_l1_cps_tps")} /> </div> </div> </div> </div> {/* SECTION V: ONCO-SURGICAL QUALITY PERFORMANCE AUDIT */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <h2 className="text-lg font-bold pb-3 flex items-center gap-2"> <Award className="w-5 h-5 text-indigo-600 dark:text-indigo-400" /> Section V: Surgical Quality Performance Audit & Specimen Registry </h2> <div className="grid grid-cols-1 md:grid-cols-4 gap-6"> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Microscopic Resection Margin (R-status) </label> <select id="resection_margin" value={formData.onco_surgical_audit?.resection_margin_r0_r1_r2 || "Rx"} onChange={(e) => setFormData((p) => ({ ...p, onco_surgical_audit: { ...p.onco_surgical_audit!, resection_margin_r0_r1_r2: e.target.value as any, }, })) } className={getFieldClass("onco_surgical_audit.resection_margin")} > <option value="Rx">Rx - Cannot be assessed</option> <option value="R0">R0 - No residual tumor (margins microscopic clear)</option> <option value="R1">R1 - Microscopic residual tumor (margins positive)</option> <option value="R2">R2 - Macroscopic residual tumor (margins gross positive)</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Lymph Nodes Harvested (Yield) </label> <input id="ln_harvested" type="number" min={0} value={formData.onco_surgical_audit?.total_lymph_nodes_harvested ?? ""} onChange={(e) => { const harv = parseInt(e.target.value) || 0; setFormData((p) => { const pos = p.onco_surgical_audit?.positive_lymph_nodes || 0; const ratio = harv > 0 ? parseFloat((pos / harv).toFixed(3)) : 0; return { ...p, onco_surgical_audit: { ...p.onco_surgical_audit!, total_lymph_nodes_harvested: harv, lymph_node_ratio: ratio, }, }; }); }} className={getFieldClass("onco_surgical_audit.total_lymph_nodes_harvested")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Positive Lymph Nodes </label> <input id="ln_positive" type="number" min={0} value={formData.onco_surgical_audit?.positive_lymph_nodes ?? ""} onChange={(e) => { const pos = parseInt(e.target.value) || 0; setFormData((p) => { const harv = p.onco_surgical_audit?.total_lymph_nodes_harvested || 1; const ratio = harv > 0 ? parseFloat((pos / harv).toFixed(3)) : 0; return { ...p, onco_surgical_audit: { ...p.onco_surgical_audit!, positive_lymph_nodes: pos, lymph_node_ratio: ratio, }, }; }); }} className={getFieldClass("onco_surgical_audit.positive_lymph_nodes")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Lymph Node Ratio (LNR) </label> <input id="ln_ratio" type="text" disabled value={ formData.onco_surgical_audit?.lymph_node_ratio !== undefined ? `${(formData.onco_surgical_audit.lymph_node_ratio * 100).toFixed(1)}%` : "0.0%" } className={`${getFieldClass("onco_surgical_audit.lymph_node_ratio")} bg-slate-100 dark:bg-slate-900 cursor-not-allowed`} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Lymphovascular Invasion (LVI) </label> <select id="lvi_status" value={formData.onco_surgical_audit?.lymphovascular_invasion || "Equivocal"} onChange={(e) => setFormData((p) => ({ ...p, onco_surgical_audit: { ...p.onco_surgical_audit!, lymphovascular_invasion: e.target.value as any, }, })) } className={getFieldClass("onco_surgical_audit.lymphovascular_invasion")} > <option value="Equivocal">Equivocal / Indeterminate</option> <option value="Present">Present (LVI+)</option> <option value="Absent">Absent (LVI-)</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Perineural Invasion (PNI) </label> <select id="pni_status" value={formData.onco_surgical_audit?.perineural_invasion || "Equivocal"} onChange={(e) => setFormData((p) => ({ ...p, onco_surgical_audit: { ...p.onco_surgical_audit!, perineural_invasion: e.target.value as any, }, })) } className={getFieldClass("onco_surgical_audit.perineural_invasion")} > <option value="Equivocal">Equivocal / Indeterminate</option> <option value="Present">Present (PNI+)</option> <option value="Absent">Absent (PNI-)</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Clavien-Dindo Surgical Grade </label> <select id="clavien_dindo" value={formData.onco_surgical_audit?.clavien_dindo_grade || ""} onChange={(e) => setFormData((p) => ({ ...p, onco_surgical_audit: { ...p.onco_surgical_audit!, clavien_dindo_grade: e.target.value, }, })) } className={getFieldClass("onco_surgical_audit.clavien_dindo_grade")} > <option value="">No Post-op Complications</option> <option value="Grade I">Grade I - Active therapy deviations</option> <option value="Grade II">Grade II - Actionable pharmacological therapeutic treatments</option> <option value="Grade IIIa">Grade IIIa - Surgical intervention without general anesthesia</option> <option value="Grade IIIb">Grade IIIb - Surgical intervention under GA</option> <option value="Grade IVa">Grade IVa - Single organ dysfunction</option> <option value="Grade IVb">Grade IVb - Multiorgan dysfunction requiring ICU stay</option> <option value="Grade V">Grade V - Death of patient</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Closest CRM / Radial Margin (mm) </label> <input id="closest_crm_mm" type="number" step="0.1" min={0} placeholder="e.g. 2.4 (0 if margin-positive)" value={formData.onco_surgical_audit?.closest_crm_mm ?? ""} onChange={(e) => { const val = e.target.value === "" ? undefined : parseFloat(e.target.value); setFormData((p) => ({ ...p, onco_surgical_audit: { ...p.onco_surgical_audit!, closest_crm_mm: val, }, })); }} className={getFieldClass("onco_surgical_audit.closest_crm_mm")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Tumor Regression Grade (TRG) </label> <select id="tumor_regression_grade" value={formData.onco_surgical_audit?.tumor_regression_grade || "Not Applicable (No Neoadjuvant Tx)"} onChange={(e) => setFormData((p) => ({ ...p, onco_surgical_audit: { ...p.onco_surgical_audit!, tumor_regression_grade: e.target.value as any, }, })) } className={getFieldClass("onco_surgical_audit.tumor_regression_grade")} > <option value="Not Applicable (No Neoadjuvant Tx)">Not Applicable (No Neoadjuvant Tx)</option> <option value="TRG 1 (Complete Response)">TRG 1 - Complete Response (No tumor cells)</option> <option value="TRG 2 (Near Complete)">TRG 2 - Near Complete (Rare single cells)</option> <option value="TRG 3 (Partial Response)">TRG 3 - Partial Response (Residual cancer with fibrosis)</option> <option value="TRG 4 (Minimal Response)">TRG 4 - Minimal Response (Degenerative changes but cancer outgrows)</option> <option value="TRG 5 (No Response)">TRG 5 - No Response (No regression seen)</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Synoptic Pathology Checklist Used? </label> <select id="synoptic_pathology" value={formData.onco_surgical_audit?.synoptic_pathology_reporting || "N/A"} onChange={(e) => setFormData((p) => ({ ...p, onco_surgical_audit: { ...p.onco_surgical_audit!, synoptic_pathology_reporting: e.target.value as any, }, })) } className={getFieldClass("onco_surgical_audit.synoptic_pathology_reporting")} > <option value="N/A">N/A / Unknown</option> <option value="Yes">Yes (CAP / RCPath Synoptic Report)</option> <option value="No">No (Narrative Report Only)</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Biobanking Registration </label> <select id="biobanking_stored" value={formData.onco_surgical_audit?.biobanking_sample_stored || "No"} onChange={(e) => setFormData((p) => ({ ...p, onco_surgical_audit: { ...p.onco_surgical_audit!, biobanking_sample_stored: e.target.value as any, biobank_id: e.target.value === "No" ? "" : p.onco_surgical_audit?.biobank_id, }, })) } className={getFieldClass("onco_surgical_audit.biobanking_sample_stored")} > <option value="No">No Specimen Consented</option> <option value="Yes">Yes (Stored in Tumor Repository)</option> </select> </div> {formData.onco_surgical_audit?.biobanking_sample_stored === "Yes" && ( <div className="md:col-span-4 grid grid-cols-1 md:grid-cols-2 gap-4 bg-indigo-50/25 dark:bg-indigo-950/10 p-4 border dark:border-indigo-900/30 rounded-xl animate-fade-in mb-2"> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Biobank Registry Specimen Barcode ID </label> <input id="biobank_registry_id" type="text" placeholder="e.g. BB-2026-CA-9938-L" value={formData.onco_surgical_audit?.biobank_id || ""} onChange={(e) => setFormData((p) => ({ ...p, onco_surgical_audit: { ...p.onco_surgical_audit!, biobank_id: e.target.value, }, })) } className={getFieldClass("onco_surgical_audit.biobank_id")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Biobank Specimen Tissue Type </label> <select id="biobank_tissue_type" value={formData.onco_surgical_audit?.biobank_tissue_type || "FFPE Block"} onChange={(e) => setFormData((p) => ({ ...p, onco_surgical_audit: { ...p.onco_surgical_audit!, biobank_tissue_type: e.target.value as any, }, })) } className={getFieldClass("onco_surgical_audit.biobank_tissue_type")} > <option value="FFPE Block">FFPE Block (Formalin-Fixed Paraffin-Embedded)</option> <option value="Fresh Frozen Tissue">Fresh Frozen Tissue</option> <option value="Liquid Biopsy (Serum/Plasma)">Liquid Biopsy (Serum / Plasma)</option> <option value="Saliva/Other">Saliva / Other Biospecimen</option> </select> </div> </div> )} </div> </div> {/* SECTION W: CLINICAL RESEARCH TRIAL REGISTRY & SURVIVOURSHIP TRACKER */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <h2 className="text-lg font-bold pb-3 flex items-center gap-2"> <TrendingUp className="w-5 h-5 text-indigo-600 dark:text-indigo-400" /> Section W: Clinical Research Trial Registry & Survivorship Audit Tracker </h2> <div className="grid grid-cols-1 md:grid-cols-4 gap-6"> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Clinical Trial Enrollment </label> <select id="trial_enrolled" value={formData.clinical_research_trial?.trial_enrolled || "No"} onChange={(e) => setFormData((p) => ({ ...p, clinical_research_trial: { ...p.clinical_research_trial!, trial_enrolled: e.target.value as any, }, })) } className={getFieldClass("clinical_research_trial.trial_enrolled")} > <option value="No">Not enrolled</option> <option value="Yes">Enrolled</option> <option value="Eligible - Refused">Eligible but patient declined participation</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Trial Registry ID / Protocol Code </label> <input id="trial_name" type="text" placeholder="e.g. SLCTR-2026-004 (OncoSafe)" value={formData.clinical_research_trial?.trial_name_code || ""} onChange={(e) => setFormData((p) => ({ ...p, clinical_research_trial: { ...p.clinical_research_trial!, trial_name_code: e.target.value, }, })) } disabled={formData.clinical_research_trial?.trial_enrolled !== "Yes"} className={`${getFieldClass("clinical_research_trial.trial_name_code")} disabled:opacity-50`} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Study Protocol Type </label> <select id="study_type" value={formData.clinical_research_trial?.study_type || ""} onChange={(e) => setFormData((p) => ({ ...p, clinical_research_trial: { ...p.clinical_research_trial!, study_type: e.target.value, }, })) } className={getFieldClass("clinical_research_trial.study_type")} > <option value="">No Active Study Protocol</option> <option value="Randomized Controlled Trial (RCT)">Randomized Controlled Trial (RCT)</option> <option value="Observational Cohort Study">Observational Prospective Cohort</option> <option value="Retrospective Research Database">Retrospective Registry / Audit Database</option> <option value="Translational Research & Biobanking">Translational Bench-to-Bedside Protocol</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Last Known Clinical Status </label> <select id="survival_status" value={formData.clinical_research_trial?.last_followup_status || "Alive and disease-free"} onChange={(e) => setFormData((p) => ({ ...p, clinical_research_trial: { ...p.clinical_research_trial!, last_followup_status: e.target.value as any, }, })) } className={getFieldClass("clinical_research_trial.last_followup_status")} > <option value="Alive and disease-free">Alive and Disease-Free (Remission)</option> <option value="Alive with disease">Alive with Recurrent / Metastatic Disease</option> <option value="Deceased">Deceased</option> <option value="Lost to follow-up">Lost to Follow-up</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Disease-Free Survival (DFS, Months) </label> <input id="dfs_months" type="number" min={0} value={formData.clinical_research_trial?.disease_free_survival_months ?? ""} onChange={(e) => setFormData((p) => ({ ...p, clinical_research_trial: { ...p.clinical_research_trial!, disease_free_survival_months: parseInt(e.target.value) || 0, }, })) } className={getFieldClass("clinical_research_trial.disease_free_survival_months")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Overall Survival (OS, Months) </label> <input id="os_months" type="number" min={0} value={formData.clinical_research_trial?.overall_survival_months ?? ""} onChange={(e) => setFormData((p) => ({ ...p, clinical_research_trial: { ...p.clinical_research_trial!, overall_survival_months: parseInt(e.target.value) || 0, }, })) } className={getFieldClass("clinical_research_trial.overall_survival_months")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Tumour Recurrence Detected? </label> <select id="recurrence_detected" value={formData.clinical_research_trial?.recurrence_detected || "No"} onChange={(e) => setFormData((p) => ({ ...p, clinical_research_trial: { ...p.clinical_research_trial!, recurrence_detected: e.target.value as any, }, })) } className={getFieldClass("clinical_research_trial.recurrence_detected")} > <option value="No">No Recurrence / Complete Remission</option> <option value="Yes">Confirmed Regional/Distant Recurrence</option> <option value="Suspected">Suspected Biochemical / Radiographic Recurrence</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Therapy Response (RECIST v1.1) </label> <select id="treatment_response_recist" value={formData.clinical_research_trial?.treatment_response_recist || "Not Evaluated"} onChange={(e) => setFormData((p) => ({ ...p, clinical_research_trial: { ...p.clinical_research_trial!, treatment_response_recist: e.target.value as any, }, })) } className={getFieldClass("clinical_research_trial.treatment_response_recist")} > <option value="Not Evaluated">Not Evaluated</option> <option value="CR (Complete Response)">CR (Complete Response)</option> <option value="PR (Partial Response)">PR (Partial Response)</option> <option value="SD (Stable Disease)">SD (Stable Disease)</option> <option value="PD (Progressive Disease)">PD (Progressive Disease)</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Therapy Toxicity (CTCAE v5.0) </label> <select id="treatment_toxicity_ctcae" value={formData.clinical_research_trial?.treatment_toxicity_ctcae || "None"} onChange={(e) => setFormData((p) => ({ ...p, clinical_research_trial: { ...p.clinical_research_trial!, treatment_toxicity_ctcae: e.target.value as any, }, })) } className={getFieldClass("clinical_research_trial.treatment_toxicity_ctcae")} > <option value="None">None (No toxic events)</option> <option value="Grade 1-2 (Mild/Moderate)">Grade 1-2 (Mild / Moderate Events)</option> <option value="Grade 3 (Severe)">Grade 3 (Severe Treatment Complications)</option> <option value="Grade 4 (Life-threatening)">Grade 4 (Life-threatening / Disability)</option> <option value="Grade 5 (Death)">Grade 5 (Treatment-related death)</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Research QoL Score (%) </label> <input id="qol_score_percentage" type="number" min={0} max={100} placeholder="e.g. 85" value={formData.clinical_research_trial?.qol_score_percentage ?? ""} onChange={(e) => { const val = e.target.value === "" ? undefined : parseInt(e.target.value); setFormData((p) => ({ ...p, clinical_research_trial: { ...p.clinical_research_trial!, qol_score_percentage: val, }, })); }} className={getFieldClass("clinical_research_trial.qol_score_percentage")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Unplanned 30-day Readmission? </label> <select id="unplanned_30day_readmission" value={formData.clinical_research_trial?.unplanned_30day_readmission || "No"} onChange={(e) => setFormData((p) => ({ ...p, clinical_research_trial: { ...p.clinical_research_trial!, unplanned_30day_readmission: e.target.value as any, }, })) } className={getFieldClass("clinical_research_trial.unplanned_30day_readmission")} > <option value="No">No</option> <option value="Yes">Yes (Readmitted following intervention)</option> </select> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Unplanned Return to Theatre? </label> <select id="unplanned_return_to_theatre" value={formData.clinical_research_trial?.unplanned_return_to_theatre || "No"} onChange={(e) => setFormData((p) => ({ ...p, clinical_research_trial: { ...p.clinical_research_trial!, unplanned_return_to_theatre: e.target.value as any, }, })) } className={getFieldClass("clinical_research_trial.unplanned_return_to_theatre")} > <option value="No">No</option> <option value="Yes">Yes (Return to theatre for complication)</option> </select> </div> {formData.clinical_research_trial?.recurrence_detected !== "No" && ( <div className="md:col-span-4 grid grid-cols-1 md:grid-cols-2 gap-6 animate-fade-in"> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Recurrence Detection Date </label> <input id="recurrence_date" type="date" value={formData.clinical_research_trial?.recurrence_date || ""} onChange={(e) => setFormData((p) => ({ ...p, clinical_research_trial: { ...p.clinical_research_trial!, recurrence_date: e.target.value, }, })) } className={getFieldClass("clinical_research_trial.recurrence_date")} /> </div> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Recurrence Anatomical Location / Site </label> <input id="recurrence_region" type="text" placeholder="Anastomotic loop, lymph nodes, lung/liver metastasis" value={formData.clinical_research_trial?.recurrence_site || ""} onChange={(e) => setFormData((p) => ({ ...p, clinical_research_trial: { ...p.clinical_research_trial!, recurrence_site: e.target.value, }, })) } className={getFieldClass("clinical_research_trial.recurrence_site")} /> </div> </div> )} </div> </div> {/* SECTION T: OTHER NOTES */} <div className="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm space-y-6"> <h2 className="text-lg font-bold pb-3"> Section T: Other Notes </h2> <div> <label className="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1"> Other Clinical Notes (Family history details or general notes) </label> <textarea id="other_clinical_notes" rows={4} value={formData.other_notes || ""} onChange={(e) => setFormData((p) => ({ ...p, other_notes: e.target.value })) } className={getFieldClass("other_notes")} placeholder="Insert family telemetry, secondary diagnostics notes, or historical observations..." ></textarea> </div> </div> {/* MASTER SUBMIT BUTTON PANEL */} <div className="flex gap-4 items-center justify-end"> <button id="cancel_form_btn" type="button" onClick={onCancel} className="px-6 py-2.5 text-slate-700 dark:text-slate-300 rounded-xl text-sm font-semibold bg-white dark:bg-slate-800 hover:bg-neutral-50 dark:hover:bg-slate-700 transition" > Cancel </button> <button id="save_patient_btn" type="submit" disabled={loading} className="px-8 py-2.5 bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white font-semibold rounded-xl text-sm shadow-sm hover:shadow transition disabled:opacity-50" > {loading ? "Committing Telemetry..." : existingPatientId ? "Revise Patient Document" : "Authorize and Save Record"} </button> </div> </div> </form> </div> );}