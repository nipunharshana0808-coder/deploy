// Calculators scoped to this surgery const rawIcuStay = (new Date(surgery.icu_exit_date || "").getTime() - new Date(surgery.icu_entry_date || "").getTime()) / 86400000; const calculatedIcuStayDays = isNaN(rawIcuStay) || rawIcuStay < 0 ? 0 : Math.ceil(rawIcuStay); const icuStayDays = surgery.icu_stay_days !== undefined ? surgery.icu_stay_days : calculatedIcuStayDays; const rawWardStay = (new Date(surgery.after_surgery_discharged_date || "").getTime() - new Date(surgery.after_surgery_ward_entry_date || "").getTime()) / 86400000; const wardStayDays = isNaN(rawWardStay) || rawWardStay < 0 ? 0 : Math.ceil(rawWardStay); const hospitalStayDays = surgery.hospital_stay_days !== undefined ? surgery.hospital_stay_days : (icuStayDays + wardStayDays); const complicationsCount = (surgery.complications || []).length; return ( <div key={surgIdx} className="space-y-4 relative pb-6 border-b dark:border-slate-700/50 last:border-0 last:pb-0"> {/* SURGERY TITLE HEADER */} <div className="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2"> <h4 className="text-sm font-bold text-slate-800 dark:text-slate-100 flex items-center gap-2"> <span className="w-6 h-6 rounded bg-rose-50 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400 flex justify-center items-center text-xs"> {surgIdx + 1} </span> {surgery.procedure_name || "Unnamed Procedure"} </h4> <span className="text-[10px] bg-slate-100 dark:bg-slate-900 px-2 py-0.5 rounded text-neutral-500 font-mono"> Hospital Stay: {hospitalStayDays} Days </span> </div> {/* BASIC DETAILS ROW */} <div className="grid grid-cols-2 lg:grid-cols-5 gap-4 text-xs bg-slate-50 dark:bg-slate-900/30 p-4 rounded-xl border dark:border-slate-700/40"> <div> <span className="text-neutral-400 block mb-0.5">Done Date:</span> <span className="font-semibold">{surgery.done_date || "N/A"}</span> </div> <div> <span className="text-neutral-400 block mb-0.5">Site:</span> <span className="font-semibold text-rose-600 dark:text-rose-400"> {surgery.surgery