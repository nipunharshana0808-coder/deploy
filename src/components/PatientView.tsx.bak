(Microscopic Residu)" : patient.onco_surgical_audit?.resection_margin_r0_r1_r2 === "R2" ? "R2 (Macroscopic Residu)" : "Rx (Cannot be assessed)"} </span> </div> <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Lymph Node Yield </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.onco_surgical_audit?.total_lymph_nodes_harvested ?? 0} harvested </span> </div> <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Positive Lymph Nodes </span> <span className={`font-semibold ${patient.onco_surgical_audit?.positive_lymph_nodes ? 'text-rose-600 font-bold' : 'text-slate-700 dark:text-slate-200'}`}> {patient.onco_surgical_audit?.positive_lymph_nodes ?? 0} positive nodes </span> </div> <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Lymph Node Ratio (LNR) </span> <span className="font-bold text-indigo-600 dark:text-indigo-400"> {patient.onco_surgical_audit?.lymph_node_ratio !== undefined ? `${(patient.onco_surgical_audit.lymph_node_ratio * 100).toFixed(1)}%` : "0.0%"} </span> </div> <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Lymphovascular Invasion (LVI) </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.onco_surgical_audit?.lymphovascular_invasion || "Equivocal"} </span> </div> <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Perineural Invasion (PNI) </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.onco_surgical_audit?.perineural_invasion || "Equivocal"} </span> </div> <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Post-op Clavien-Dindo Classification </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.onco_surgical_audit?.clavien_dindo_grade || "Grade 0 (Uneventful)"} </span> </div> <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Specimen Biobanking Sample Stored </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.onco_surgical_audit?.biobanking_sample_stored === "Yes" ? `Stored (ID: ${patient.onco_surgical_audit.biobank_id || "N/A"})` : "No"} </span> </div> {patient.onco_surgical_audit?.biobanking_sample_stored === "Yes" && patient.onco_surgical_audit?.biobank_tissue_type && ( <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Biobank Specimen Tissue </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.onco_surgical_audit.biobank_tissue_type} </span> </div> )} {patient.onco_surgical_audit?.closest_crm_mm !== undefined && ( <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Closest CRM / Radial Margin </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.onco_surgical_audit.closest_crm_mm} mm </span> </div> )} {patient.onco_surgical_audit?.tumor_regression_grade && ( <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Tumor Regression Grade (TRG) </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.onco_surgical_audit.tumor_regression_grade} </span> </div> )} {patient.onco_surgical_audit?.synoptic_pathology_reporting && ( <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Synoptic Report Used </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.onco_surgical_audit.synoptic_pathology_reporting} </span> </div> )} </div> </div> </div> {/* SECTION W: CLINICAL RESEARCH TRIAL REGISTRY & SURVIVORSHIP AUDIT TRACKER */} <div className="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-sm space-y-4"> <h3 className="text-sm font-bold pb-2 flex items-center gap-2"> <TrendingUp className="w-4 h-4 text-indigo-600 dark:text-indigo-400" /> Section W: Clinical Research Trial Registry & Survivorship Tracker </h3> <div className="p-4 bg-neutral-50 dark:bg-slate-900/40 rounded-lg text-xs space-y-4"> <div className="grid grid-cols-2 md:grid-cols-4 gap-4"> <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Trial Enrollment Status </span> <span className={`font-bold inline-block px-2 py-0.5 rounded text-[10px] ${ patient.clinical_research_trial?.trial_enrolled === "Yes" ? "bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 border border-indigo-500/20" : "bg-neutral-500/10 text-slate-600" }`}> {patient.clinical_research_trial?.trial_enrolled || "No"} </span> </div> <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Trial Protocol Registry Code </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.clinical_research_trial?.trial_name_code || "N/A"} </span> </div> <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Research Design Type </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.clinical_research_trial?.study_type || "Registry Study / N/A"} </span> </div> <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Last Confirmed Follow-up Status </span> <span className="font-bold text-slate-800 dark:text-slate-100"> {patient.clinical_research_trial?.last_followup_status || "Alive and disease-free"} </span> </div> <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Disease-Free Survival (DFS) </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.clinical_research_trial?.disease_free_survival_months !== undefined ? `${patient.clinical_research_trial.disease_free_survival_months} months` : "Not Tracked"} </span> </div> <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Overall Survival (OS) </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.clinical_research_trial?.overall_survival_months !== undefined ? `${patient.clinical_research_trial.overall_survival_months} months` : "Not Tracked"} </span> </div> <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Disease Recurrence Detected </span> <span className={`font-semibold ${patient.clinical_research_trial?.recurrence_detected !== "No" ? 'text-rose-600 font-bold' : 'text-slate-700 dark:text-slate-200'}`}> {patient.clinical_research_trial?.recurrence_detected || "No"} </span> </div> <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Recurrence Coordinates </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.clinical_research_trial?.recurrence_detected !== "No" ? `${patient.clinical_research_trial?.recurrence_site || "Unspecified site"} (on ${patient.clinical_research_trial?.recurrence_date || "Unknown Date"})` : "None detected"} </span> </div> {patient.clinical_research_trial?.treatment_response_recist && ( <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> RECIST v1.1 Response </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.clinical_research_trial.treatment_response_recist} </span> </div> )} {patient.clinical_research_trial?.treatment_toxicity_ctcae && ( <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> CTCAE Toxicity Profile </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.clinical_research_trial.treatment_toxicity_ctcae} </span> </div> )} {patient.clinical_research_trial?.qol_score_percentage !== undefined && ( <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Research QoL Score (%) </span> <span className="font-semibold text-slate-700 dark:text-slate-200"> {patient.clinical_research_trial.qol_score_percentage}% </span> </div> )} {patient.clinical_research_trial?.unplanned_30day_readmission && ( <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Unplanned 30-Day Readmission </span> <span className={`font-semibold ${patient.clinical_research_trial.unplanned_30day_readmission === 'Yes' ? 'text-rose-600 font-bold' : 'text-slate-700 dark:text-slate-200'}`}> {patient.clinical_research_trial.unplanned_30day_readmission} </span> </div> )} {patient.clinical_research_trial?.unplanned_return_to_theatre && ( <div> <span className="text-[10px] text-neutral-400 uppercase font-bold block mb-0.5"> Unplanned Return to Theatre </span> <span className={`font-semibold ${patient.clinical_research_trial.unplanned_return_to_theatre === 'Yes' ? 'text-rose-600 font-bold' : 'text-slate-700 dark:text-slate-200'}`}> {patient.clinical_research_trial.unplanned_return_to_theatre} </span> </div> )} </div> </div> </div> {/* SECTION X: AUDIT TRAIL */} <div className="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-sm space-y-4"> <h3 className="text-sm font-bold pb-2 flex items-center gap-2"> <ShieldCheck className="w-4.5 h-4.5 text-blue-500" /> Section X: System Audit Log </h3> <div className="space-y-2 text-xs max-h-64 overflow-y-auto"> {(patient.audit_trail || []).sort((a,b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime()).map(log => ( <div key={log.id} className="p-2 bg-neutral-50 dark:bg-slate-900/40 rounded border border-neutral-100 dark:border-slate-800 grid grid-cols-[160px,1fr] gap-4"> <div className="font-mono text-[9px] text-neutral-500"> {new Date(log.timestamp).toLocaleString()} </div> <div> <span className={`font-bold uppercase text-[9px] ${log.action === 'access' ? 'text-blue-500' : 'text-amber-600'}`}> {log.action} </span> <span className="text-slate-700 dark:text-slate-200 ml-2 font-medium"> {log.actor_name} </span> <p className="text-neutral-500 mt-1">{log.details}</p> {log.ip_address && <p className="text-[9px] text-neutral-400 mt-0.5">IP: {log.ip_address}</p>} </div> </div> ))} {(patient.audit_trail || []).length === 0 && <p className="text-neutral-400 font-mono italic">No actions logged.</p>} </div> </div> </div> </div> </div> </div> );*/}