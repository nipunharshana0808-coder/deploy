/* @ts-nocheck*/
import React, { useState, useEffect, useRef } from "react";import {  FileText,  ArrowLeft,  MessageSquare,  Sparkles,  Send,  Library,  PlusCircle,  Trash2,  Edit,  HelpCircle,  Eye,  RefreshCw,  Layers,  ShieldCheck,  Heart,  Stethoscope,  Scissors,  Dna,  Flame,  ShieldAlert,  HeartHandshake,  History,  Activity,  Users,  Award,  TrendingUp,  Upload,} from "lucide-react";import {  Patient,  MediaRecord,  SocialHistory,  Investigations,  Allergies,} from "../new-patient-types";import { STAGING_OPTIONS, HISTOLOGICAL_GRADING_OPTIONS } from "../data/staging";interface PatientViewProps {  patientId: string;  onBack: () => void;  onEdit: (patientId: string) => void;  onDelete: (patientId: string) => void;}interface ChatMessage {  role: "user" | "model";  text: string;  timestamp: string;}export default function PatientView({  patientId,  onBack,  onEdit,  onDelete,}: PatientViewProps): React.ReactElement {  const [patient, setPatient] = useState<Patient | null>(null);  const [loading, setLoading] = useState(true);  const [errorMsg, setErrorMsg] = useState("");  /* Media attachments list */ const [attachments, setAttachments] = useState<    MediaRecord[]  >([]); /* Active investigation visual tab const [activeInvTab, setActiveInvTab] = useState< | "imaging" | "biopsies" | "endoscopy" | "ihc" | "genetic" | "tumour_markers" | "others" >("imaging");
// AI chat states const [chatHistory, setChatHistory] = useState<ChatMessage[]>([]); const [chatInput, setChatInput] = useState(""); const [chatLoading, setChatLoading] = useState(false); const chatEndRef = useRef<HTMLDivElement>(null);
// New follow-up state const [newFollowUpNote, setNewFollowUpNote] = useState(""); const [followUpLoading, setFollowUpLoading] = useState(false); useEffect(() => { 
// 1. Fetch patient fetch(`/api/patients/${patientId}`) .then((res) => { if (!res.ok) throw new Error("Unassigned patient record ID."); return res.json(); }) .then((data) => { setPatient(data); setLoading(false);
// Start conversation with a friendly clinical hint setChatHistory([ { role: "model", text: `Authorized Clinical Agent active. I have loaded ${data.title || "Dr."} ${data.initials} ${data.last_name}'s oncology timeline. Ask me anything about their medical reports, drug history, or oncology guidelines (NCCN/ESMO).`, timestamp: new Date().toLocaleTimeString(), }, ]); }) .catch((err) => { setErrorMsg(err.message); setLoading(false); });
// 2. Fetch associated media list fetch(`/api/files?patientId=${encodeURIComponent(patientId)}`) .then((res) => res.json()) .then((data) => setAttachments(data.map((item: any) => ({ public_id: item.id, secure_url: item.webViewLink || item.webContentLink || "", resource_type: item.mimeType || "", format: item.mimeType || "", bytes: item.size || 0, created_at: item.uploadDate || "", folder: item.driveFolderId || "", tags: [], original_filename: item.name || "", upload_type: item.extracted ? "ai_extracted" : "manual", })))) .catch((err) => console.error(err)); }, [patientId]);
// Auto scroll chat to base useEffect(() => { chatEndRef.current?.scrollIntoView({ behavior: "smooth" }); }, [chatHistory]);
// Submit chat query to server-side Gemini Proxy const handleSendChat = async (e: React.FormEvent) => { e.preventDefault(); if (!chatInput.trim() || chatLoading || !patient) return; const userMsg: ChatMessage = { role: "user", text: chatInput, timestamp: new Date().toLocaleTimeString(), }; setChatHistory((prev) => [...prev, userMsg]); setChatInput(""); setChatLoading(true); try { 
// Package query alongside previous chat entries and patient records for complete grounding const res = await fetch("/api/chat", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ patientRecord: patient, query: userMsg.text, history: chatHistory.map((h) => ({ role: h.role, parts: [{ text: h.text }], })), }), }); const data = await res.json(); if (!res.ok) throw new Error(data.error || "Gemini Consultation error."); setChatHistory((prev) => [ ...prev, { role: "model", text: data.reply, timestamp: new Date().toLocaleTimeString(), }, ]); } catch (err: any) { setChatHistory((prev) => [ ...prev, { role: "model", text: `Error parsing diagnostic telemetry: ${err.message}`, timestamp: new Date().toLocaleTimeString(), }, ]); } finally { setChatLoading(false); } };
// Quick Chat Suggestion Trigger const triggerQuickPrompt = (promptText: string) => { setChatInput(promptText); };
// Add a follow up log const handleAddFollowUp = async (e: React.FormEvent) => { e.preventDefault(); if (!newFollowUpNote.trim() || !patient) return; setFollowUpLoading(true); try { const updatedFollowUps = [ ...(patient.follow_up_notes || []), { date: new Date().toISOString().split("T")[0], findings: [newFollowUpNote] }, ]; const res = await fetch(`/api/patients/${patientId}`, { method: "PUT", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ ...patient, follow_up_notes: updatedFollowUps, }), }); const data = await res.json(); if (!res.ok) throw new Error("Failed to post follow up note"); setPatient(data); setNewFollowUpNote(""); } catch (err: any) { alert(err.message); } finally { setFollowUpLoading(false); } }; if (loading) { return ( <div className="p-16 text-center text-sm font-mono text-neutral-400"> Loading oncologist ledger workspace... </div> ); } if (errorMsg || !patient) { return ( <div className="p-8 text-center bg-rose-500/10 border border-rose-500/30 text-rose-500 rounded-xl space-y-4"> <ShieldAlert className="w-8 h-8 mx-auto" /> <p className="font-semibold"> {errorMsg || "Failed to map records folder."} </p> <button onClick={onBack} className="px-4 py-2 bg-slate-800 rounded font-semibold text-xs text-white" > Back to search </button> </div> ); }
// Calculate age const currentYear = new Date().getFullYear(); const birthYear = patient.dob ? parseInt(patient.dob.split("-")[0]) : null; const approxAge = birthYear ? currentYear - birthYear : "Unknown";
// Surgery stay calculation variables const parsedIcuEntry = patient.surgery?.icu_entry_date; const parsedIcuExit = patient.surgery?.icu_exit_date; const icuStayDays = (() => { if ( patient.surgery?.icu_entered !== "Yes" || !parsedIcuEntry || !parsedIcuExit ) return 0; const d1 = new Date(parsedIcuEntry); const d2 = new Date(parsedIcuExit); if (isNaN(d1.getTime()) || isNaN(d2.getTime())) return 0; const diff = Math.ceil( (d2.getTime() - d1.getTime()) / (1000 * 60 * 60 * 24), ); return diff >= 0 ? diff : 0; })(); const parsedWardEntry = patient.surgery?.after_surgery_ward_entry_date; const parsedWardExit = patient.surgery?.after_surgery_discharged_date; const wardStayDays = (() => { if (!parsedWardEntry || !parsedWardExit) return 0; const d1 = new Date(parsedWardEntry); const d2 = new Date(parsedWardExit); if (isNaN(d1.getTime()) || isNaN(d2.getTime())) return 0; const diff = Math.ceil( (d2.getTime() - d1.getTime()) / (1000 * 60 * 60 * 24), ); return diff >= 0 ? diff : 0; })(); const parsedSurgDate = patient.surgery?.done_date; const hospitalStayDays = (() => { if (!parsedSurgDate || !parsedWardExit) return 0; const d1 = new Date(parsedSurgDate); const d2 = new Date(parsedWardExit); if (isNaN(d1.getTime()) || isNaN(d2.getTime())) return 0; const diff = Math.ceil( (d2.getTime() - d1.getTime()) / (1000 * 60 * 60 * 24), ); return diff >= 0 ? diff : 0; })(); const complicationsCount = (patient.surgery?.complications || []).length; return ( <div id="patient-view-container" className="space-y-8 animate-fade-in text-neutral-800 dark:text-neutral-100 pb-20" > {/* Top action header */} <div className="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pb-5"> <button id="back_to_search_btn" onClick={onBack} className="px-3 py-1.5 border dark:border-slate-700/80 rounded-lg text-xs font-bold hover:bg-neutral-50 dark:hover:bg-slate-700 inline-flex items-center gap-1 bg-white dark:bg-slate-800 text-slate-705 dark:text-slate-300" > <ArrowLeft className="w-4 h-4" /> Back to Records Index </button> <div className="flex gap-2"> {/* Action buttons */} <button onClick={() => onEdit(patientId)} className="px-3.5 py-1.5 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg text-xs font-bold inline-flex items-center gap-1.5 text-blue-700 dark:text-blue-300 hover:bg-blue-100" > <Edit className="w-4 h-4" /> Edit Record </button> <button onClick={() => onDelete(patientId)} className="px-3.5 py-1.5 bg-rose-50 dark:bg-rose-900/20 border border-rose-200 dark:border-rose-800 rounded-lg text-xs font-bold inline-flex items-center gap-1.5 text-rose-700 dark:text-rose-400 hover:bg-rose-100" > <Trash2 className="w-4 h-4" /> Delete Record </button> </div> </div> {/* TWO PANEL GRID LAYOUT: LEFT RECORD DETAILS, RIGHT AI ASSISTANT CHAT */} <div className="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start"> {/* LEFT COLUMN: THE COMPLETE RECORD DOSSIER (COL SPAN 8) */} <div className="lg:col-span-7 space-y-8 print-no-border"> {/* AI CHAT INTERFACE */} <div className="bg-white dark:bg-slate-900 rounded-2xl p-6 shadow-sm"> <div className="flex items-center gap-2 font-bold text-sm mb-4"> <Sparkles className="w-4 h-4 text-emerald-500" /> AI Clinical Consultant </div> <div className="h-64 overflow-y-auto p-4 space-y-4 mb-4 bg-neutral-50 dark:bg-slate-950/40 rounded-lg"> {chatHistory.map((msg, i) => ( <div key={i} className={`text-xs p-3 rounded-lg ${msg.role === 'user' ? 'bg-blue-50 dark:bg-blue-900/20 self-end ml-10' : 'bg-neutral-100 dark:bg-slate-800 self-start mr-10'}`}> {msg.text} </div> ))} <div ref={chatEndRef} /> </div> <form onSubmit={handleSendChat} className="flex gap-2 p-2 pt-0 pt-4 items-center"> <input type="file" id="file-upload" className="hidden" onChange={(e) => { if (e.target.files && e.target.files[0]) { /* handle file logic */ } }} /> <label htmlFor="file-upload" className="p-2 cursor-pointer text-neutral-400 hover:text-emerald-500"> <Upload className="w-4 h-4" /> </label> <input value={chatInput} onChange={(e) => setChatInput(e.target.value)} className="flex-1 bg-neutral-50 dark:bg-slate-900 border dark:border-slate-700 rounded-lg p-2 text-xs" placeholder="Discuss patient case..." /> <button type="submit" className="bg-emerald-500 text-white p-2 rounded-lg"> <Send className="w-4 h-4" /> </button> </form> </div> {/* 1. THE HERO CARD Header */} <div className="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-sm space-y-4"> <div className="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4"> <div className="flex items-center gap-4"> <div className="w-14 h-14 bg-emerald-500/10 text-emerald-500 rounded-2xl flex items-center justify-center font-bold font-mono text-xl border border-emerald-500/10"> {(patient.initials || "").replace(/\./g, "").substring(0, 2)} </div> <div> <h2 id="patient-detail-name" className="text-xl font-bold text-slate-800 dark:text-white" > {patient.title} {patient.initials} {patient.last_name} </h2> <div className="flex flex-wrap items-center gap-2 text-xs text-neutral-500 font-medium mt-0.5"> <span>{patient.gender}</span> <span>•</span> <span> Age {approxAge} ({patient.dob}) </span> <span>•</span> <span>NIC: {patient.nic}</span> </div> </div> </div> <div className="flex flex-col items-end text-xs font-mono"> <span className="text-[10px] text-neutral-400"> Clinic Admission No: </span> <span className="font-bold text-slate-800 dark:text-white text-sm"> {patient.clinic_no || "Unassigned"} </span> </div> </div> {/* Badges types */} <div className="flex flex-wrap gap-2 pt-2 pt-3"> {(patient.oncology_type || []).map((type, idx) => ( <span key={idx} className="px-2.5 py-1 bg-emerald-500/10 text-emerald-500 dark:text-emerald-400 text-xs font-bold rounded-lg border border-emerald-500/20" > {type === "Other" && patient.other_oncology_type ? `Other: ${patient.other_oncology_type}` : type} </span> ))} {patient.bht_no && ( <span className="px-2.5 py-1 bg-slate-100 dark:bg-slate-900 border dark:border-slate-800 text-neutral-500 dark:text-slate-400 text-xs font-mono rounded-lg"> BHT No: {patient.bht_no} </span> )} {patient.living_area && ( <span className="px-2.5 py-1 bg-slate-100 dark:bg-slate-900 border dark:border-slate-800 text-neutral-500 dark:text-slate-400 text-xs rounded-lg"> Area: {patient.living_area} </span> )} </div> </div> {/* 2. TABBED CLINICAL SECTIONS */} {/* SECTION A & B: BIOMETRICS & SOURCING */} <div className="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-sm space-y-4"> <h3 className="text-sm font-bold pb-2 flex items-center gap-2"> <Stethoscope className="w-4.5 h-4.5 text-emerald-500" /> Sourcing & Medical Status </h3> <div className="grid grid-cols-2 sm:grid-cols-3 gap-6 text-xs"> <div> <span className="text-neutral-400 block mb-0.5"> Contact Line: </span> <span className="font-mono font-semibold">{patient.tp_countryCode || "+94"} {patient.tp}</span> </div> <div> <span className="text-neutral-400 block mb-0.5"> Hospital Name: </span> <span className="font-semibold"> {patient.hospital_name || "N/A"} </span> </div> <div> <span className="text-neutral-400 block mb-0.5"> Hospital Location: </span> <span className="font-semibold"> {patient.hospital_location || "N/A"} </span> </div> <div> <span className="text-neutral-400 block mb-0.5"> Marital Status: </span> <span>{patient.marital_status || "N/A"}</span> </div> <div> <span className="text-neutral-400 block mb-0.5"> Occupation: </span> <span>{patient.occupation || "N/A"}</span> </div> <div> <span className="text-neutral-400 block mb-0.5"> Informed Patient Consent: </span> <span className="text-emerald-500 font-bold flex items-center gap-1"> <ShieldCheck className="w-3.5 h-3.5" /> Checked ( {patient.consent_date}) </span> </div> </div> </div> {/* SECTION C: MEDICAL HISTORIES */} <div className="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-sm space-y-6"> <h3 className="text-sm font-bold pb-2 flex items-center gap-2"> <History className="w-4.5 h-4.5 text-blue-500" /> Patient Historical Diagnostics </h3> {/* PRESENTING COMPLAINTS */} <div className="space-y-2"> <span className="text-xs font-bold text-slate-700 dark:text-slate-300"> Presenting Complaints: </span> <div className="space-y-1.5 text-xs"> {(patient.presenting_complaints || []).map((item, idx) => ( <div key={idx} className="p-2 rounded-lg bg-neutral-50 dark:bg-slate-900/40 flex justify-between" > <span className="font-semibold">{item.complaint_name}</span> <span className="text-neutral-500 font-mono"> {item.duration} {item.notes && `• ${item.notes}`} </span> </div> ))} {(patient.presenting_complaints || []).length === 0 && ( <p className="text-[11px] text-neutral-400 font-mono"> No complaint records logged. </p> )} </div> </div> {/* COMORBIDITIES */} <div className="space-y-2 pt-2 pt-4"> <span className="text-xs font-bold text-slate-700 dark:text-slate-300"> Pre-existing Comorbidities: </span> <div className="space-y-1.5 text-xs"> {(patient.comorbidities || []).map((item, idx) => ( <div key={idx} className="p-2 rounded-lg bg-neutral-50 dark:bg-slate-900/40 flex justify-between" > <span className="font-semibold"> {item.comorbidity_name} </span> <span className="text-neutral-500 font-mono"> {item.duration} {item.notes && `• ${item.notes}`} </span> </div> ))} {(patient.comorbidities || []).length === 0 && ( <p className="text-[11px] text-neutral-400 font-mono"> Negligible comorbidities. </p> )} </div> </div> {/* DRUG HISTORY & ALLERGIES */} <div className="space-y-3 pt-2 pt-4 text-xs"> <span className="font-bold text-slate-700 dark:text-slate-300"> Drugs & Allergies: </span> <div className="grid grid-cols-1 sm:grid-cols-2 gap-4"> <div className="p-3 bg-neutral-50 dark:bg-slate-900/40 rounded-lg space-y-1.5"> <span className="font-semibold block border-b pb-1"> Drug Prescription list: </span> {(patient.drug_history || []).map((dh, i) => ( <div key={i} className="text-[11px] font-mono select-all"> • {dh.drug_name} {dh.dose} {dh.frequency} ({dh.route}) </div> ))} {(patient.drug_history || []).length === 0 && ( <span className="text-[11px] text-neutral-400"> No active medication records. </span> )} </div> <div className="p-3 bg-rose-500/5 rounded-lg space-y-1.5 border border-rose-500/10"> <span className="font-semibold block border-b pb-1 text-rose-600 dark:text-rose-400"> Allergies: </span> <div className="text-[11px] space-y-1"> <p> <span className="text-neutral-400">Drugs:</span>{" "} {(patient.allergies?.drugs || []).join(", ") || "None"} </p> <p> <span className="text-neutral-400">Foods:</span>{" "} {(patient.allergies?.foods || []).join(", ") || "None"} </p> <p> <span className="text-neutral-400">Others:</span>{" "} {(patient.allergies?.others || []).join(", ") || "None"} </p> </div> </div> </div> </div> {/* FAMILY HISTORY */} {patient.family_history && (patient.family_history || []).length > 0 && ( <div className="space-y-2 pt-2 pt-4"> <span className="text-xs font-bold text-slate-700 dark:text-slate-300"> Family Clinical History: </span> <div className="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs"> {(patient.family_history || []).map((item, idx) => ( <div key={idx} className="p-2 rounded-lg bg-neutral-50 dark:bg-slate-900/40 flex justify-between" > <span className="font-semibold"> {item.morbidity_name} ({item.relationship}) </span> <span className="text-neutral-500 font-mono"> {item.notes} </span> </div> ))} </div> </div> )} {/* ONCOLOGY RISK FACTORS */} {patient.risk_factors && (patient.risk_factors || []).length > 0 && ( <div className="space-y-2 pt-2 pt-4"> <span className="text-xs font-bold text-slate-700 dark:text-slate-300"> Oncology Risk Factors: </span> <div className="flex flex-wrap gap-1.5"> {(patient.risk_factors || []).map((item, idx) => ( <span key={idx} className="px-2 py-1 bg-amber-500/10 text-amber-600 dark:text-amber-400 font-mono text-[10px] rounded font-medium" > {item.risk_factor_name} {item.notes && `(${item.notes})`} </span> ))} </div> </div> )} {/* ANTHROPOMETRIC MEASUREMENTS */} {patient.examination_findings && patient.examination_findings.filter(f => f.examination_type !== "Organ System").length > 0 && ( <div className="space-y-2 pt-2 pt-4"> <span className="text-xs font-bold text-slate-700 dark:text-slate-300"> Anthropometric Measurements: </span> <div className="grid grid-cols-1 sm:grid-cols-3 gap-3 text-xs"> {patient.examination_findings .filter(f => f.examination_type !== "Organ System") .map((item, idx) => ( <div key={idx} className="p-2.5 rounded-lg bg-neutral-50 dark:bg-slate-900/40 border dark:border-slate-800 space-y-1" > <div className="flex justify-between items-center"> <span className="font-bold text-slate-700 dark:text-slate-300"> {item.examination_type} </span> <span className="text-[10px] text-neutral-400 font-mono"> {item.date} </span> </div> <p className="text-neutral-500 text-[11px] font-mono"> {item.findings} </p> </div> ))} </div> </div> )} {/* PHYSICAL EXAMINATIONS */} {patient.examination_findings && patient.examination_findings.filter(f => f.examination_type === "Organ System").length > 0 && ( <div className="space-y-2 pt-2 pt-4"> <span className="text-xs font-bold text-slate-700 dark:text-slate-300"> Physical Examinations: </span> <div className="grid grid-cols-1 sm:grid-cols-3 gap-3 text-xs"> {patient.examination_findings .filter(f => f.examination_type === "Organ System") .map((item, idx) => ( <div key={idx} className="p-2.5 rounded-lg bg-neutral-50 dark:bg-slate-900/40 border dark:border-slate-800 space-y-1" > <div className="flex justify-between items-center"> <span className="font-bold text-slate-700 dark:text-slate-300"> {item.organ_system_name || "Organ System"} </span> <span className="text-[10px] text-neutral-400 font-mono"> {item.date} </span> </div> <p className="text-neutral-500 text-[11px] font-mono"> {item.findings} </p> </div> ))} </div> </div> )} {/* USUAL PRESCRIPTIONS */} {patient.usual_prescriptions && (patient.usual_prescriptions || []).length > 0 && ( <div className="space-y-2 pt-2 pt-4"> <span className="text-xs font-bold text-slate-700 dark:text-slate-300"> Long-term Home Prescriptions: </span> <div className="space-y-1.5 text-xs"> {(patient.usual_prescriptions || []).map((item, idx) => ( <div key={idx} className="p-2 rounded-lg bg-neutral-50 dark:bg-slate-900/40 flex flex-col sm:flex-row sm:justify-between" > <span className="font-semibold"> {item.drug_name} ({item.dose} - {item.frequency}) </span> <span className="text-neutral-500 font-mono text-[11px]"> {item.duration} {item.notes && `• ${item.notes}`} </span> </div> ))} </div> </div> )} {/* SOCIAL HISTORIES & PERSONAL HABITS */} {patient.social_history && ( <div className="space-y-2 pt-2 pt-4 text-xs"> <span className="font-bold text-slate-700 dark:text-slate-300"> Lifestyle Habits & Social Profile: </span> <div className="grid grid-cols-1 sm:grid-cols-2 gap-4"> <div className="p-2.5 rounded-lg bg-neutral-50 dark:bg-slate-900/40"> <p className="font-semibold text-slate-600 dark:text-slate-400"> Smoking Habit: </p> <p className="mt-1"> <span className={`px-1.5 py-0.5 rounded text-[10px] font-bold ${ patient.social_history.smoking?.status === "Current" ? "bg-rose-500/10 text-rose-500" : "bg-neutral-500/15 text-neutral-400" }`} > {patient.social_history.smoking?.status || "Non consumer"} </span> {patient.social_history.smoking?.amounts && ( <span className="font-mono text-neutral-500 ml-2"> ({patient.social_history.smoking?.amounts}) </span> )} </p> </div> <div className="p-2.5 rounded-lg bg-neutral-50 dark:bg-slate-900/40"> <p className="font-semibold text-slate-600 dark:text-slate-400"> Alcohol Habit: </p> <p className="mt-1"> <span className={`px-1.5 py-0.5 rounded text-[10px] font-bold ${ patient.social_history.alcohol?.status === "Current" ? "bg-rose-500/10 text-rose-500" : "bg-neutral-500/15 text-neutral-400" }`} > {patient.social_history.alcohol?.status || "Non consumer"} </span> {patient.social_history.alcohol?.amounts && ( <span className="font-mono text-neutral-500 ml-2"> ({patient.social_history.alcohol?.amounts}) </span> )} </p> </div> </div> </div> )} </div> {/* SECTION D: TABBED PATHOLOGY LABORATORY INVESTIGATIONS */} <div className="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-sm space-y-6"> <h3 className="text-sm font-bold pb-2 flex items-center gap-2"> <Dna className="w-4.5 h-4.5 text-emerald-500 animate-pulse" /> Pathology Laboratory Investigations </h3> {/* TABS SELECTS */} <div className="flex border-b border-neutral-100 dark:border-slate-700 gap-2 text-xs overflow-x-auto whitespace-nowrap"> {( [ "imaging", "biopsies", "endoscopy", "ihc", "genetic", "tumour_markers", "others", ] as const ).map((tab) => ( <button key={tab} type="button" onClick={() => setActiveInvTab(tab)} className={`px-3 py-2 font-bold border-b-2 capitalize transition-all ${ activeInvTab === tab ? "border-emerald-500 text-emerald-600 dark:text-emerald-400" : "border-transparent text-neutral-400 hover:text-slate-600" }`} > {tab === "ihc" ? "IHC" : tab === "tumour_markers" ? "tumour markers" : tab} </button> ))} </div> {/* IMAGING TAB CONTENT */} {activeInvTab === "imaging" && ( <div className="space-y-4 text-xs"> {(patient.investigations?.imaging || []).map((item, i) => ( <div key={i} className="p-4 rounded-xl bg-neutral-50 dark:bg-slate-900/40 space-y-2.5 border dark:border-slate-800" > <div className="flex justify-between items-center bg-white dark:bg-slate-800/60 p-2 rounded-lg border dark:border-slate-700/60"> <div className="flex flex-wrap items-center gap-2"> <span className="font-bold uppercase text-emerald-500 text-[10px] tracking-wide"> Modality: {item.modality} </span> {item.purpose && ( <span className="px-1.5 py-0.5 rounded bg-blue-500/10 text-blue-500 text-[9px] font-bold"> {item.purpose} </span> )} </div> <span className="font-mono text-neutral-400 text-[10px]"> {item.date} </span> </div> <div className="grid grid-cols-2 gap-4 text-[11px]"> <div> <span className="text-neutral-405 block"> Mass lesion identified? </span> <span className="font-bold text-slate-700 dark:text-slate-300"> {item.mass_present} </span> </div> {item.mass_pr