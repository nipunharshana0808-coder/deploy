# Copy to .env for local development, and add the same variables in Vercel.

# Firebase client config used by the browser app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin service account JSON used by the API for Firestore REST.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_WEB_PROJECT_ID=

# Google Drive media vault. OAuth refresh-token mode is for an ordinary My Drive.
DRIVE_FOLDER_ID=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
VITE_DRIVE_ROOT_FOLDER_ID=

# Gemini primary/secondary fallback.
GEMINI_API_KEY_PRIMARY=
GEMINI_MODEL_PRIMARY=auto
GEMINI_API_KEY_SECONDARY=
GEMINI_MODEL_SECONDARY=auto
