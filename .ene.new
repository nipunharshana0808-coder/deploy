# Add these in Vercel > Project > Settings > Environment Variables.
# Keep this file as placeholders only. Never commit real credentials.
FIREBASE_WEB_API_KEY=your_firebase_web_api_key
FIREBASE_WEB_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_WEB_PROJECT_ID=your_project_id
FIREBASE_WEB_APP_ID=1:123456789:web:abc123
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}
# Use these three OAuth values for a free dedicated Google account with ordinary My Drive.
GOOGLE_DRIVE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=your_client_secret
GOOGLE_DRIVE_REFRESH_TOKEN=your_refresh_token
# Optional alternative for Google Workspace Shared Drives only:
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"REPLACE_ME"}
DRIVE_FOLDER_ID=your_drive_folder_id
GEMINI_API_KEY_PRIMARY=your_gemini_api_key
# Optional. Use one model, comma-separated fallback models, or auto.
GEMINI_MODEL_PRIMARY=auto
GEMINI_API_KEY_SECONDARY=your_secondary_gemini_api_key
# Optional. Use one model, comma-separated fallback models, or auto.
GEMINI_MODEL_SECONDARY=auto
OPENROUTER_API_KEY=
# Optional. Use one OpenRouter model, comma-separated fallback models, or auto.
OPENROUTER_MODEL=auto
ALLOWED_ORIGINS=https://YOUR-PROJECT.vercel.app
